<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ViewPrism2.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="ViewPrism2.App.Views.TagsTabView"
             x:DataType="vm:TagsTabViewModel">
  <!-- タグタブ(3 ペイン、仕様 §2.6 / G-6 / ECO-099):
       左=ビュー管理 / 中央=階層構造エディタ(バッチ保存・配置モデル統一) / 右=タグパレット。
       CAD= ViewPrismUI docs/screens/tag_tab.md(2026-07-16 mock v3)+captures/tag_tab/。
       配置=クリック配置(placing)+挿入ポイント+「＋ 子にする」。行操作=「⋯」メニューへ集約、
       状態は HOME/条件チップ(VC-TAG-12/13/14)。 -->

  <UserControl.Resources>
    <!-- GF-03(REQ-060(c)): ホームタグのアイコンは家形シルエット(★は不可)。
         PathIcon+StreamGeometry 直書き(フォントアイコン依存禁止 — K-DESIGN v2.0)。 -->
    <StreamGeometry x:Key="HomeIconGeometry">M12 3 L3 10 L5 10 L5 20 L10 20 L10 14 L14 14 L14 20 L19 20 L19 10 L21 10 Z</StreamGeometry>
    <!-- ECO-099: 行ハンドル(⠿・mock 子行の grab ドット 6 個。第一便は表示のみ=TAG-014) -->
    <StreamGeometry x:Key="GripDotsGeometry">M7.4,6a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0 M13.4,6a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0 M7.4,12a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0 M13.4,12a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0 M7.4,18a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0 M13.4,18a1.6,1.6 0 1,0 3.2,0a1.6,1.6 0 1,0 -3.2,0</StreamGeometry>

    <!-- ECO-099: 階層行の再帰テンプレート(mock DOM と同型= 行+子ブロック〔左ガイド線〕の入れ子)。
         mock は 2 階層プロトタイプ — 行ハンドル/カレット/挿入ポイント寸法は IsRootLevel で一般化。 -->
    <DataTemplate x:Key="HierarchyNodeTemplate" x:DataType="vm:EditNodeViewModel">
      <StackPanel>
        <!-- 挿入ポイント(この行の前=兄弟挿入・VC-TAG-12③)。配置/移動ドラッグ共通(ECO-100)。
             per-node 可視=禁止位置(移動元サブツリー内部)は出さない(裁定 b)。 -->
        <Border Classes="insertPoint ipBefore" Classes.rootLv="{Binding IsRootLevel}"
                IsVisible="{Binding InsertBeforeTargetVisible}"
                ToolTip.Tip="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[hierarchy.insertHere]}"
                PointerPressed="OnInsertBeforePressed">
          <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
            <Ellipse Classes="insertDot" />
            <Border Grid.Column="1" Classes="insertLine" />
          </Grid>
        </Border>

        <!-- 行本体(mock: 親行 44px/子行 42px・行高不変=layoutInvariant)。
             ECO-100(裁定 a): 行全体ドラッグ=移動。クリック(展開/選択)は閾値未満のリリースで確定。 -->
        <Border Classes="nodeRow" Classes.child="{Binding !IsRootLevel}" Classes.selected="{Binding IsSelected}"
                Classes.moveSource="{Binding IsMoveSource}"
                PointerPressed="OnNodeRowPressed" PointerMoved="OnNodeRowMoved" PointerReleased="OnNodeRowReleased"
                PointerCaptureLost="OnNodeRowCaptureLost">
          <DockPanel>
            <!-- 行末アクション(右端から: ⋯ → 家ゴースト)。配置モード中は一時停止=非表示(VC-TAG-12⑦/v3 MOCK 裁定) -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                        IsVisible="{Binding !$parent[UserControl].((vm:TagsTabViewModel)DataContext).Editor.ShowInsertTargets}">
              <!-- ホーム1クリック(VC-TAG-14): 行ホバー時のみ出現するゴーストボタン。トグル=既存 ToggleHome -->
              <Button Classes="homeGhost" ToolTip.Tip="{Binding HomeButtonTitle}"
                      Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Editor.ToggleHomeCommand}"
                      CommandParameter="{Binding}">
                <PathIcon Data="{StaticResource HomeIconGeometry}" Width="15" Height="15" />
              </Button>
              <!-- 行操作の集約(VC-TAG-13): ⋯メニュー。背景クリックで閉じる=Flyout light dismiss -->
              <Button Classes="rowMenuBtn">
                <PathIcon Data="{StaticResource MoreIcon}" Width="15" Height="15" />
                <Button.Flyout>
                  <Flyout Placement="BottomEdgeAlignedRight" FlyoutPresenterClasses="rowMenu">
                    <Border Classes="rowMenuPanel">
                      <StackPanel Spacing="1">
                        <Button Classes="rowMenuItem" Click="OnMenuSetHomeClick">
                          <StackPanel Orientation="Horizontal" Spacing="9">
                            <PathIcon Data="{StaticResource HomeIconGeometry}" />
                            <TextBlock Text="{Binding MenuSetHomeText}" />
                          </StackPanel>
                        </Button>
                        <Button Classes="rowMenuItem" Click="OnMenuRenameClick">
                          <StackPanel Orientation="Horizontal" Spacing="9">
                            <PathIcon Data="{StaticResource PencilIcon}" />
                            <TextBlock Text="{Binding MenuRenameText}" />
                          </StackPanel>
                        </Button>
                        <Button Classes="rowMenuItem" Click="OnMenuSetConditionClick"
                                IsEnabled="{Binding CanHaveCondition}">
                          <StackPanel Orientation="Horizontal" Spacing="9">
                            <PathIcon Data="{StaticResource FunnelIcon}" />
                            <TextBlock Text="{Binding MenuSetConditionText}" />
                          </StackPanel>
                        </Button>
                        <Border Classes="rowMenuSep" />
                        <Button Classes="rowMenuItem danger" Click="OnMenuDeleteClick">
                          <StackPanel Orientation="Horizontal" Spacing="9">
                            <PathIcon Data="{StaticResource TrashIcon}" />
                            <TextBlock Text="{Binding MenuRemoveText}" />
                          </StackPanel>
                        </Button>
                      </StackPanel>
                    </Border>
                  </Flyout>
                </Button.Flyout>
              </Button>
            </StackPanel>
            <!-- 「＋ 子にする」(VC-TAG-12④): 配置/移動ドラッグ共通(ECO-100)。子として受ける面。
                 破線=Rectangle 重ね(Border 非対応)。禁止位置(移動元の自身・子孫)は出さない(裁定 b)。 -->
            <Border DockPanel.Dock="Right" Classes="makeChild" Cursor="Hand" Margin="8,0,2,0"
                    IsVisible="{Binding ChildTargetVisible}"
                    PointerPressed="OnMakeChildPressed">
              <Panel>
                <Rectangle Classes="makeChildDash" />
                <TextBlock Classes="makeChildText" Margin="9,3"
                           Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[hierarchy.makeChild]}" />
              </Panel>
            </Border>
            <!-- 子数バッジ(mock childCount) -->
            <Border DockPanel.Dock="Right" Classes="childCountPill" IsVisible="{Binding HasChildren}" Margin="6,0,0,0">
              <TextBlock Text="{Binding ChildCount}" />
            </Border>
            <!-- 数値タグの定義域メタ(mock node.meta="1–5 ★") -->
            <Border DockPanel.Dock="Right" Classes="numMetaPill" IsVisible="{Binding HasNumericMeta}" Margin="6,0,0,0">
              <TextBlock Text="{Binding NumericMeta}" />
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <!-- 子行=行ハンドル(表示のみ・D&D 挙動は第二便 TAG-014) -->
              <PathIcon Classes="rowHandle" Data="{StaticResource GripDotsGeometry}" Width="14" Height="14"
                        IsVisible="{Binding !IsRootLevel}" />
              <!-- 子ありの行=展開カレット(クリックで開閉) -->
              <PathIcon Classes="caret" Classes.expanded="{Binding IsExpanded}"
                        Data="{StaticResource ChevronRightIcon}" Width="15" Height="15"
                        IsVisible="{Binding HasChildren}" />
              <!-- ルートの葉行=カレット幅スペーサー(mock isLeaf) -->
              <Border Width="16" IsVisible="{Binding ShowLeafSpacer}" />
              <!-- 色ドット+淡色リング(mock dotStyle) -->
              <Border Classes="dotRing" Background="{Binding RingColor}" IsVisible="{Binding HasColor}">
                <Ellipse Width="11" Height="11" Fill="{Binding Color}" />
              </Border>
              <Ellipse Width="11" Height="11" Stroke="{StaticResource BorderLineBrush}" StrokeThickness="2"
                       IsVisible="{Binding !HasColor}" VerticalAlignment="Center" />
              <TextBlock Classes="nodeName" Text="{Binding DisplayName}"
                         IsVisible="{Binding !IsEditingAlias}" VerticalAlignment="Center"
                         FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
              <!-- 別名インライン編集(TAG-015①裁定=従来契約踏襲: Enter 確定/Esc 取消/空→タグ名) -->
              <TextBox Text="{Binding AliasEditText}" IsVisible="{Binding IsEditingAlias}"
                       MinWidth="120" FontSize="13" Padding="6,3"
                       KeyDown="OnAliasKeyDown" LostFocus="OnAliasLostFocus" />
              <Border Classes="typeChip" Classes.simple="{Binding IsSimple}" Classes.text="{Binding IsTextual}"
                      Classes.number="{Binding IsNumeric}" IsVisible="{Binding HasType}">
                <TextBlock Text="{Binding TypeText}" />
              </Border>
              <!-- HOME チップ(VC-TAG-13④: 淡青・常時表示・非対話) -->
              <Border Classes="homePill" IsVisible="{Binding IsHome}">
                <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[hierarchy.homePill]}" />
              </Border>
              <!-- 展開モードバッジ(REQ-096/ECO-086・非既定のみ=CAD VC-TAG-3・条件バッジの左) -->
              <Border IsVisible="{Binding HasExpansionBadge}" Background="#f2edfc" CornerRadius="6"
                      Padding="7,2" VerticalAlignment="Center">
                <TextBlock Text="{Binding ExpansionBadgeText}" FontSize="11" Foreground="#7c53d6"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
              </Border>
              <!-- 条件チップ(VC-TAG-13⑤: 琥珀へ統一・非対話。TAG-015③裁定=幅上限+省略+ツールチップ) -->
              <Border Classes="condChip" IsVisible="{Binding HasCondition}"
                      ToolTip.Tip="{Binding ConditionSummary}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <PathIcon Data="{StaticResource FunnelIcon}" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding ConditionSummary}" VerticalAlignment="Center"
                             MaxWidth="150" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Border>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- 子ブロック(mock: margin-left 18+pad 10+左ガイド線)。展開中のみ -->
        <Border Classes="childrenBlock" IsVisible="{Binding ShowChildren}">
          <StackPanel Spacing="2">
            <ItemsControl ItemsSource="{Binding Children}" ItemTemplate="{StaticResource HierarchyNodeTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="2" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
            <!-- 子リスト末尾の挿入ポイント(VC-TAG-12③「各子リスト末尾」・配置/移動共通=ECO-100) -->
            <Border Classes="insertPoint ipChildEnd"
                    IsVisible="{Binding ChildTargetVisible}"
                    ToolTip.Tip="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[hierarchy.insertAtEnd]}"
                    PointerPressed="OnInsertChildEndPressed">
              <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                <Ellipse Classes="insertDot" />
                <Border Grid.Column="1" Classes="insertLine" />
              </Grid>
            </Border>
          </StackPanel>
        </Border>
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- ECO-007/E1: ビュー行のタグ数バッジ(配置タグ数=階層ノード数)。控えめなピル。 -->
    <Style Selector="Border.tagCountBadge">
      <Setter Property="Background" Value="{StaticResource BorderLineBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="7,1" />
      <Setter Property="MinWidth" Value="22" />
      <Setter Property="Margin" Value="6,0" />
    </Style>
    <Style Selector="Border.tagCountBadge TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ============ ECO-099: 階層行(mock 行テンプレート) ============ -->
    <Style Selector="Border.nodeRow">
      <Setter Property="Height" Value="44" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.nodeRow.child">
      <Setter Property="Height" Value="42" />
    </Style>
    <Style Selector="Border.nodeRow:pointerover">
      <Setter Property="Background" Value="#f4f6fa" />
    </Style>
    <Style Selector="Border.nodeRow.selected">
      <Setter Property="Background" Value="#eaf1fe" />
    </Style>
    <Style Selector="Border.nodeRow.selected:pointerover">
      <Setter Property="Background" Value="#eaf1fe" />
    </Style>
    <!-- ECO-100(裁定 e): 移動ドラッグの元行は減光(既存 D&D 言語の範囲。独自ゴーストは作らない) -->
    <Style Selector="Border.nodeRow.moveSource">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <!-- ECO-100: ドラッグオーバー中の受け面強調= :pointerover と同色(新しい視覚言語を発明しない) -->
    <Style Selector="Border.insertPoint.dropHover">
      <Setter Property="Background" Value="#f3f8ff" />
    </Style>
    <Style Selector="Border.makeChild.dropHover">
      <Setter Property="Background" Value="#eaf1fe" />
    </Style>
    <Style Selector="Border.makeChild.dropHover Rectangle.makeChildDash">
      <Setter Property="Stroke" Value="#2f6bed" />
    </Style>
    <Style Selector="PathIcon.rowHandle">
      <Setter Property="Foreground" Value="#cbd1da" />
    </Style>
    <Style Selector="PathIcon.caret">
      <Setter Property="Foreground" Value="#98a0ad" />
      <Setter Property="RenderTransform" Value="rotate(0deg)" />
    </Style>
    <Style Selector="PathIcon.caret.expanded">
      <Setter Property="RenderTransform" Value="rotate(90deg)" />
    </Style>
    <Style Selector="Border.dotRing">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.childrenBlock">
      <Setter Property="Margin" Value="18,0,0,4" />
      <Setter Property="Padding" Value="10,0,0,0" />
      <Setter Property="BorderThickness" Value="1.5,0,0,0" />
      <Setter Property="BorderBrush" Value="#eef0f4" />
    </Style>
    <Style Selector="Border.childCountPill">
      <Setter Property="Background" Value="#f1f3f7" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.childCountPill TextBlock">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="#98a0ad" />
    </Style>
    <Style Selector="Border.numMetaPill">
      <Setter Property="Background" Value="#fbf3df" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.numMetaPill TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#9a7b1a" />
    </Style>

    <!-- 挿入ポイント(VC-TAG-12③: 小円=白地 #7ea4f2 輪郭+ライン #c7d8fb・ホバー #f3f8ff) -->
    <Style Selector="Border.insertPoint">
      <Setter Property="Height" Value="12" />
      <Setter Property="Padding" Value="8,0" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.insertPoint.rootLv">
      <Setter Property="Height" Value="14" />
    </Style>
    <Style Selector="Border.insertPoint:pointerover">
      <Setter Property="Background" Value="#f3f8ff" />
    </Style>
    <Style Selector="Ellipse.insertDot">
      <Setter Property="Width" Value="7" />
      <Setter Property="Height" Value="7" />
      <Setter Property="Fill" Value="White" />
      <Setter Property="Stroke" Value="#7ea4f2" />
      <Setter Property="StrokeThickness" Value="2" />
    </Style>
    <Style Selector="Border.insertLine">
      <Setter Property="Height" Value="2" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="#c7d8fb" />
      <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

    <!-- 「＋ 子にする」(VC-TAG-12④: 破線 #9dbcf7・文字 #2f6bed・ホバー #eaf1fe) -->
    <Style Selector="Border.makeChild">
      <Setter Property="Background" Value="White" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.makeChild:pointerover">
      <Setter Property="Background" Value="#eaf1fe" />
    </Style>
    <Style Selector="Rectangle.makeChildDash">
      <Setter Property="Stroke" Value="#9dbcf7" />
      <Setter Property="StrokeThickness" Value="1.5" />
      <Setter Property="StrokeDashArray" Value="3,2" />
      <Setter Property="RadiusX" Value="7" />
      <Setter Property="RadiusY" Value="7" />
      <Setter Property="Fill" Value="Transparent" />
    </Style>
    <Style Selector="Border.makeChild:pointerover Rectangle.makeChildDash">
      <Setter Property="Stroke" Value="#2f6bed" />
    </Style>
    <Style Selector="TextBlock.makeChildText">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#2f6bed" />
    </Style>

    <!-- 行末アクション(VC-TAG-13①/14①: ⋯=淡色、家ゴースト=行ホバー時のみ出現) -->
    <Style Selector="Button.rowMenuBtn, Button.homeGhost">
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.rowMenuBtn PathIcon">
      <Setter Property="Foreground" Value="#c3c9d3" />
    </Style>
    <Style Selector="Button.rowMenuBtn /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.rowMenuBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#eef1f5" />
    </Style>
    <Style Selector="Button.rowMenuBtn:pointerover PathIcon">
      <Setter Property="Foreground" Value="#5b6473" />
    </Style>
    <Style Selector="Button.homeGhost">
      <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="Border.nodeRow:pointerover Button.homeGhost">
      <Setter Property="IsVisible" Value="True" />
    </Style>
    <Style Selector="Button.homeGhost PathIcon">
      <Setter Property="Foreground" Value="#aab1bd" />
    </Style>
    <Style Selector="Button.homeGhost /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.homeGhost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#eaf1fe" />
    </Style>
    <Style Selector="Button.homeGhost:pointerover PathIcon">
      <Setter Property="Foreground" Value="#2459cf" />
    </Style>

    <!-- ⋯メニュー(VC-TAG-13②③: 幅178/角丸11/影・削除のみ警告色・カード外へ重なる=Popup) -->
    <Style Selector="FlyoutPresenter.rowMenu">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Border.rowMenuPanel">
      <Setter Property="Width" Value="178" />
      <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="#e2e6ec" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="5" />
      <Setter Property="BoxShadow" Value="0 14 34 -12 #47142040" />
    </Style>
    <Style Selector="Button.rowMenuItem">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.rowMenuItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.rowMenuItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#f4f6fa" />
    </Style>
    <Style Selector="Button.rowMenuItem PathIcon">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
      <Setter Property="Foreground" Value="#98a0ad" />
    </Style>
    <Style Selector="Button.rowMenuItem.danger">
      <Setter Property="Foreground" Value="#c4282d" />
    </Style>
    <Style Selector="Button.rowMenuItem.danger PathIcon">
      <Setter Property="Foreground" Value="#c4282d" />
    </Style>
    <Style Selector="Button.rowMenuItem.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#fbeaea" />
    </Style>
    <Style Selector="Border.rowMenuSep">
      <Setter Property="Height" Value="1" />
      <Setter Property="Background" Value="#eef0f4" />
      <Setter Property="Margin" Value="6,4" />
    </Style>

    <!-- ヘッダ帯(VC-TAG-12②: 通常ヒント ⇔ 配置中チップ+Esc 解除) -->
    <Style Selector="TextBlock.placeHint">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#aab1bd" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.placingBand">
      <Setter Property="Background" Value="#eaf1fe" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.placingBand TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#2459cf" />
    </Style>
    <Style Selector="Button.escRelease">
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="#dfe3ea" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.escRelease:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#f1f3f7" />
    </Style>

    <!-- ============ ECO-103: 保存モデル(mock v4・VC-TAG-16) ============ -->
    <Style Selector="Border.unsavedChip">
      <Setter Property="Background" Value="#fbf3df" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="9,3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.unsavedChip TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#9a7b1a" />
    </Style>

    <Style Selector="Border.saveBar">
      <Setter Property="Background" Value="#1d2430" />
      <Setter Property="CornerRadius" Value="13" />
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#14ffffff" />
      <Setter Property="BoxShadow" Value="0 16 40 -12 #66141c2c" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform />
        </Setter.Value>
      </Setter>
    </Style>
    <!-- vpRise 近似(下から 12px・0.3s): 出現時にスタイルアニメで再生 -->
    <Style Selector="Border.saveBar">
      <Style.Animations>
        <Animation Duration="0:0:0.3" FillMode="Forward">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="TranslateTransform.Y" Value="12" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="TranslateTransform.Y" Value="0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- attention(VC-TAG-16③): 琥珀ボーダー+vpShake 近似(±9px・0.5s) -->
    <Style Selector="Border.saveBar.attention">
      <Setter Property="BorderBrush" Value="#b3e8b931" />
      <Style.Animations>
        <Animation Duration="0:0:0.5" FillMode="Forward">
          <KeyFrame Cue="0%"><Setter Property="TranslateTransform.X" Value="0" /></KeyFrame>
          <KeyFrame Cue="15%"><Setter Property="TranslateTransform.X" Value="-9" /></KeyFrame>
          <KeyFrame Cue="35%"><Setter Property="TranslateTransform.X" Value="9" /></KeyFrame>
          <KeyFrame Cue="55%"><Setter Property="TranslateTransform.X" Value="-9" /></KeyFrame>
          <KeyFrame Cue="75%"><Setter Property="TranslateTransform.X" Value="9" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="TranslateTransform.X" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <!-- GF-103-02: 琥珀ドットのハロー(mock= box-shadow 0 0 0 3px rgba(232,185,49,.22))。
         ナビの unsavedDot と同じリング様式(MainWindow.axaml)= 22%α 地+Padding 3。 -->
    <Style Selector="Border.saveBarDot">
      <Setter Property="Background" Value="#38e8b931" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.saveBarMsg">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#dfe4ec" />
    </Style>
    <Style Selector="Border.saveBar.attention TextBlock.saveBarMsg">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#f5d979" />
    </Style>
    <Style Selector="Button.saveBarDiscard">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="13,0" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#c6cede" />
      <!-- GF-103-01: 固定高+Padding縦0 は縦中央を明示継承(ECO-040 規約。既定 Stretch で上寄り) -->
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.saveBarDiscard /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.saveBarDiscard:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#17ffffff" />
    </Style>
    <Style Selector="Button.saveBarDiscard:pointerover">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.saveBarSave">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="White" />
      <!-- GF-103-01: 同上(ECO-040 規約) -->
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <!-- Fluent Button は背景を ContentPresenter が描く — グラデはそちらへ(GF-056-02 系の罠回避) -->
    <Style Selector="Button.saveBarSave /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#4a82f0" Offset="0" />
            <GradientStop Color="#2f6bed" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Button.saveBarSave:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#3f76eb" Offset="0" />
            <GradientStop Color="#255ed6" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="Button.saveBarSave TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Border.savedToast">
      <Setter Property="Background" Value="#0f8a5e" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="BoxShadow" Value="0 14 30 -10 #800f8a5e" />
    </Style>
    <Style Selector="Border.savedToast">
      <Style.Animations>
        <Animation Duration="0:0:0.25" FillMode="Forward">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.savedToast TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- パレット: 配置中カード(VC-TAG-12①: 強調枠+「配置中」チップ=白字・アクセント地) -->
    <Style Selector="Border.card.placing">
      <Setter Property="BorderBrush" Value="#cfe0fc" />
      <Setter Property="Background" Value="#f6faff" />
    </Style>
    <Style Selector="Border.placingChip">
      <Setter Property="Background" Value="#2f6bed" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="7,2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.placingChip TextBlock">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="240,1,*,1,300">
    <!-- 左: ビュー管理(新規ビュー・一覧・編集/削除・選択) -->
    <DockPanel Grid.Column="0" Background="{StaticResource PanelBrush}">
      <TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="{Binding Loc[view.viewManagement]}" />
      <!-- ECO-009 ②: 新規ビュー CTA(青グラデ) -->
      <Button DockPanel.Dock="Top" Classes="cta" Command="{Binding NewViewCommand}"
              Margin="12,4,12,10" HorizontalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource PlusIcon}" Width="14" Height="14" Foreground="White" />
          <TextBlock Text="{Binding Loc[view.newView]}" />
        </StackPanel>
      </Button>
      <TextBlock DockPanel.Dock="Top" Text="{Binding Loc[view.savedViews]}" FontSize="11"
                 Foreground="{StaticResource FaintTextBrush}" Margin="14,2,14,8" />
      <Panel>
        <ScrollViewer Padding="12,0,12,8">
          <ItemsControl ItemsSource="{Binding Views}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ViewRowViewModel">
                <!-- ECO-009 ②: ビューカード行(先頭アイコン+名前+タグ数+編集/削除。選択=淡青) -->
                <Border Classes="navCard" Classes.selected="{Binding IsSelected}" PointerPressed="OnViewRowPressed">
                  <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                      <Button Classes="iconBtn"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).EditViewCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource PencilIcon}" />
                      </Button>
                      <Button Classes="iconBtn danger"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).DeleteViewCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource TrashIcon}" />
                      </Button>
                    </StackPanel>
                    <!-- ECO-007/E1: タグ数バッジ(★なし・説明 tooltip)。 -->
                    <Border DockPanel.Dock="Right" Classes="countBadge" VerticalAlignment="Center"
                            ToolTip.Tip="{Binding Description}">
                      <TextBlock Text="{Binding TagCount}" />
                    </Border>
                    <Border DockPanel.Dock="Left" Classes="leadIcon" Margin="0,0,10,0">
                      <PathIcon Data="{StaticResource ViewListIcon}" />
                    </Border>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               ToolTip.Tip="{Binding Description}" />
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        <TextBlock Text="{Binding Loc[view.noViews]}" IsVisible="{Binding IsViewsEmpty}"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="14,4" TextWrapping="Wrap" />
      </Panel>
    </DockPanel>

    <Border Grid.Column="1" Background="{StaticResource BorderLineBrush}" />

    <!-- 中央: 階層構造エディタ(ECO-099: 配置モデル統一。上部見出し/保存は固定・本文スクロール=layoutInvariant) -->
    <DockPanel Grid.Column="2">
      <!-- ECO-103(mock v4): ヘッダの保存/キャンセルボタンは撤去=フローティング保存バーへ置換。
           未保存はヘッダ「未保存の変更」チップ(琥珀)で常時掲示(VC-TAG-16①)。 -->
      <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="14,8" MinHeight="32">
          <TextBlock Text="{Binding Loc[view.hierarchyStructure]}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Editor.ViewName}" Foreground="{StaticResource TextMutedBrush}"
                     VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          <Border Classes="unsavedChip" IsVisible="{Binding Editor.IsDirty}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <Ellipse Width="6" Height="6" Fill="#e8b931" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Loc[hierarchy.unsavedChip]}" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
      <!-- 本文(mock: ツリーカード+ガイダンスカードが一体でスクロール)+保存バー/トーストのフロート層 -->
      <Panel>
      <ScrollViewer>
        <StackPanel Margin="14,12,14,14" Spacing="14">
          <!-- コンテナカード(主役) -->
          <Border Classes="containerCard">
            <StackPanel>
              <Border Classes="cardHeader">
                <DockPanel>
                  <!-- ヘッダ帯(VC-TAG-12②): 通常ヒント ⇔ 「{タグ名}」を配置中+Esc 解除 -->
                  <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Classes="placeHint" IsVisible="{Binding !Editor.ShowInsertTargets}"
                               Text="{Binding Loc[hierarchy.placeHint]}" />
                    <!-- ECO-100(裁定 e): 帯は配置中と同型。移動中は InsertBannerText が移動 copy を返す -->
                    <Border Classes="placingBand" IsVisible="{Binding Editor.ShowInsertTargets}">
                      <TextBlock Text="{Binding Editor.InsertBannerText}" MaxWidth="420"
                                 TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Button Classes="escRelease" IsVisible="{Binding Editor.ShowInsertTargets}"
                            Command="{Binding Editor.CancelPlacingCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{Binding Loc[hierarchy.placingEsc]}" FontSize="11.5" FontWeight="SemiBold"
                                   Foreground="#5b6473" />
                        <TextBlock Text="{Binding Loc[hierarchy.placingRelease]}" FontSize="11.5"
                                   Foreground="#98a0ad" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource FolderIcon}" Width="16" Height="16"
                              Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Loc[hierarchy.viewStructure]}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Classes="accentPill" IsVisible="{Binding Editor.HasView}">
                      <TextBlock Text="{Binding Editor.NodeCountText}" />
                    </Border>
                  </StackPanel>
                </DockPanel>
              </Border>
              <Panel x:Name="TreeHost" Background="Transparent" DragDrop.AllowDrop="True" MinHeight="180">
                <!-- 空状態(仕様 §2.6): ビュー未選択 / 階層ノード 0 件 -->
                <TextBlock Text="{Binding Loc[view.selectViewPlease]}" IsVisible="{Binding !Editor.HasView}"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <StackPanel IsVisible="{Binding Editor.IsTreeEmpty}" Spacing="4"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Loc[view.noTagsAdded]}" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" />
                  <TextBlock Text="{Binding Loc[hierarchy.dropToAdd]}" Foreground="{StaticResource TextMutedBrush}"
                             FontSize="12" TextAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="8">
                  <ItemsControl ItemsSource="{Binding Editor.Roots}" ItemTemplate="{StaticResource HierarchyNodeTemplate}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="2" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                  </ItemsControl>
                  <!-- ルート末尾の挿入ポイント(VC-TAG-12③「ルート末尾」・配置/移動共通=ECO-100) -->
                  <Border Classes="insertPoint rootLv ipRootEnd" IsVisible="{Binding Editor.ShowInsertTargets}"
                          ToolTip.Tip="{Binding Loc[hierarchy.insertAtEnd]}"
                          PointerPressed="OnInsertRootEndPressed">
                    <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                      <Ellipse Classes="insertDot" />
                      <Border Grid.Column="1" Classes="insertLine" />
                    </Grid>
                  </Border>
                </StackPanel>
              </Panel>
            </StackPanel>
          </Border>
          <!-- ガイダンスカード(mock v3 文言。ツリーカードと一体でスクロール) -->
          <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1" CornerRadius="11" Padding="14,12">
            <DockPanel>
              <PathIcon DockPanel.Dock="Left" Data="{StaticResource InfoIcon}" Width="15" Height="15"
                        Foreground="#aab1bd" VerticalAlignment="Top" Margin="0,2,9,0" />
              <StackPanel Spacing="5">
                <TextBlock Text="{Binding Loc[hierarchy.guidePlace]}" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Loc[hierarchy.guideMenu]}" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Loc[hierarchy.guideHome]}" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Loc[hierarchy.helpViewUsage]}" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" />
              </StackPanel>
            </DockPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
      <!-- フローティング保存バー(VC-TAG-16②③: dirty 時のみ・ペイン下部中央・ダーク地。
           attention= 琥珀ボーダー+ガード文言/保存失敗理由(TAG-016 iv)+vpShake 相当)。 -->
      <Border Classes="saveBar" Classes.attention="{Binding Editor.IsSaveBarAttention}"
              IsVisible="{Binding Editor.IsDirty}"
              HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,18">
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border Classes="saveBarDot">
            <Ellipse Width="8" Height="8" Fill="#e8b931" />
          </Border>
          <TextBlock Classes="saveBarMsg" Text="{Binding Editor.SaveBarMessage}" VerticalAlignment="Center"
                     MaxWidth="440" TextTrimming="CharacterEllipsis" />
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Classes="saveBarDiscard" Content="{Binding Loc[hierarchy.saveBar.discard]}"
                    Command="{Binding Editor.CancelCommand}" />
            <Button Classes="saveBarSave" Command="{Binding Editor.SaveCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource CheckIcon}" Width="14" Height="14" Foreground="White" />
                <TextBlock Text="{Binding Loc[hierarchy.saveBar.save]}" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
      <!-- 保存トースト(VC-TAG-16④: 緑・1.8s 自動消滅=VM タイマ) -->
      <Border Classes="savedToast" IsVisible="{Binding Editor.IsSavedToastVisible}"
              HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <PathIcon Data="{StaticResource CheckIcon}" Width="14" Height="14" Foreground="White" />
          <TextBlock Text="{Binding Loc[hierarchy.savedToast]}" VerticalAlignment="Center" />
        </StackPanel>
      </Border>
      </Panel>
    </DockPanel>

    <Border Grid.Column="3" Background="{StaticResource BorderLineBrush}" />

    <!-- 右: タグパレット(ECO-009: モック CAD 準拠。ECO-099: クリック=配置モード・配置中カード強調) -->
    <DockPanel Grid.Column="4" Background="{StaticResource PanelBrush}">
      <!-- ヘッダ: タイトル+件数バッジ -->
      <DockPanel DockPanel.Dock="Top" Margin="16,14,16,8">
        <Border DockPanel.Dock="Right" Classes="countBadge" VerticalAlignment="Center">
          <TextBlock Text="{Binding Palette.TotalCount}" />
        </Border>
        <TextBlock Text="{Binding Loc[navigation.tagPalette]}" FontSize="15" FontWeight="SemiBold"
                   VerticalAlignment="Center" />
      </DockPanel>
      <!-- 検索 + 追加 CTA -->
      <DockPanel DockPanel.Dock="Top" Margin="16,0,16,10">
        <Button DockPanel.Dock="Right" Classes="cta" Command="{Binding Palette.NewTagCommand}" Margin="10,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Data="{StaticResource PlusIcon}" Width="14" Height="14" Foreground="White" />
            <TextBlock Text="{Binding Loc[common.add]}" />
          </StackPanel>
        </Button>
        <TextBox Text="{Binding Palette.SearchText}" PlaceholderText="{Binding Loc[tag.searchTags]}"
                 VerticalAlignment="Center" CornerRadius="10" Height="40" />
      </DockPanel>
      <!-- 件数 + 型凡例 -->
      <DockPanel DockPanel.Dock="Top" Margin="18,0,18,8">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="2" Background="{StaticResource ChipSimpleFg}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Loc[tag.type.simple]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="2" Background="{StaticResource ChipTextFg}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Loc[tag.type.textual]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="2" Background="{StaticResource ChipNumFg}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Loc[tag.type.numeric]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
        </StackPanel>
        <TextBlock Text="{Binding Palette.ItemCountText}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center" />
      </DockPanel>
      <TextBlock DockPanel.Dock="Bottom" Text="{Binding Palette.StatusMessage}"
                 Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="16,4" TextWrapping="Wrap" />
      <Panel>
        <ScrollViewer Padding="14,0,14,8">
          <ItemsControl ItemsSource="{Binding Palette.Tags}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:TagPaletteRowViewModel">
                <!-- ECO-099: クリック=配置モードのトグル/ドラッグ=従来 D&D(閾値で判別)。
                     カード強調は配置中のみ(mock cardStyle は placing 起点)。 -->
                <Border Classes="card" Classes.placing="{Binding IsPlacing}"
                        PointerPressed="OnPaletteItemPressed" PointerMoved="OnPaletteItemMoved"
                        PointerReleased="OnPaletteItemReleased" PointerCaptureLost="OnPaletteItemCaptureLost">
                  <StackPanel Spacing="9">
                    <!-- 行1: 色ドット+名前+型チップ+配置中チップ+アクション -->
                    <DockPanel>
                      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                        <Button Classes="iconBtn"
                                Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Palette.EditCommand}"
                                CommandParameter="{Binding}">
                          <PathIcon Data="{StaticResource PencilIcon}" />
                        </Button>
                        <Button Classes="iconBtn danger"
                                Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Palette.DeleteCommand}"
                                CommandParameter="{Binding}">
                          <PathIcon Data="{StaticResource TrashIcon}" />
                        </Button>
                      </StackPanel>
                      <!-- 「配置中」チップ(VC-TAG-12①: 白字・アクセント地) -->
                      <Border DockPanel.Dock="Right" Classes="placingChip" IsVisible="{Binding IsPlacing}" Margin="6,0,4,0">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.placing]}" />
                      </Border>
                      <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                        <Border Classes="dotRing" Background="{Binding RingColor}" IsVisible="{Binding HasColor}">
                          <Ellipse Width="11" Height="11" Fill="{Binding Color}" />
                        </Border>
                        <Ellipse Width="11" Height="11" Stroke="{StaticResource BorderLineBrush}" StrokeThickness="2"
                                 IsVisible="{Binding !HasColor}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Border Classes="typeChip" Classes.simple="{Binding IsSimple}"
                                Classes.text="{Binding IsTextual}" Classes.number="{Binding IsNumeric}">
                          <TextBlock Text="{Binding TypeText}" />
                        </Border>
                      </StackPanel>
                    </DockPanel>
                    <!-- テキスト: 候補値チップ。
                         ECO-089(ECO-088 同型): WrapPanel の折返し(mock flex-wrap)は有限幅測定が
                         前提 — 横 StackPanel は無限幅測定で折返し契機を奪い、多数候補値でカードが
                         押し広がり右端要素(編集/削除アイコン)が見切れる(VC-TAG-9)。
                         ECO-092(TAG-013=T-a): 候補値=閲覧プレビュー。最大 2 行+非対話「ほか N 件」
                         (件数のみ・展開/ポップオーバーなし)。長い値は幅上限+省略+ツールチップ。
                         定義順維持。折畳み計算は行 VM(実測供給は code-behind EvaluateCandidateRows)。
                         IMG-023A/B(操作面=ECO-091)とは別契約(VC-TAG-10)。 -->
                    <Grid ColumnDefinitions="Auto,*" Margin="20,0,0,0"
                          IsVisible="{Binding HasCandidateValues}">
                      <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.candidateValues]}"
                                 FontSize="11" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center"
                                 Margin="0,0,6,0" />
                      <ItemsControl Grid.Column="1" Classes="candidateStrip" ItemsSource="{Binding CandidateDisplay}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.DataTemplates>
                          <DataTemplate DataType="sys:String">
                            <Border Classes="valueChip" Margin="0,0,6,4" MaxWidth="130" ToolTip.Tip="{Binding}">
                              <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                            </Border>
                          </DataTemplate>
                          <DataTemplate DataType="vm:ChipMoreVM">
                            <TextBlock Classes="valueMore" Text="{Binding Label}" Margin="0,0,6,4" />
                          </DataTemplate>
                        </ItemsControl.DataTemplates>
                      </ItemsControl>
                    </Grid>
                    <!-- 数値: 範囲ピル+刻み -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="20,0,0,0"
                                IsVisible="{Binding HasRange}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.range]}"
                                 FontSize="11" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                      <Border Classes="rangePill"><TextBlock Text="{Binding RangeText}" /></Border>
                      <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding HasStep}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.step]}"
                                   FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" />
                        <TextBlock Text="{Binding StepValue}" FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" />
                      </StackPanel>
                    </StackPanel>
                    <!-- シンプル: 注記 -->
                    <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.simpleNote]}"
                               IsVisible="{Binding IsSimple}" Margin="20,0,0,0" FontSize="11.5"
                               Foreground="{StaticResource FaintTextBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        <TextBlock Text="{Binding Loc[tag.noTags]}" IsVisible="{Binding Palette.IsEmpty}"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="16,4" TextWrapping="Wrap" />
      </Panel>
    </DockPanel>
  </Grid>
</UserControl>
