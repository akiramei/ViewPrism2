<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ViewPrism2.App.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="ViewPrism2.App.Views.TagsTabView"
             x:DataType="vm:TagsTabViewModel">
  <!-- タグタブ(3 ペイン、仕様 §2.6 v1.2 / G-6):
       左=ビュー管理 / 中央=階層構造エディタ(バッチ保存) / 右=タグパレット -->

  <UserControl.Resources>
    <!-- GF-03(REQ-060(c)): ホームタグのアイコンは家形シルエット(★は不可)。
         PathIcon+StreamGeometry 直書き(フォントアイコン依存禁止 — K-DESIGN v2.0)。 -->
    <StreamGeometry x:Key="HomeIconGeometry">M12 3 L3 10 L5 10 L5 20 L10 20 L10 14 L14 14 L14 20 L19 20 L19 10 L21 10 Z</StreamGeometry>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="TreeView#HierarchyTree TreeViewItem" x:DataType="vm:EditNodeViewModel">
      <!-- 展開/折畳(仕様 §2.6 のノード操作)を VM の状態と同期 -->
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
    </Style>
    <Style Selector="Button.mini.homeOn PathIcon">
      <!-- ホーム設定中のトグルアイコンはアクセント色で強調(GF-03) -->
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="Button.mini.homeOff PathIcon">
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.nodeName.home">
      <!-- ホームタグ設定中ノードの強調表示(G-6) -->
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <!-- ECO-009: パレットの選択強調・型チップは Styles/Components.axaml の card / typeChip へ移行。 -->

    <!-- ECO-007/E1: ビュー行のタグ数バッジ(配置タグ数=階層ノード数)。控えめなピル。 -->
    <Style Selector="Border.tagCountBadge">
      <Setter Property="Background" Value="{StaticResource BorderLineBrush}" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="7,1" />
      <Setter Property="MinWidth" Value="22" />
      <Setter Property="Margin" Value="6,0" />
    </Style>
    <Style Selector="Border.tagCountBadge TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="240,1,*,1,300">
    <!-- 左: ビュー管理(新規ビュー・一覧・編集/削除・選択) -->
    <DockPanel Grid.Column="0" Background="{StaticResource PanelBrush}">
      <TextBlock DockPanel.Dock="Top" Classes="sectionHeader" Text="{Binding Loc[view.viewManagement]}" />
      <!-- ECO-009 ②: 新規ビュー CTA(青グラデ) -->
      <Button DockPanel.Dock="Top" Classes="cta" Command="{Binding NewViewCommand}"
              Margin="12,4,12,10" HorizontalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource PlusIcon}" Width="14" Height="14" Foreground="White" />
          <TextBlock Text="{Binding Loc[view.newView]}" />
        </StackPanel>
      </Button>
      <TextBlock DockPanel.Dock="Top" Text="{Binding Loc[view.savedViews]}" FontSize="11"
                 Foreground="{StaticResource FaintTextBrush}" Margin="14,2,14,8" />
      <Panel>
        <ScrollViewer Padding="12,0,12,8">
          <ItemsControl ItemsSource="{Binding Views}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ViewRowViewModel">
                <!-- ECO-009 ②: ビューカード行(先頭アイコン+名前+タグ数+編集/削除。選択=淡青) -->
                <Border Classes="navCard" Classes.selected="{Binding IsSelected}" PointerPressed="OnViewRowPressed">
                  <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                      <Button Classes="iconBtn"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).EditViewCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource PencilIcon}" />
                      </Button>
                      <Button Classes="iconBtn danger"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).DeleteViewCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource TrashIcon}" />
                      </Button>
                    </StackPanel>
                    <!-- ECO-007/E1: タグ数バッジ(★なし・説明 tooltip)。 -->
                    <Border DockPanel.Dock="Right" Classes="countBadge" VerticalAlignment="Center"
                            ToolTip.Tip="{Binding Description}">
                      <TextBlock Text="{Binding TagCount}" />
                    </Border>
                    <Border DockPanel.Dock="Left" Classes="leadIcon" Margin="0,0,10,0">
                      <PathIcon Data="{StaticResource ViewListIcon}" />
                    </Border>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               ToolTip.Tip="{Binding Description}" />
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        <TextBlock Text="{Binding Loc[view.noViews]}" IsVisible="{Binding IsViewsEmpty}"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="14,4" TextWrapping="Wrap" />
      </Panel>
    </DockPanel>

    <Border Grid.Column="1" Background="{StaticResource BorderLineBrush}" />

    <!-- 中央: 階層構造エディタ(ECO-009 ③: コンテナカード・型チップ・条件チップ・アイコンボタン) -->
    <DockPanel Grid.Column="2">
      <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,0,1">
        <DockPanel Margin="14,8">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
            <Button Content="{Binding Loc[common.save]}" Command="{Binding Editor.SaveCommand}" MinWidth="80" />
            <Button Content="{Binding Loc[common.cancel]}" Command="{Binding Editor.CancelCommand}" MinWidth="80" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding Loc[view.hierarchyStructure]}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Editor.ViewName}" Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </DockPanel>
      </Border>
      <!-- 配置ボタン(主=CTA/従=既定) -->
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="14,12,14,8">
        <Button Classes="cta" Content="{Binding AddRootButtonText}" Command="{Binding AddRootNodeCommand}" />
        <Button Content="{Binding AddChildButtonText}" Command="{Binding AddChildNodeCommand}" />
        <TextBlock Text="{Binding Editor.StatusMessage}" Foreground="{StaticResource DangerBrush}"
                   FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
      </StackPanel>
      <!-- ヘルプ箱(下端) -->
      <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource CardBorderBrush}"
              BorderThickness="1" CornerRadius="11" Padding="14,11" Margin="14,8,14,14">
        <StackPanel Spacing="5">
          <TextBlock Text="{Binding Loc[hierarchy.helpNest]}" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" />
          <TextBlock Text="{Binding Loc[hierarchy.helpViewUsage]}" Foreground="{StaticResource TextMutedBrush}" FontSize="12.5" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <!-- コンテナカード(主役) -->
      <Border Classes="containerCard" Margin="14,0,14,0">
        <DockPanel>
          <Border Classes="cardHeader" DockPanel.Dock="Top">
            <DockPanel>
              <TextBlock DockPanel.Dock="Right" Text="{Binding Loc[hierarchy.dragHint]}"
                         Foreground="{StaticResource FaintTextBrush}" FontSize="12" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource FolderIcon}" Width="16" Height="16"
                          Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Loc[hierarchy.viewStructure]}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Border Classes="accentPill" IsVisible="{Binding Editor.HasView}">
                  <TextBlock Text="{Binding Editor.NodeCountText}" />
                </Border>
              </StackPanel>
            </DockPanel>
          </Border>
          <Panel x:Name="TreeHost" Background="Transparent" DragDrop.AllowDrop="True">
            <!-- 空状態(仕様 §2.6): ビュー未選択 / 階層ノード 0 件 -->
            <TextBlock Text="{Binding Loc[view.selectViewPlease]}" IsVisible="{Binding !Editor.HasView}"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <StackPanel IsVisible="{Binding Editor.IsTreeEmpty}" Spacing="4"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="{Binding Loc[view.noTagsAdded]}" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" />
              <TextBlock Text="{Binding Loc[hierarchy.dropToAdd]}" Foreground="{StaticResource TextMutedBrush}"
                         FontSize="12" TextAlignment="Center" />
            </StackPanel>
            <TreeView x:Name="HierarchyTree" ItemsSource="{Binding Editor.Roots}"
                      SelectionChanged="OnHierarchySelectionChanged" Background="Transparent" Padding="6">
              <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:EditNodeViewModel">
                  <DockPanel MinHeight="40">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                      <Button Classes="iconBtn"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Editor.BeginAliasEditCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource PencilIcon}" />
                      </Button>
                      <!-- GF-03: ホームトグル=家アイコン(設定中=アクセント) -->
                      <Button Classes="iconBtn" Classes.homeOn="{Binding IsHome}"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Editor.ToggleHomeCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource HomeIconGeometry}" />
                      </Button>
                      <Button Classes="iconBtn" IsVisible="{Binding CanHaveCondition}"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Editor.EditConditionCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource FunnelIcon}" />
                      </Button>
                      <Button Classes="iconBtn danger"
                              Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Editor.DeleteNodeCommand}"
                              CommandParameter="{Binding}">
                        <PathIcon Data="{StaticResource TrashIcon}" />
                      </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <Ellipse Width="10" Height="10" Fill="{Binding Color, FallbackValue=Transparent}"
                               IsVisible="{Binding HasColor}" VerticalAlignment="Center" />
                      <TextBlock Classes="nodeName" Classes.home="{Binding IsHome}" Text="{Binding DisplayName}"
                                 IsVisible="{Binding !IsEditingAlias}" VerticalAlignment="Center"
                                 FontSize="14" FontWeight="Medium" TextTrimming="CharacterEllipsis" />
                      <TextBox Text="{Binding AliasEditText}" IsVisible="{Binding IsEditingAlias}"
                               MinWidth="120" FontSize="13" Padding="6,3"
                               KeyDown="OnAliasKeyDown" LostFocus="OnAliasLostFocus" />
                      <Border Classes="typeChip" Classes.simple="{Binding IsSimple}" Classes.text="{Binding IsTextual}"
                              Classes.number="{Binding IsNumeric}" IsVisible="{Binding HasType}">
                        <TextBlock Text="{Binding TypeText}" />
                      </Border>
                      <Border Classes="homePill" IsVisible="{Binding IsHome}">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[hierarchy.homePill]}" />
                      </Border>
                      <!-- 展開モードバッジ(REQ-096/ECO-086・非既定のみ表示=CAD VC-TAG-3・紫) -->
                      <Border IsVisible="{Binding HasExpansionBadge}" Background="#f2edfc" CornerRadius="6"
                              Padding="7,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ExpansionBadgeText}" FontSize="11" Foreground="#7c53d6"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                      </Border>
                      <Border Classes="condChip" Classes.amber="{Binding IsConditionAmber}" Classes.mono="{Binding IsConditionMono}"
                              IsVisible="{Binding HasCondition}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <PathIcon Data="{StaticResource FunnelIcon}" VerticalAlignment="Center" />
                          <TextBlock Text="{Binding ConditionSummary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </DockPanel>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
          </Panel>
        </DockPanel>
      </Border>
    </DockPanel>

    <Border Grid.Column="3" Background="{StaticResource BorderLineBrush}" />

    <!-- 右: タグパレット(ECO-009: モック CAD 準拠の再実装。Card/型チップ/候補値・範囲/CTA/アイコンボタン/件数・凡例) -->
    <DockPanel Grid.Column="4" Background="{StaticResource PanelBrush}">
      <!-- ヘッダ: タイトル+件数バッジ -->
      <DockPanel DockPanel.Dock="Top" Margin="16,14,16,8">
        <Border DockPanel.Dock="Right" Classes="countBadge" VerticalAlignment="Center">
          <TextBlock Text="{Binding Palette.TotalCount}" />
        </Border>
        <TextBlock Text="{Binding Loc[navigation.tagPalette]}" FontSize="15" FontWeight="SemiBold"
                   VerticalAlignment="Center" />
      </DockPanel>
      <!-- 検索 + 追加 CTA -->
      <DockPanel DockPanel.Dock="Top" Margin="16,0,16,10">
        <Button DockPanel.Dock="Right" Classes="cta" Command="{Binding Palette.NewTagCommand}" Margin="10,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Data="{StaticResource PlusIcon}" Width="14" Height="14" Foreground="White" />
            <TextBlock Text="{Binding Loc[common.add]}" />
          </StackPanel>
        </Button>
        <TextBox Text="{Binding Palette.SearchText}" PlaceholderText="{Binding Loc[tag.searchTags]}"
                 VerticalAlignment="Center" CornerRadius="10" Height="40" />
      </DockPanel>
      <!-- 件数 + 型凡例 -->
      <DockPanel DockPanel.Dock="Top" Margin="18,0,18,8">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="2" Background="{StaticResource ChipSimpleFg}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Loc[tag.type.simple]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="2" Background="{StaticResource ChipTextFg}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Loc[tag.type.textual]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="8" Height="8" CornerRadius="2" Background="{StaticResource ChipNumFg}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Loc[tag.type.numeric]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
        </StackPanel>
        <TextBlock Text="{Binding Palette.ItemCountText}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center" />
      </DockPanel>
      <TextBlock DockPanel.Dock="Bottom" Text="{Binding Palette.StatusMessage}"
                 Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="16,4" TextWrapping="Wrap" />
      <Panel>
        <ScrollViewer Padding="14,0,14,8">
          <ItemsControl ItemsSource="{Binding Palette.Tags}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:TagPaletteRowViewModel">
                <Border Classes="card" Classes.selected="{Binding IsSelected}" PointerPressed="OnPaletteItemPressed">
                  <StackPanel Spacing="9">
                    <!-- 行1: 色ドット+名前+型チップ+アクション -->
                    <DockPanel>
                      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                        <Button Classes="iconBtn"
                                Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Palette.EditCommand}"
                                CommandParameter="{Binding}">
                          <PathIcon Data="{StaticResource PencilIcon}" />
                        </Button>
                        <Button Classes="iconBtn danger"
                                Command="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Palette.DeleteCommand}"
                                CommandParameter="{Binding}">
                          <PathIcon Data="{StaticResource TrashIcon}" />
                        </Button>
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                        <Ellipse Width="11" Height="11" Fill="{Binding Color, FallbackValue=Transparent}"
                                 IsVisible="{Binding HasColor}" VerticalAlignment="Center" />
                        <Ellipse Width="11" Height="11" Stroke="{StaticResource BorderLineBrush}" StrokeThickness="2"
                                 IsVisible="{Binding !HasColor}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Border Classes="typeChip" Classes.simple="{Binding IsSimple}"
                                Classes.text="{Binding IsTextual}" Classes.number="{Binding IsNumeric}">
                          <TextBlock Text="{Binding TypeText}" />
                        </Border>
                      </StackPanel>
                    </DockPanel>
                    <!-- テキスト: 候補値チップ -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="20,0,0,0"
                                IsVisible="{Binding HasCandidateValues}">
                      <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.candidateValues]}"
                                 FontSize="11" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                      <ItemsControl ItemsSource="{Binding CandidateValues}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="sys:String">
                            <Border Classes="valueChip" Margin="0,0,6,4">
                              <TextBlock Text="{Binding}" />
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                    <!-- 数値: 範囲ピル+刻み -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="20,0,0,0"
                                IsVisible="{Binding HasRange}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.range]}"
                                 FontSize="11" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                      <Border Classes="rangePill"><TextBlock Text="{Binding RangeText}" /></Border>
                      <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding HasStep}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.step]}"
                                   FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" />
                        <TextBlock Text="{Binding StepValue}" FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" />
                      </StackPanel>
                    </StackPanel>
                    <!-- シンプル: 注記 -->
                    <TextBlock Text="{Binding $parent[UserControl].((vm:TagsTabViewModel)DataContext).Loc[tag.palette.simpleNote]}"
                               IsVisible="{Binding IsSimple}" Margin="20,0,0,0" FontSize="11.5"
                               Foreground="{StaticResource FaintTextBrush}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        <TextBlock Text="{Binding Loc[tag.noTags]}" IsVisible="{Binding Palette.IsEmpty}"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="16,4" TextWrapping="Wrap" />
      </Panel>
    </DockPanel>
  </Grid>
</UserControl>
