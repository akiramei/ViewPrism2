<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.RepairWindow"
        x:DataType="vm:RepairViewModel"
        Title="{Binding Loc[repair.title]}"
        Width="860" Height="640"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Foreground="{StaticResource TextPrimaryBrush}"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- 修復ライフサイクル UI(仕様 §2.11.5 / golden G-10): criteria 検索フォーム+結果、relink 候補提示/確定。
       各操作は M-CRITERIA-024 / M-RELINK-025 の API のみ経由。空条件は検索ボタン非活性(§2.11.1)。 -->
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="{Binding Loc[repair.title]}" FontSize="16" FontWeight="SemiBold"
               Margin="0,0,0,12" />

    <!-- フッター(C-REPAIR-UI-001): 一括自動修復(AutoRepairableCount>0 で活性)+ 選択行の単一自動修復・除外
         (SelectedMissing 選択時に活性)+ 結果文言。状態遷移は VM の API のみ経由(UI で再実装しない)。 -->
    <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{Binding AutoRepairAllLabel}"
                Command="{Binding AutoRepairAllCommandCommand}"
                IsEnabled="{Binding HasAutoRepairable}"
                Background="{StaticResource AccentBrush}" Foreground="White" Padding="14,8" />
        <Button Content="{Binding Loc[repair.autoRepair]}"
                Command="{Binding AutoRepairSelectedCommand}"
                IsEnabled="{Binding CanExcludeSelected}"
                Padding="14,8" />
        <Button Content="{Binding Loc[repair.exclude]}"
                Command="{Binding ExcludeSelectedCommand}"
                IsEnabled="{Binding CanExcludeSelected}"
                Padding="14,8" />
      </StackPanel>
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" />
    </StackPanel>

    <Grid ColumnDefinitions="*,16,*">
      <!-- 左: criteria 条件検索 -->
      <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
              BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="1"
              CornerRadius="6" Padding="12">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="{Binding Loc[repair.criteria.title]}"
                     FontWeight="SemiBold" Margin="0,0,0,8" />
          <Grid DockPanel.Dock="Top" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                ColumnDefinitions="Auto,8,*" Margin="0,0,0,8">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Loc[repair.criteria.hash]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding HashInput}" PlaceholderText="SHA-256" Margin="0,0,0,4" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Loc[repair.criteria.name]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding NameContainsInput}" Margin="0,0,0,4" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Loc[repair.criteria.extension]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding ExtensionInput}" PlaceholderText=".jpg" Margin="0,0,0,4" />
            <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding Loc[repair.criteria.mtimeFrom]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding MtimeFromInput}" PlaceholderText="2026-01-01T00:00:00.000Z" Margin="0,0,0,4" />
            <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Loc[repair.criteria.mtimeTo]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding MtimeToInput}" PlaceholderText="2026-12-31T23:59:59.999Z" Margin="0,0,0,4" />
            <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding Loc[repair.criteria.sizeMin]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding SizeMinInput}" Margin="0,0,0,4" />
            <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding Loc[repair.criteria.sizeMax]}" VerticalAlignment="Center" />
            <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding SizeMaxInput}" Margin="0,0,0,4" />
            <Button Grid.Row="7" Grid.Column="2" HorizontalAlignment="Right" Margin="0,8,0,0"
                    Content="{Binding Loc[repair.search]}"
                    Command="{Binding SearchCommand}" IsEnabled="{Binding CanSearchCandidates}"
                    Background="{StaticResource AccentBrush}" Foreground="White" Padding="16,8" />
          </Grid>

          <!-- GF-V4-03: 検索は選択中 missing の再リンク候補(右)を現在の条件で絞り込む(原典 AdvancedRepairModal 準拠)。
               Normal 限定の別「検索結果」リストは廃止。 -->
          <TextBlock Text="{Binding Loc[repair.criteria.help]}"
                     Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap"
                     VerticalAlignment="Top" />
        </DockPanel>
      </Border>

      <!-- 右: relink フロー(missing → 候補 → 確定) -->
      <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
              BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="1"
              CornerRadius="6" Padding="12">
        <Grid RowDefinitions="Auto,*,Auto,*,Auto">
          <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="{Binding Loc[repair.missingImages]}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding RepairSummary}" FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
          </StackPanel>
          <Panel Grid.Row="1">
            <TextBlock IsVisible="{Binding HasNoMissing}" Text="{Binding Loc[repair.noMissingImages]}"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <ListBox ItemsSource="{Binding MissingImages}" SelectedItem="{Binding SelectedMissing}"
                     Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:MissingImageViewModel">
                  <!-- リンク切れ画像行: ファイル名(主)+相対パス(従)。実体は欠損のためサムネイルは持たない。 -->
                  <StackPanel Spacing="1" Margin="0,2">
                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding RelativePath}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Panel>

          <TextBlock Grid.Row="2" Text="{Binding Loc[repair.candidates]}" FontWeight="SemiBold" Margin="0,8,0,6" />
          <Panel Grid.Row="3">
            <TextBlock IsVisible="{Binding HasNoCandidates}" Text="{Binding Loc[repair.noCandidates]}"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            <ListBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}"
                     Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:RelinkCandidateViewModel">
                  <!-- GF-V4-04(§2.11.5 表示パリティ・原典 AdvancedRepairModal 準拠):
                       サムネイル+ファイル名+パス+サイズ+更新日時で再リンク可否を判断できる情報を提示する。 -->
                  <Grid ColumnDefinitions="56,8,*" Margin="0,2">
                    <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4" ClipToBounds="True"
                            Background="{StaticResource AppBackgroundBrush}"
                            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="1">
                      <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding RelativePath}" FontSize="12"
                                 Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                      <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding SizeText}" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="{Binding ModifiedText}" FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                      </StackPanel>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Panel>

          <Button Grid.Row="4" HorizontalAlignment="Right" Margin="0,8,0,0"
                  Content="{Binding Loc[repair.relink.commit]}"
                  Command="{Binding CommitRelinkCommand}"
                  Background="{StaticResource AccentBrush}" Foreground="White" Padding="16,8" />
        </Grid>
      </Border>
    </Grid>
  </DockPanel>
</Window>
