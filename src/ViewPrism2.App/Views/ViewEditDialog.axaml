<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        x:Class="ViewPrism2.App.Views.ViewEditDialog"
        x:DataType="vm:ViewEditDialogViewModel"
        x:Name="Root"
        Width="520" Height="624"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- ビュー作成/編集ダイアログ(仕様 §2.6 v1.2: 名前+説明)
       + ECO-025 α: 表示列の構成(display_columns の進化モデル・列ピッカー・名前固定)
       レイアウト=モック準拠(GF): フッター(キャンセル/保存)を下部固定・本体をスクロール・追加元は2カラム -->
  <Window.Styles>
    <!-- 件数バッジ: 通常=アクセント / 上限到達=アンバー(VE-002) -->
    <Style Selector="Border.countBadge">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.countBadge.atLimit">
      <Setter Property="Background" Value="{StaticResource WarnBrush}" />
    </Style>
    <!-- 選択済み列の行 -->
    <Style Selector="Border.colRow">
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    </Style>
    <!-- ソースチップ(基本=グレー / タグ=青) -->
    <Style Selector="Border.srcChip">
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="6,1" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- 追加元カード(全幅の行): 基本情報=破線相当 / タグ=実線 -->
    <Style Selector="Button.addCard">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="Margin" Value="0,0,0,4" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.addCard:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
    </Style>
    <!-- アイコンボタン(上/下/削除) -->
    <Style Selector="Button.iconBtn">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <DockPanel Margin="16">
    <!-- ===== フッター(下部固定・件数が増えても常に押せる・モック準拠) ===== -->
    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,10,0,0">
      <Border BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,1,0,0" />
      <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                 FontSize="12" TextWrapping="Wrap"
                 IsVisible="{Binding ErrorMessage, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}" />
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="{Binding Loc[common.cancel]}" Click="OnCancelClick" MinWidth="80" />
          <Button Content="{Binding Loc[common.save]}" Command="{Binding SaveCommand}" MinWidth="80"
                  Background="{StaticResource CtaBrush}" Foreground="White" />
        </StackPanel>
        <TextBlock Text="{Binding Loc[view.saveColumnsNote]}" FontSize="11" Margin="0,0,12,0"
                   Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
      </DockPanel>
    </StackPanel>

    <!-- ===== 本体(スクロール) ===== -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="8">
        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" />

        <!-- 名前(必須)+説明 -->
        <TextBlock Text="{Binding Loc[view.viewName]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
        <TextBox Text="{Binding Name}" PlaceholderText="{Binding Loc[view.viewNamePlaceholder]}" />
        <TextBlock Text="{Binding Loc[view.description]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
        <TextBox Text="{Binding Description}" PlaceholderText="{Binding Loc[view.descriptionPlaceholder]}"
                 AcceptsReturn="True" MinHeight="52" TextWrapping="Wrap" />

        <Border BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,1,0,0" Margin="0,4,0,0" Padding="0,10,0,0">
          <StackPanel Spacing="8">
            <!-- 表示列の設定 見出し + 件数バッジ -->
            <DockPanel>
              <Border DockPanel.Dock="Right" Classes="countBadge" Classes.atLimit="{Binding IsAtLimit}">
                <TextBlock Text="{Binding ColumnCountText}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
              </Border>
              <TextBlock Text="{Binding Loc[view.displayColumnsSection]}" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>
            <TextBlock Text="{Binding Loc[view.displayColumnsToFileList]}" FontSize="11"
                       Foreground="{StaticResource FaintTextBrush}" />

            <!-- 選択済み列(順序どおり・先頭は name 固定) -->
            <ItemsControl ItemsSource="{Binding SelectedColumns}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectedColumnRow">
                  <Border Classes="colRow">
                    <DockPanel>
                      <!-- 右: 上/下/削除(name 固定は「固定」バッジ) -->
                      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Border IsVisible="{Binding IsNameLocked}" Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                          <TextBlock Text="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).Loc[view.columnFixed]}"
                                     FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <StackPanel Orientation="Horizontal" Spacing="2" IsVisible="{Binding !IsNameLocked}">
                          <Button Classes="iconBtn" Content="▲" FontSize="10"
                                  IsEnabled="{Binding CanMoveUp}"
                                  ToolTip.Tip="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).Loc[view.columnMoveUp]}"
                                  Command="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).MoveColumnUpCommand}"
                                  CommandParameter="{Binding}" />
                          <Button Classes="iconBtn" Content="▼" FontSize="10"
                                  IsEnabled="{Binding CanMoveDown}"
                                  ToolTip.Tip="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).Loc[view.columnMoveDown]}"
                                  Command="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).MoveColumnDownCommand}"
                                  CommandParameter="{Binding}" />
                          <Button Classes="iconBtn" Content="✕" FontSize="11" Foreground="{StaticResource DangerBrush}"
                                  ToolTip.Tip="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).Loc[view.columnRemove]}"
                                  Command="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).RemoveColumnCommand}"
                                  CommandParameter="{Binding}" />
                        </StackPanel>
                      </StackPanel>
                      <!-- 左: ソースチップ + 色ドット + ラベル -->
                      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Classes="srcChip" Background="{StaticResource CardSelectedBgBrush}">
                          <TextBlock Text="{Binding SourceLabel}" FontSize="10"
                                     Foreground="{StaticResource TextMutedBrush}" />
                        </Border>
                        <Ellipse Width="10" Height="10" Fill="{Binding Color, FallbackValue=Transparent}"
                                 IsVisible="{Binding ShowColorDot}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 追加元(2カラム・モック準拠): 左=基本情報 / 右=タグ(ビュー内・内部スクロール) -->
            <Grid ColumnDefinitions="*,12,*" Margin="0,4,0,0">
              <!-- 左: 基本情報(破線相当カード) -->
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding Loc[view.basicInformation]}" FontSize="12" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding BasicSources}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AddSourceRow">
                      <Button Classes="addCard" BorderBrush="{StaticResource TextMutedBrush}"
                              IsEnabled="{Binding !#Root.((vm:ViewEditDialogViewModel)DataContext).IsAtLimit}"
                              Command="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).AddColumnCommand}"
                              CommandParameter="{Binding}">
                        <DockPanel>
                          <TextBlock DockPanel.Dock="Left" Text="＋" FontSize="12" Margin="0,0,6,0"
                                     Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                          <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                        </DockPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding Loc[view.noAvailableBasics]}" FontSize="11"
                           Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap"
                           IsVisible="{Binding !HasBasicSources}" />
              </StackPanel>

              <!-- 右: タグ(ビュー内)・内部スクロールで有界化 -->
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="{Binding Loc[view.addTagColumns]}" FontSize="12" FontWeight="SemiBold" />
                <ScrollViewer MaxHeight="188" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <ItemsControl ItemsSource="{Binding TagSources}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:AddSourceRow">
                        <Button Classes="addCard"
                                IsEnabled="{Binding !#Root.((vm:ViewEditDialogViewModel)DataContext).IsAtLimit}"
                                Command="{Binding #Root.((vm:ViewEditDialogViewModel)DataContext).AddColumnCommand}"
                                CommandParameter="{Binding}">
                          <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="＋" FontSize="12" Margin="0,0,6,0"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                            <Border DockPanel.Dock="Right" Classes="srcChip" Background="{StaticResource CardSelectedBgBrush}">
                              <TextBlock Text="{Binding KindLabel}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                              <Ellipse Width="10" Height="10" Fill="{Binding Color, FallbackValue=Transparent}"
                                       IsVisible="{Binding ShowColorDot}" VerticalAlignment="Center" />
                              <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                            </StackPanel>
                          </DockPanel>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="{Binding Loc[view.noAvailableTags]}" FontSize="11"
                           Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap"
                           IsVisible="{Binding !HasTagSources}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
