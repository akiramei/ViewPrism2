<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.PendingReviewWindow"
        x:DataType="vm:PendingReviewViewModel"
        Width="760" SizeToContent="Height" MaxHeight="720"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Title="{Binding WindowTitle}"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- pending 裁定ダイアログ(ECO-129/REQ-101・E-UI-PENDING-049。CAD= pending_review.md PD-2〜4)。
       左=一覧(内部スクロール・末尾到達性=CMP-008)/右=詳細/フッター=CMP-011 dlgBtn 委譲。
       裁定は 1 件ずつ確定・✕はいつでも可(破棄の概念なし)。 -->
  <Window.Styles>
    <Style Selector="Border.adjRow">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="9,7" />
    </Style>
    <Style Selector="Border.adjRow.active">
      <Setter Property="Background" Value="#EAF1FE" />
    </Style>
    <!-- 由来チップ(10.5/700・radius5): changed=琥珀/new=青/reappeared・restored=灰 -->
    <Style Selector="Border.originChip">
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="6,1" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="Border.originChip.amber">
      <Setter Property="Background" Value="#FDF8EF" />
    </Style>
    <Style Selector="Border.originChip.amber TextBlock">
      <Setter Property="Foreground" Value="#8A5A20" />
    </Style>
    <Style Selector="Border.originChip.blue">
      <Setter Property="Background" Value="#EAF1FE" />
    </Style>
    <Style Selector="Border.originChip.blue TextBlock">
      <Setter Property="Foreground" Value="#2459CF" />
    </Style>
    <Style Selector="Border.originChip.gray">
      <Setter Property="Background" Value="#F1F3F7" />
    </Style>
    <Style Selector="Border.originChip.gray TextBlock">
      <Setter Property="Foreground" Value="#5B6473" />
    </Style>
    <!-- 由来説明カード(L4): 琥珀=内容変更系/青=候補あり -->
    <Style Selector="Border.whyCard">
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#FDF8EF" />
      <Setter Property="BorderBrush" Value="#E0B36A" />
    </Style>
    <Style Selector="Border.whyCard.candidate">
      <Setter Property="Background" Value="#EAF1FE" />
      <Setter Property="BorderBrush" Value="#CFE0FC" />
    </Style>
    <Style Selector="Border.whyCard TextBlock.lead">
      <Setter Property="Foreground" Value="#8A5A20" />
    </Style>
    <Style Selector="Border.whyCard.candidate TextBlock.lead">
      <Setter Property="Foreground" Value="#2459CF" />
    </Style>
  </Window.Styles>

  <DockPanel>
    <!-- フッター(docked・CMP-011。「保留して次へ」= 左端分離) -->
    <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#EEF0F4" BorderThickness="0,1,0,0">
      <DockPanel Margin="20,14">
        <Button DockPanel.Dock="Left" Classes="dlgBtn secondary"
                IsVisible="{Binding HasSelection}"
                Command="{Binding DeferCommand}"
                Content="{Binding Loc[pending.defer]}" />
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
          <Button Classes="dlgBtn secondary"
                  IsVisible="{Binding IsEmpty}"
                  Command="{Binding CloseWindowCommand}"
                  Content="{Binding Loc[common.close]}" />
          <Button Classes="dlgBtn destructive"
                  IsVisible="{Binding HasSelection}"
                  Command="{Binding DeleteCommand}"
                  Content="{Binding Loc[pending.delete]}" />
          <Button Classes="dlgBtn secondary" x:Name="TreatAsNewButton"
                  Command="{Binding TreatAsNewCommand}"
                  Content="{Binding Loc[pending.treatAsNew]}"
                  IsVisible="{Binding ShowTreatAsNew}" />
          <Button Classes="dlgBtn secondary" x:Name="RelinkButton"
                  Command="{Binding OpenRepairCommand}"
                  Content="{Binding Loc[pending.relink]}"
                  IsVisible="{Binding ShowRelink}" />
          <Button Classes="dlgBtn primary" x:Name="AcceptButton"
                  IsVisible="{Binding HasSelection}"
                  Command="{Binding AcceptCommand}"
                  Content="{Binding AcceptLabel}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 本体 -->
    <Panel>
      <!-- PD-4 空状態 -->
      <StackPanel IsVisible="{Binding IsEmpty}" Margin="20,44" Spacing="12" HorizontalAlignment="Center">
        <Border Width="44" Height="44" CornerRadius="12" Background="#EAFAF0" HorizontalAlignment="Center">
          <Path Width="22" Height="22" Stretch="Uniform" Stroke="#0F8A4D" StrokeThickness="2"
                Data="M5 12.5l4.2 4.2L19 7" />
        </Border>
        <TextBlock FontWeight="Bold" HorizontalAlignment="Center" Text="{Binding Loc[pending.emptyTitle]}" />
        <TextBlock FontSize="12" Foreground="#8A93A2" HorizontalAlignment="Center"
                   Text="{Binding Loc[pending.emptyDesc]}" />
      </StackPanel>

      <!-- PD-2/3 裁定面 -->
      <Grid ColumnDefinitions="264,*" IsVisible="{Binding HasSelection}" MinHeight="400">
        <!-- 左: pending 一覧(内部スクロール。末尾到達性= 余白は内容側 Margin=CP-AXAML-LINT-117) -->
        <Border Grid.Column="0" BorderBrush="#EEF0F4" BorderThickness="0,0,1,0">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Items}" Margin="10">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PendingItemVM">
                  <Button Background="Transparent" BorderThickness="0" Padding="0"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Command="{Binding $parent[Window].((vm:PendingReviewViewModel)DataContext).SelectCommand}"
                          CommandParameter="{Binding}">
                    <Border Classes="adjRow" Classes.active="{Binding IsSelected}">
                      <StackPanel Orientation="Horizontal" Spacing="9">
                        <Border Width="40" Height="30" CornerRadius="6" ClipToBounds="True"
                                Background="#EEF1F7" VerticalAlignment="Center">
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#2B3340"
                                     TextTrimming="CharacterEllipsis" MaxWidth="170"
                                     Text="{Binding FileName}" />
                          <Border Classes="originChip"
                                  Classes.amber="{Binding IsOriginAmber}"
                                  Classes.blue="{Binding IsOriginBlue}"
                                  Classes.gray="{Binding IsOriginGray}">
                            <TextBlock FontSize="10.5" FontWeight="Bold" Text="{Binding OriginLabel}" />
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- 右: 詳細 -->
        <StackPanel Grid.Column="1" Margin="20,16" Spacing="12">
          <Border Height="190" CornerRadius="12" ClipToBounds="True" Background="#EEF1F7"
                  BorderBrush="#E3E7EE" BorderThickness="1">
            <Panel>
              <c:ThumbnailImage SourcePath="{Binding PreviewPath}" Stretch="Uniform" />
              <!-- 未裁定バッジ(琥珀破線=REG-C8 族)。プレビュー重畳時は地を白 95% -->
              <Panel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10">
                <Border Background="#F2FDF8EF" CornerRadius="6" Padding="7,2">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <Ellipse Width="6" Height="6" Fill="#B5670C" VerticalAlignment="Center" />
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#8A5A20"
                               Text="{Binding $parent[Window].((vm:PendingReviewViewModel)DataContext).Loc[pending.badge]}" />
                  </StackPanel>
                </Border>
                <Rectangle Stroke="#E0B36A" StrokeThickness="1" StrokeDashArray="3,2"
                           RadiusX="6" RadiusY="6" IsHitTestVisible="False" />
              </Panel>
            </Panel>
          </Border>
          <TextBlock FontSize="12.5" FontWeight="SemiBold" Foreground="#2B3340"
                     TextTrimming="CharacterEllipsis" Text="{Binding PathLine}" />
          <Border Classes="whyCard" Classes.candidate="{Binding WhyIsCandidate}">
            <StackPanel Spacing="2">
              <TextBlock Classes="lead" FontSize="12.5" FontWeight="Bold" TextWrapping="Wrap"
                         Text="{Binding WhyLead}" />
              <TextBlock FontSize="11.5" TextWrapping="Wrap" Foreground="#8A5A20"
                         IsVisible="{Binding !WhyIsCandidate}" Text="{Binding WhyDesc}" />
              <TextBlock FontSize="11.5" TextWrapping="Wrap" Foreground="#3F5F9E"
                         IsVisible="{Binding WhyIsCandidate}" Text="{Binding WhyDesc}" />
            </StackPanel>
          </Border>
          <Border BorderBrush="#E3E7EE" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
            <StackPanel>
              <Border Height="32" Padding="12,0" BorderBrush="#EEF0F4" BorderThickness="0,0,0,1">
                <DockPanel VerticalAlignment="Center">
                  <TextBlock Width="90" FontSize="12" Foreground="#8A93A2"
                             Text="{Binding $parent[Window].((vm:PendingReviewViewModel)DataContext).Loc[common.size]}" />
                  <TextBlock FontSize="12" FontWeight="Bold" Foreground="#2B3340" Text="{Binding SizeText}" />
                </DockPanel>
              </Border>
              <Border Height="32" Padding="12,0" BorderBrush="#EEF0F4" BorderThickness="0,0,0,1">
                <DockPanel VerticalAlignment="Center">
                  <TextBlock Width="90" FontSize="12" Foreground="#8A93A2"
                             Text="{Binding $parent[Window].((vm:PendingReviewViewModel)DataContext).Loc[common.modifiedDate]}" />
                  <TextBlock FontSize="12" FontWeight="Bold" Foreground="#2B3340" Text="{Binding DateText}" />
                </DockPanel>
              </Border>
              <Border Height="32" Padding="12,0" IsVisible="{Binding HasTagRow}">
                <DockPanel VerticalAlignment="Center">
                  <TextBlock Width="90" FontSize="12" Foreground="#8A93A2"
                             Text="{Binding $parent[Window].((vm:PendingReviewViewModel)DataContext).Loc[pending.tagsLabel]}" />
                  <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#2B3340" Text="{Binding TagCountText}" />
                </DockPanel>
              </Border>
            </StackPanel>
          </Border>
          <TextBlock FontSize="12" Foreground="#C4282D" TextWrapping="Wrap"
                     IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                     Text="{Binding StatusMessage}" />
        </StackPanel>
      </Grid>
    </Panel>
  </DockPanel>
</Window>
