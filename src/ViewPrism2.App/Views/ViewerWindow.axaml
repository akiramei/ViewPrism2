<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.ViewerWindow"
        x:DataType="vm:ViewerViewModel"
        Title="{Binding Title}"
        Width="1000" Height="760"
        MinWidth="480" MinHeight="360"
        FontSize="14"
        Foreground="{StaticResource TextPrimaryBrush}"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- ビューア(M-UI-014 / M-UI-018、REQ-044・§2.9、G-4/G-8): モック準拠の刷新。
       白ツールバー(segmented モードピル+表示設定+閉じる) / ダーク(または ライト/市松)キャンバス /
       右ドロワー設定(モード別・説明つき) / ダーク下部バー(単一・見開きのみ。シークは単一)。
       キー: PageDown/PageUp は論理キー。矢印は空間キー(spread-right で反転)。Escape=閉じる。
       計算は M-VIEWERCORE-017(Core)経由(コードビハインドで判定しない)。 -->
  <Window.KeyBindings>
    <KeyBinding Gesture="PageDown" Command="{Binding NextCommand}" />
    <KeyBinding Gesture="PageUp" Command="{Binding PrevCommand}" />
    <KeyBinding Gesture="Right" Command="{Binding ArrowRightCommand}" />
    <KeyBinding Gesture="Left" Command="{Binding ArrowLeftCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding CloseCommand}" />
  </Window.KeyBindings>

  <Window.Resources>
    <!-- 市松(チェッカー)下地: 透過確認向け。20px タイル・淡灰/白。 -->
    <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" SourceRect="0,0,40,40"
                  DestinationRect="0,0,40,40" Stretch="None">
      <DrawingBrush.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#FFFFFF" Geometry="M0,0 H40 V40 H0 Z" />
          <GeometryDrawing Brush="#E6E9EF" Geometry="M0,0 H20 V20 H0 Z M20,20 H40 V40 H20 Z" />
        </DrawingGroup>
      </DrawingBrush.Drawing>
    </DrawingBrush>
  </Window.Resources>

  <Window.Styles>
    <!-- ツールバーのモードピル群は app の segmented/segBtnText を再利用(Components.axaml)。 -->

    <!-- ツールバーボタン(表示設定・閉じる) -->
    <Style Selector="Button.vToolBtn">
      <Setter Property="Height" Value="36" />
      <Setter Property="Padding" Value="13,0" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="#DFE3EA" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.vToolBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#FAFBFC" />
      <Setter Property="BorderBrush" Value="#CFD6E1" />
    </Style>
    <Style Selector="Button.vToolBtn.active">
      <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="Button.vToolBtn.active /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
    </Style>
    <Style Selector="Button.vToolBtn PathIcon">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
    </Style>
    <Style Selector="Button.vClose:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#F4D6D8" />
      <Setter Property="BorderBrush" Value="#E7B6BA" />
    </Style>
    <Style Selector="Button.vClose:pointerover">
      <Setter Property="Foreground" Value="#C4282D" />
    </Style>

    <!-- タグ制御 マッピング設定カード(モック準拠・淡紫) -->
    <Style Selector="Button.tagMapCard">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Background" Value="#F3EFFE" />
      <Setter Property="BorderBrush" Value="#E3D9FB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.tagMapCard:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#ECE4FD" />
      <Setter Property="BorderBrush" Value="#D5C6F8" />
    </Style>
    <Style Selector="Border.tagMapBadge">
      <Setter Property="Background" Value="#E3D9FB" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="7,2" />
    </Style>

    <!-- タグ制御マッピングモーダル: 行カード + アクションアイコンバッジ(モック準拠) -->
    <Style Selector="Border.tagRowCard">
      <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="#EBEEF3" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.tagRowIcon">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>

    <!-- 下部バーのナビ(ダーク) -->
    <Style Selector="Button.vNav">
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Background" Value="#2A2E37" />
      <Setter Property="BorderBrush" Value="#363B46" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#DFE4EC" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.vNav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#333845" />
    </Style>

    <!-- 設定ドロワー: セクション見出し / 設定ラベル / 説明 / 情報ボックス -->
    <Style Selector="TextBlock.vHead">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
      <Setter Property="Margin" Value="0,6,0,2" />
    </Style>
    <Style Selector="TextBlock.vLabel">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.vDesc">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
      <Setter Property="Margin" Value="0,1,0,7" />
    </Style>
    <Style Selector="Border.vInfo">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="Border.vInfo TextBlock">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
  </Window.Styles>

  <!-- 行で物理分割(ツールバー / BODY / 下部バー)。DockPanel は BODY の右ドロワーが下部バーと
       重なる Z オーダー不具合があったため Grid 行に変更(golden GF-V2-TC-02) -->
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- ===================== TOOLBAR(白) ===================== -->
    <Border Grid.Row="0" Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="#E6E9EF" BorderThickness="0,0,0,1">
      <DockPanel Margin="14,9" VerticalAlignment="Center">
        <!-- 右: カウンタ+閉じる -->
        <Button DockPanel.Dock="Right" Classes="vToolBtn vClose" Command="{Binding CloseCommand}"
                Content="{Binding Loc[viewer.close]}" Margin="11,0,0,0" />
        <TextBlock DockPanel.Dock="Right" Text="{Binding CurrentPositionText}" VerticalAlignment="Center"
                   FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12.5" FontWeight="SemiBold"
                   Foreground="{StaticResource TextMutedBrush}" />

        <!-- 左: モードピル + 表示設定 -->
        <StackPanel Orientation="Horizontal" Spacing="13" VerticalAlignment="Center">
          <Border Classes="segmented">
            <StackPanel Orientation="Horizontal" Spacing="2">
              <Button Classes="segBtnText" Classes.active="{Binding IsNormal}"
                      Command="{Binding SetNormalModeCommand}" Content="{Binding Loc[viewer.mode.normal]}" />
              <Button Classes="segBtnText" Classes.active="{Binding IsScroll}"
                      Command="{Binding SetScrollModeCommand}" Content="{Binding Loc[viewer.mode.scroll]}" />
              <Button Classes="segBtnText" Classes.active="{Binding IsSpreadRight}"
                      Command="{Binding SetSpreadRightModeCommand}" Content="{Binding Loc[viewer.openDirection.right]}" />
              <Button Classes="segBtnText" Classes.active="{Binding IsSpreadLeft}"
                      Command="{Binding SetSpreadLeftModeCommand}" Content="{Binding Loc[viewer.openDirection.left]}" />
            </StackPanel>
          </Border>

          <Border Width="1" Height="26" Background="#EEF0F4" />

          <Button Classes="vToolBtn" Classes.active="{Binding SettingsOpen}" Command="{Binding ToggleSettingsCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource TuneIcon}" />
              <TextBlock Text="{Binding Loc[viewer.displaySettings]}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- タグ制御 ON バッジ(GF-TAGCTRL-05 V4・見開き+タグ制御 ON 時のみ・モック準拠) -->
          <Border IsVisible="{Binding ShowTagControlBadge}" Height="34" Padding="12,0" CornerRadius="9"
                  Background="#F3EFFE" BorderBrush="#E2D7FB" BorderThickness="1" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <Border Width="8" Height="8" CornerRadius="4" Background="#8B5CF6" VerticalAlignment="Center"
                      BoxShadow="0 0 0 3 #2E8B5CF6" Margin="3,0,0,0" />
              <TextBlock Text="{Binding Loc[viewer.tagControl.badge]}" FontSize="12.5" FontWeight="SemiBold"
                         Foreground="#7A5BD0" VerticalAlignment="Center" />
              <TextBlock Text="{Binding TagControlMappingBadge}" FontSize="11"
                         Foreground="#9B8AD0" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ===================== 下部バー(ダーク。単一・見開きのみ) ===================== -->
    <Border Grid.Row="2" Background="#1B1E24" BorderBrush="#000000" BorderThickness="0,1,0,0"
            IsVisible="{Binding ShowBottomBar}">
      <!-- カウンタ(左)とナビ(中央)を同一セルに重ね、ナビは「バー全幅」基準で中央化する。
           カウンタの桁数(1/32→10/32)が増えても中央のボタン位置がずれない(maintainer golden GF-V1)。 -->
      <Grid Margin="16,9" VerticalAlignment="Center">
        <TextBlock Text="{Binding CurrentPositionText}" HorizontalAlignment="Left" VerticalAlignment="Center"
                   FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12.5" FontWeight="SemiBold"
                   Foreground="#9AA3B0" />
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Button Classes="vNav" Command="{Binding PrevCommand}" Content="{Binding Loc[viewer.prev]}" />
          <Slider Width="160" Minimum="0" Maximum="{Binding SeekMax}" Value="{Binding SeekValue, Mode=TwoWay}"
                  IsVisible="{Binding ShowSeek}" VerticalAlignment="Center" />
          <Button Classes="vNav" Command="{Binding NextCommand}" Content="{Binding Loc[viewer.next]}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===================== BODY(キャンバス + 右ドロワー) ===================== -->
    <Panel Grid.Row="1">
      <!-- 背景レイヤ(下地色。モード host は透明で上に重なる) -->
      <Border Background="#15171C" IsVisible="{Binding IsBgDark}" />
      <Border Background="#EDEFF3" IsVisible="{Binding IsBgLight}" />
      <Border Background="{StaticResource CheckerBrush}" IsVisible="{Binding IsBgChecker}" />

      <!-- モード描画(IsVisible で切替) -->
      <Panel x:Name="ViewerBody" Focusable="True">
        <!-- normal/Fit: ウィンドウフィット(縮小のみ)+画像外余白クリックで閉じる(REQ-044) -->
        <Panel x:Name="NormalHost" Background="Transparent"
               IsVisible="{Binding ShowNormalFit}" PointerPressed="OnNormalBackgroundPressed">
          <Image x:Name="NormalImage" Stretch="Uniform" StretchDirection="DownOnly" Margin="26" />
        </Panel>

        <!-- normal/Width・One: スクロール表示(幅合わせ=縦スクロール / 原寸=両スクロール) -->
        <ScrollViewer x:Name="NormalScroll" Background="Transparent"
                      IsVisible="{Binding ShowNormalScroll}"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
          <Image x:Name="NormalScrollImage" Margin="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </ScrollViewer>

        <!-- scroll: 縦連続(仮想化必須)。横揃え=ScrollHAlign。クリック無操作。 -->
        <!-- 縦スクロールバーは常時表示(Visible)にして幅を固定する。Auto だとバー出入りで
             利用可能幅が ±スクロールバー幅 だけ振動し、Uniform/DownOnly 画像(幅依存の高さ)の
             高さが再計算→extent 変化→ScrollChanged 再発火 という自己励起ループになる(GF-V2)。 -->
        <ListBox x:Name="ScrollList" IsVisible="{Binding IsScroll}"
                 ItemsSource="{Binding Items}"
                 Background="Transparent" BorderThickness="0" Focusable="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Visible">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent" />
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ImageEntry">
              <c:ViewerImage SourcePath="{Binding AbsolutePath}"
                             ErrorTemplate="{Binding $parent[Window].((vm:ViewerViewModel)DataContext).LoadErrorTemplate}"
                             HorizontalAlignment="{Binding $parent[Window].((vm:ViewerViewModel)DataContext).ScrollItemAlignment}"
                             MinHeight="64" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- spread: 2 列。クリックは各半面全体で送り。空白ページは無地。
             タグ制御 spread 占有時は両列にまたがる単一画像(SpreadOccupyImage)を表示する(§2.12)。 -->
        <Grid x:Name="SpreadHost" IsVisible="{Binding IsSpread}" ColumnDefinitions="*,*" Background="Transparent">
          <Panel Grid.Column="0" x:Name="SpreadLeftHalf" Background="Transparent" PointerPressed="OnSpreadLeftPressed">
            <c:ViewerImage x:Name="SpreadLeftImage" Margin="14" ErrorTemplate="{Binding LoadErrorTemplate}" />
          </Panel>
          <Panel Grid.Column="1" x:Name="SpreadRightHalf" Background="Transparent" PointerPressed="OnSpreadRightPressed">
            <c:ViewerImage x:Name="SpreadRightImage" Margin="14" ErrorTemplate="{Binding LoadErrorTemplate}" />
          </Panel>
          <!-- spread 占有(タグ制御): 1 枚で見開き全体を占有。クリックは右半面送り扱い。 -->
          <Panel Grid.Column="0" Grid.ColumnSpan="2" x:Name="SpreadOccupyHalf" Background="Transparent"
                 IsVisible="{Binding CurrentIsSpreadOccupy}" PointerPressed="OnSpreadRightPressed">
            <c:ViewerImage x:Name="SpreadOccupyImage" Margin="14" ErrorTemplate="{Binding LoadErrorTemplate}" />
          </Panel>
        </Grid>
      </Panel>
    </Panel>

    <!-- ===================== 設定ドロワー(右) =====================
         ScrollViewer の有界化(GF-TAGCTRL): ドロワーを `*` 行(Grid.Row=1)へ直接置くことで、
         ScrollViewer が有界高さ(= body 行高)を受け取りスクロールする。BODY と同じ `*` 行に重ねるが、
         下部バー(Row=2)とは別行なので Z オーダー不具合(GF-V2-TC-02)も再発しない。
         ヘッドレス実測で Viewport<Extent(=スクロール可)・Padding を内容 Margin 化で下端到達も確認済。 -->
    <Border Grid.Row="1" HorizontalAlignment="Right" Width="376" IsVisible="{Binding SettingsOpen}"
              Background="{StaticResource AppBackgroundBrush}" BorderBrush="#E6E9EF" BorderThickness="1,0,0,0">
        <!-- Padding は ScrollViewer ではなく内容(StackPanel)の Margin に置く。Avalonia の
             ScrollViewer.Padding は Extent に含まれず最大スクロール時に下端が切れるため(GF-TAGCTRL 実測)。 -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="4" Margin="16,14,28,16">

            <!-- モードバッジ(GF-TAGCTRL-05 V3・バッジのみ追随=歯車/X ヘッダは付けない。モック modeLabel) -->
            <Border Background="#EAF1FE" CornerRadius="6" Padding="9,3" HorizontalAlignment="Left" Margin="0,0,0,6">
              <TextBlock Text="{Binding CurrentModeLabel}" FontSize="12" FontWeight="SemiBold" Foreground="#2F6BED" />
            </Border>

            <!-- ===== 単一: フィット / 背景 / info ===== -->
            <StackPanel Spacing="4" IsVisible="{Binding IsNormal}">
              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.fit]}" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.fit.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsFitFit}"
                          Command="{Binding SetFitCommand}" CommandParameter="fit" Content="{Binding Loc[viewer.fit.fit]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsFitWidth}"
                          Command="{Binding SetFitCommand}" CommandParameter="width" Content="{Binding Loc[viewer.fit.width]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsFitOne}"
                          Command="{Binding SetFitCommand}" CommandParameter="one" Content="{Binding Loc[viewer.fit.one]}" />
                </StackPanel>
              </Border>

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.background]}" Margin="0,14,0,0" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.background.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsBgDark}"
                          Command="{Binding SetBackgroundCommand}" CommandParameter="dark" Content="{Binding Loc[viewer.bg.dark]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsBgLight}"
                          Command="{Binding SetBackgroundCommand}" CommandParameter="light" Content="{Binding Loc[viewer.bg.light]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsBgChecker}"
                          Command="{Binding SetBackgroundCommand}" CommandParameter="checker" Content="{Binding Loc[viewer.bg.checker]}" />
                </StackPanel>
              </Border>

              <Border Classes="vInfo" Margin="0,14,0,0">
                <TextBlock Text="{Binding Loc[viewer.info.single]}" TextWrapping="Wrap" />
              </Border>
            </StackPanel>

            <!-- ===== 縦スクロール: 共通(リサイズ/横揃え/ギャップ) + info ===== -->
            <StackPanel Spacing="4" IsVisible="{Binding IsScroll}">
              <TextBlock Classes="vHead" Text="{Binding Loc[viewer.commonSettings]}" />

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.resize]}" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.resize.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsResizeLarger}"
                          Command="{Binding SetResizeCommand}" CommandParameter="larger" Content="{Binding Loc[viewer.resize.matchLargerHeight]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsResizeSmaller}"
                          Command="{Binding SetResizeCommand}" CommandParameter="smaller" Content="{Binding Loc[viewer.resize.matchSmallerHeight]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsResizeNone}"
                          Command="{Binding SetResizeCommand}" CommandParameter="none" Content="{Binding Loc[viewer.resize.noResize]}" />
                </StackPanel>
              </Border>

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.hAlign]}" Margin="0,12,0,0" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.hAlign.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsHAlignLeft}"
                          Command="{Binding SetHAlignCommand}" CommandParameter="left" Content="{Binding Loc[viewer.hAlign.left]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsHAlignCenter}"
                          Command="{Binding SetHAlignCommand}" CommandParameter="center" Content="{Binding Loc[viewer.hAlign.center]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsHAlignRight}"
                          Command="{Binding SetHAlignCommand}" CommandParameter="right" Content="{Binding Loc[viewer.hAlign.right]}" />
                </StackPanel>
              </Border>

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.gap]}" Margin="0,12,0,0" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.gap.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsGapTight}"
                          Command="{Binding SetGapCommand}" CommandParameter="tight" Content="{Binding Loc[viewer.gap.tight]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsGapLoose}"
                          Command="{Binding SetGapCommand}" CommandParameter="loose" Content="{Binding Loc[viewer.gap.loose]}" />
                </StackPanel>
              </Border>
              <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0" IsEnabled="{Binding IsGapLoose}">
                <TextBlock Grid.Column="0" Classes="vDesc" Margin="0" VerticalAlignment="Center"
                           Text="{Binding Loc[viewer.gapWidth]}" />
                <TextBlock Grid.Column="1" Text="{Binding CustomGapPx, StringFormat='{}{0} px'}" Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" />
              </Grid>
              <Slider Minimum="0" Maximum="100" Value="{Binding CustomGapPx}" IsEnabled="{Binding IsGapLoose}" />

              <Border Classes="vInfo" Margin="0,12,0,0">
                <TextBlock Text="{Binding Loc[viewer.info.scroll]}" TextWrapping="Wrap" />
              </Border>
            </StackPanel>

            <!-- ===== 見開き: 共通(リサイズ/垂直揃え/ギャップ) + 見開き設定(ページ送り) ===== -->
            <StackPanel Spacing="4" IsVisible="{Binding IsSpread}">
              <TextBlock Classes="vHead" Text="{Binding Loc[viewer.commonSettings]}" />

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.resize]}" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.resize.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsResizeLarger}"
                          Command="{Binding SetResizeCommand}" CommandParameter="larger" Content="{Binding Loc[viewer.resize.matchLargerHeight]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsResizeSmaller}"
                          Command="{Binding SetResizeCommand}" CommandParameter="smaller" Content="{Binding Loc[viewer.resize.matchSmallerHeight]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsResizeNone}"
                          Command="{Binding SetResizeCommand}" CommandParameter="none" Content="{Binding Loc[viewer.resize.noResize]}" />
                </StackPanel>
              </Border>

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.align]}" Margin="0,12,0,0" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.align.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsAlignTop}"
                          Command="{Binding SetAlignCommand}" CommandParameter="top" Content="{Binding Loc[viewer.align.top]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsAlignMiddle}"
                          Command="{Binding SetAlignCommand}" CommandParameter="middle" Content="{Binding Loc[viewer.align.middle]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsAlignBottom}"
                          Command="{Binding SetAlignCommand}" CommandParameter="bottom" Content="{Binding Loc[viewer.align.bottom]}" />
                </StackPanel>
              </Border>

              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.gap]}" Margin="0,12,0,0" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.gap.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsGapTight}"
                          Command="{Binding SetGapCommand}" CommandParameter="tight" Content="{Binding Loc[viewer.gap.tight]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsGapLoose}"
                          Command="{Binding SetGapCommand}" CommandParameter="loose" Content="{Binding Loc[viewer.gap.loose]}" />
                </StackPanel>
              </Border>
              <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0" IsEnabled="{Binding IsGapLoose}">
                <TextBlock Grid.Column="0" Classes="vDesc" Margin="0" VerticalAlignment="Center"
                           Text="{Binding Loc[viewer.gapWidth]}" />
                <TextBlock Grid.Column="1" Text="{Binding CustomGapPx, StringFormat='{}{0} px'}" Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" />
              </Grid>
              <Slider Minimum="0" Maximum="100" Value="{Binding CustomGapPx}" IsEnabled="{Binding IsGapLoose}" />

              <TextBlock Classes="vHead" Text="{Binding Loc[viewer.spreadSettings]}" Margin="0,14,0,2" />
              <TextBlock Classes="vLabel" Text="{Binding Loc[viewer.pageTurn]}" />
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.pageTurn.desc]}" />
              <Border Classes="segmented" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                  <Button Classes="segBtnText" Classes.active="{Binding IsTurnDouble}"
                          Command="{Binding SetTurnCommand}" CommandParameter="double" Content="{Binding Loc[viewer.pageTurn.doublePage]}" />
                  <Button Classes="segBtnText" Classes.active="{Binding IsTurnSingle}"
                          Command="{Binding SetTurnCommand}" CommandParameter="single" Content="{Binding Loc[viewer.pageTurn.singlePage]}" />
                </StackPanel>
              </Border>
              <CheckBox IsChecked="{Binding StartWithEmptyPage}" Margin="0,8,0,0"
                        Content="{Binding Loc[viewer.startWithEmptyPage]}" />

              <!-- ===== タグ制御モード(ECO-022 / §2.12.6・モック準拠): トグル + マッピング設定カード ===== -->
              <Grid ColumnDefinitions="*,Auto" Margin="0,16,0,0">
                <TextBlock Grid.Column="0" Classes="vHead" Text="{Binding Loc[viewer.tagControl]}" VerticalAlignment="Center" />
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableTagControl}" OnContent="" OffContent="" MinWidth="0" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Classes="vDesc" Text="{Binding Loc[viewer.tagControl.desc]}" />
              <Button Classes="tagMapCard" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                      IsEnabled="{Binding EnableTagControl}"
                      Command="{Binding ToggleTagControlMappingCommand}">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                  <PathIcon Grid.Column="0" Data="{StaticResource FolderIcon}" Width="18" Height="18"
                            Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Loc[viewer.tagControl.mapping.card.title]}" FontWeight="SemiBold"
                               FontSize="13" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding Loc[viewer.tagControl.mapping.card.subtitle]}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,1,0,0" />
                  </StackPanel>
                  <Border Grid.Column="2" Classes="tagMapBadge" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="{Binding TagControlMappingBadge}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                  </Border>
                  <PathIcon Grid.Column="3" Data="{StaticResource ChevronRightIcon}" Width="14" Height="14"
                            Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                </Grid>
              </Button>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
    </Border>

    <!-- ===================== タグ制御マッピングモーダル(全面オーバーレイ・ECO-019 同型・モック準拠) =====================
         DockPanel: ヘッダ(Top・タグアイコン+タイトル+説明+X)/ フッター(Bottom・補足+既定に戻す+完了)/ 行(fill・カード・スクロール)。
         フッターを常時 docked にして主操作「完了」を常に到達可能にし、行が多くても中央だけがスクロールする(GF-TAGCTRL・実測で有界)。
         picker は即時適用(SetTagActionMapping/ライブ反映)を維持。「完了」=閉じる・「既定に戻す」=全アクション未割り当て。 -->
    <Panel Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding TagControlMappingOpen}">
        <!-- 暗幕(クリックで閉じる) -->
        <Border Background="#88000000" PointerPressed="OnTagControlBackdropPressed" />
        <!-- 幅820・角丸14 はモック権威(standalone.html width:820px;border-radius:14px)。GF-TAGCTRL-05 D1。 -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="820" MaxHeight="720"
                Background="{StaticResource AppBackgroundBrush}" BorderBrush="#E6E9EF" BorderThickness="1"
                CornerRadius="14" Padding="0" BoxShadow="0 12 40 0 #40000000">
          <DockPanel>
            <!-- ヘッダ -->
            <Border DockPanel.Dock="Top" Padding="22,18" BorderBrush="#EEF0F4" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="11" Background="#F3EFFE"
                        VerticalAlignment="Top" Margin="0,0,14,0">
                  <PathIcon Data="{StaticResource TagIcon}" Width="20" Height="20"
                            Foreground="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Loc[viewer.tagControl.mapping.title]}"
                             FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                  <TextBlock Text="{Binding Loc[viewer.tagControl.mapping.desc]}" Classes="vDesc"
                             TextWrapping="Wrap" MaxWidth="440" Margin="0,3,0,0" />
                </StackPanel>
                <Button Grid.Column="2" Classes="iconBtn" VerticalAlignment="Top"
                        Command="{Binding CloseTagControlMappingCommand}">
                  <PathIcon Data="{StaticResource CloseIcon}" />
                </Button>
              </Grid>
            </Border>
            <!-- 列見出し(GF-TAGCTRL-05 D2・モック grid 30/1fr/248・色 #AAB1BD)。
                 左右インセット 33(=ItemsControl 18 + カード border1 + padding14)でカード内寸に揃える。 -->
            <Grid DockPanel.Dock="Top" Margin="33,6,33,2" ColumnDefinitions="34,*,248">
              <TextBlock Grid.Column="1" Text="{Binding Loc[viewer.tagControl.mapping.colAction]}" Margin="12,0,0,0"
                         FontSize="11" FontWeight="Bold" Foreground="#AAB1BD" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding Loc[viewer.tagControl.mapping.colTag]}"
                         FontSize="11" FontWeight="Bold" Foreground="#AAB1BD" VerticalAlignment="Center" />
            </Grid>
            <!-- フッター -->
            <Border DockPanel.Dock="Bottom" Padding="22,14" BorderBrush="#EEF0F4" BorderThickness="0,1,0,0">
              <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- 補足は icon(Auto)+text(*) の Grid にして * 幅で折り返す。横 StackPanel だと
                     テキストに無限幅が渡り折り返さずハードクリップする(GF-TAGCTRL)。通常は短縮文で 1 行。 -->
                <Grid Grid.Column="0" ColumnDefinitions="Auto,*" Margin="0,0,12,0" VerticalAlignment="Center">
                  <PathIcon Grid.Column="0" Data="{StaticResource InfoIcon}" Width="14" Height="14"
                            Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Top" Margin="0,1,7,0" />
                  <TextBlock Grid.Column="1" Text="{Binding Loc[viewer.tagControl.mapping.footer]}" TextWrapping="Wrap"
                             FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                </Grid>
                <Button Grid.Column="1" Classes="vToolBtn" Margin="0,0,10,0"
                        Command="{Binding ResetTagControlMappingCommand}"
                        Content="{Binding Loc[viewer.tagControl.mapping.reset]}" />
                <Button Grid.Column="2" Classes="cta" MinWidth="96"
                        Command="{Binding CloseTagControlMappingCommand}"
                        Content="{Binding Loc[viewer.tagControl.mapping.done]}" />
              </Grid>
            </Border>
            <!-- 6 行(予約アクション・カード) -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding TagActionRows}" Margin="18,14,18,4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:TagControlMappingRow">
                    <Border Classes="tagRowCard">
                      <!-- picker 列 248 はモック権威(grid ...248px)。GF-TAGCTRL-05 D3。 -->
                      <Grid ColumnDefinitions="Auto,*,248" VerticalAlignment="Center">
                        <!-- アクションアイコンバッジ(アクション固定色) -->
                        <Border Grid.Column="0" Classes="tagRowIcon" Background="{Binding IconBg}"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                          <TextBlock Text="{Binding Glyph}" FontSize="16" Foreground="{Binding IconFg}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <!-- 名前+英名+説明 -->
                        <StackPanel Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding EnglishName}" FontSize="11.5"
                                       FontFamily="Cascadia Mono,Consolas,monospace"
                                       Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                          </StackPanel>
                          <TextBlock Text="{Binding Description}" Classes="vDesc" Margin="0,2,0,0"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                        <!-- タグ picker(即時適用 Flyout) -->
                        <Button Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Classes="vToolBtn" Padding="10,0">
                          <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <Ellipse Grid.Column="0" Width="11" Height="11" Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding HasAssignment}"
                                     Fill="{Binding PickerColor, FallbackValue=#9AA3B0, TargetNullValue=#9AA3B0}" />
                            <TextBlock Grid.Column="1" Text="{Binding PickerText}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <PathIcon Grid.Column="2" Data="{StaticResource ChevronDownIcon}"
                                      Width="11" Height="11" Margin="6,0,0,0" />
                          </Grid>
                          <Button.Flyout>
                            <Flyout Placement="Bottom">
                              <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel MinWidth="248" Spacing="1">
                                  <!-- 未割り当て(クリア) -->
                                  <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                          Classes="vToolBtn" BorderThickness="0"
                                          Command="{Binding ClearCommand}"
                                          Content="{Binding $parent[Window].((vm:ViewerViewModel)DataContext).Loc[viewer.tagControl.clear]}" />
                                  <!-- 作成済みタグ(現存のみ) -->
                                  <ItemsControl ItemsSource="{Binding Options}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:TagPickerOption">
                                        <!-- 行: 色ドット / タグ名 / 使用中バッジ(D4) / 選択✓(D5)。モック権威。 -->
                                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                Classes="vToolBtn" BorderThickness="0"
                                                Command="{Binding $parent[ItemsControl].((vm:TagControlMappingRow)DataContext).AssignCommand}"
                                                CommandParameter="{Binding}">
                                          <Grid ColumnDefinitions="Auto,*,Auto,Auto" VerticalAlignment="Center">
                                            <Ellipse Grid.Column="0" Width="11" Height="11" Margin="0,0,8,0" VerticalAlignment="Center"
                                                     Fill="{Binding Color, FallbackValue=#9AA3B0, TargetNullValue=#9AA3B0}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="2" IsVisible="{Binding UsedElsewhere}" Background="#FDF2DD"
                                                    CornerRadius="5" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                              <TextBlock Text="{Binding $parent[Window].((vm:ViewerViewModel)DataContext).Loc[viewer.tagControl.inUse]}"
                                                         FontSize="9.5" FontWeight="SemiBold" Foreground="#C08A2A" />
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="✓" IsVisible="{Binding IsSelected}"
                                                       Foreground="#2F6BED" FontWeight="Bold" FontSize="13"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" />
                                          </Grid>
                                        </Button>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </ScrollViewer>
                            </Flyout>
                          </Button.Flyout>
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>
    </Panel>
  </Grid>
</Window>
