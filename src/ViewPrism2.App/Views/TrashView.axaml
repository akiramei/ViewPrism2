<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.TrashView"
        x:DataType="vm:TrashViewModel"
        Title="{Binding Loc[trash.title]}"
        Width="720" Height="520"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Foreground="{StaticResource TextPrimaryBrush}"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- トラッシュ表示(仕様 §2.10.5 / §2.11.3-4 / K-DESIGN): 選択中コレクションの deleted 一覧+件数。
       V4 で『復元』『完全削除』を追加。完全削除は確認+非破壊明示文言(裁定 6)。空時は「ゴミ箱は空です」。 -->
  <DockPanel Margin="16">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <TextBlock Grid.Column="0" Text="{Binding Loc[trash.title]}" FontSize="16" FontWeight="SemiBold"
                 VerticalAlignment="Center" />
      <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="10,4">
        <TextBlock Text="{Binding Count, StringFormat='{}{0}'}" />
      </Border>
    </Grid>

    <!-- 下部: 操作バー(復元・完全削除)+結果メッセージ。完全削除は非破壊明示文言を確認で出す -->
    <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" />
        <Button Grid.Column="1" Content="{Binding Loc[trash.restore]}" Margin="0,0,8,0"
                Command="{Binding RestoreCommand}" IsEnabled="{Binding CanOperate}" Padding="14,8" />
        <Button Grid.Column="2" Content="{Binding Loc[trash.purge]}"
                Command="{Binding PurgeCommand}" IsEnabled="{Binding CanOperate}"
                Background="{StaticResource DangerBrush}" Foreground="White" Padding="14,8" />
      </Grid>
    </Border>

    <Panel>
      <TextBlock IsVisible="{Binding IsEmpty}" Text="{Binding Loc[trash.empty]}"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
      <ScrollViewer>
        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}"
                 Background="Transparent">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:TrashItemViewModel">
              <Border Width="150" Margin="6" Padding="6" CornerRadius="6"
                      BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                  <Border Height="110" CornerRadius="4" ClipToBounds="True">
                    <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" />
                  </Border>
                  <TextBlock Text="{Binding FileName}" FontSize="12" TextTrimming="CharacterEllipsis"
                             HorizontalAlignment="Center" />
                  <!-- DC-TRASH-001(A-3): ファイル名の下にファイルサイズを従テキストで提示(削除判断材料) -->
                  <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                             TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>
    </Panel>
  </DockPanel>
</Window>
