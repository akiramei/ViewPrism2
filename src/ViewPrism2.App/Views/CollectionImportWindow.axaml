<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        x:Class="ViewPrism2.App.Views.CollectionImportWindow"
        x:DataType="vm:CollectionImportViewModel"
        Title="{Binding WindowTitle}"
        Width="940" Height="640"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- ECO-073 B-2〜B-4 取り込みウィザード(CAD snapshot_export_import・mock 権威)。
       stepper: ファイル → 検証 → プレビュー → 完了。docked フッター+ボディ単一スクロール -->
  <Window.Styles>
    <!-- GF-073-01 同族: ボタンは中央揃え(Avalonia 既定=Left)・二次操作は outline(既定グレーにしない) -->
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.outlineButton">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="#D6E0EE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Button.choice">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="#D6E0EE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10,3" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Border.stateTile">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <!-- GF-073-07: B-3 の mock 転写 — タグ件数チップ/競合カード状態色/5状態タイル配色 -->
    <Style Selector="Border.tagChip">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.tagChip.create">
      <Setter Property="Background" Value="#E7F6EC" />
      <Setter Property="BorderBrush" Value="#C4E7D2" />
    </Style>
    <Style Selector="Border.tagChip.map">
      <Setter Property="Background" Value="#EFF4FE" />
      <Setter Property="BorderBrush" Value="#D3E1FB" />
    </Style>
    <Style Selector="Border.tagChip.conflict">
      <Setter Property="Background" Value="#FCF4DC" />
      <Setter Property="BorderBrush" Value="#EDDFAF" />
    </Style>
    <Style Selector="Border.conflictCard">
      <Setter Property="Background" Value="#FFFBEB" />
      <Setter Property="BorderBrush" Value="#EDDFAF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="Border.conflictCard.resolved">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    </Style>
    <Style Selector="Button.choice.selected">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Border.stateTile.exact">
      <Setter Property="Background" Value="#EFF9F1" />
      <Setter Property="BorderBrush" Value="#CFE8D8" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.stateTile.moved">
      <Setter Property="Background" Value="#EFF4FE" />
      <Setter Property="BorderBrush" Value="#D3E1FB" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.stateTile.warn">
      <Setter Property="Background" Value="#FFFBEB" />
      <Setter Property="BorderBrush" Value="#EDDFAF" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <!-- GF-073-04: stepper は番号バッジ+接続線(mock B-2)。到達済み=青塗り・未到達=灰 -->
    <Style Selector="Border.stepBadge">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Background" Value="#E4E9F2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.stepBadge.active">
      <Setter Property="Background" Value="#2F6BED" />
    </Style>
    <Style Selector="Border.stepBadge > TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#7A879C" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.stepBadge.active > TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="TextBlock.stepLabel">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.stepLabel.active">
      <Setter Property="Foreground" Value="#2F6BED" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Border.stepLine">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="2" />
      <Setter Property="Background" Value="#D8DEE9" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.stepLine.active">
      <Setter Property="Background" Value="#2F6BED" />
    </Style>
    <!-- GF-073-03: パッケージ概要は区切り線つき行+値は右寄せ太字(mock B-2 のテーブル言語) -->
    <Style Selector="Border.summaryRow">
      <Setter Property="BorderBrush" Value="#EFF2F7" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="0,7" />
    </Style>
    <Style Selector="Border.summaryRow.last">
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBlock.summaryValue">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextAlignment" Value="Right" />
    </Style>
  </Window.Styles>
  <DockPanel Margin="20">
    <!-- docked フッター -->
    <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10">
          <Button Classes="outlineButton" Content="{Binding Loc[common.cancel]}" Click="OnCloseClick"
                  MinWidth="110" Padding="0,7" IsVisible="{Binding !OnDoneStep}" />
          <Button Content="{Binding Loc[package.next]}" Command="{Binding ToPreviewCommand}"
                  IsVisible="{Binding OnFileStep}" IsEnabled="{Binding VerifyOk}"
                  Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="6"
                  MinWidth="150" Padding="0,7" />
          <Button Classes="outlineButton" Content="{Binding Loc[package.back]}" Command="{Binding BackToFileCommand}"
                  IsVisible="{Binding OnPreviewStep}" MinWidth="90" Padding="0,7" />
          <Button Content="{Binding Loc[package.execute]}" Command="{Binding ExecuteCommand}"
                  IsVisible="{Binding OnPreviewStep}" IsEnabled="{Binding CanExecute}"
                  Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="6"
                  MinWidth="140" Padding="0,7" />
          <Button Content="{Binding Loc[package.finish]}" Click="OnCloseClick"
                  IsVisible="{Binding OnDoneStep}"
                  Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="6"
                  MinWidth="110" Padding="0,7" />
        </StackPanel>
        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
          <TextBlock Text="{Binding BlockReason}" FontSize="12" Foreground="#8A6D1A" TextWrapping="Wrap"
                     IsVisible="{Binding OnPreviewStep}" />
          <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource DangerBrush}"
                     TextWrapping="Wrap"
                     IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer>
      <StackPanel Spacing="14">
        <!-- GF-073-01: タイトルは Window.Title のみ(本文へ重複させない) -->
        <!-- GF-073-04: stepper=番号バッジ式(mock B-2)。CAD「B-2 に可視」=ファイル/検証面のみ表示。
             検証済み(VerifyOk)で 2 まで点灯。B-3/B-4 は Window.Title が専用タイトルへ切替 -->
        <StackPanel x:Name="Stepper" Orientation="Horizontal" Spacing="8" IsVisible="{Binding OnFileStep}">
          <Border Classes="stepBadge active">
            <TextBlock Text="1" />
          </Border>
          <TextBlock Classes="stepLabel active" Text="{Binding Loc[package.stepFile]}" />
          <Border Classes="stepLine" Classes.active="{Binding VerifyOk}" />
          <Border Classes="stepBadge" Classes.active="{Binding VerifyOk}">
            <TextBlock Text="2" />
          </Border>
          <TextBlock Classes="stepLabel" Classes.active="{Binding VerifyOk}"
                     Text="{Binding Loc[package.stepVerify]}" />
          <Border Classes="stepLine" />
          <Border Classes="stepBadge">
            <TextBlock Text="3" />
          </Border>
          <TextBlock Classes="stepLabel" Text="{Binding Loc[package.stepPreview]}" />
          <Border Classes="stepLine" />
          <Border Classes="stepBadge">
            <TextBlock Text="4" />
          </Border>
          <TextBlock Classes="stepLabel" Text="{Binding Loc[package.stepDone]}" />
        </StackPanel>

        <!-- ===== B-2: ファイル選択+検証 ===== -->
        <StackPanel Spacing="12" IsVisible="{Binding OnFileStep}">
          <!-- GF-073-03: ファイルグリフ+ファイル名太字+サイズ淡色の 2 行構成(mock B-2) -->
          <Border Classes="card" Padding="14,10">
            <DockPanel>
              <Button DockPanel.Dock="Right" Classes="choice" Content="{Binding Loc[snapshot.changeDir]}"
                      Command="{Binding PickFileCommand}" VerticalAlignment="Center" />
              <Border DockPanel.Dock="Left" Background="#EEF1F7" CornerRadius="8" Width="36" Height="36"
                      Margin="0,0,12,0" VerticalAlignment="Center">
                <Path Classes="fileGlyph" Width="12" Height="15" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Stroke="#5B657A" StrokeThickness="1.4"
                      Data="M1,1 L8,1 L12,5 L12,16 L1,16 Z M8,1 L8,5 L12,5" />
              </Border>
              <StackPanel VerticalAlignment="Center" Spacing="2" Margin="0,0,12,0">
                <!-- ECO-074 案イ: キャンセル残留(未選択)は空白でなくプレースホルダ文言 -->
                <TextBlock x:Name="PackagePlaceholder" Text="{Binding Loc[package.selectFilePrompt]}"
                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                           IsVisible="{Binding PackageFileName, Converter={x:Static ObjectConverters.IsNull}}" />
                <TextBlock Text="{Binding PackageFileName, FallbackValue=''}" FontFamily="Consolas,monospace"
                           FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding PackageFileName, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <TextBlock x:Name="PackageSizeText" Text="{Binding PackageFileSizeText}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           IsVisible="{Binding PackageFileSizeText, Converter={x:Static ObjectConverters.IsNotNull}}" />
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- 互換性 OK: 概要 -->
          <StackPanel Spacing="8" IsVisible="{Binding VerifyOk}">
            <Border Background="#E7F6EC" BorderBrush="#C4E7D2" BorderThickness="1" CornerRadius="8" Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="calloutGlyph" Width="11" Height="9" Stretch="Uniform" VerticalAlignment="Center"
                      Stroke="#1F7A3D" StrokeThickness="1.8" Data="M1,5.5 L4.5,9 L11,1.5" />
                <TextBlock Text="{Binding Loc[package.compatible]}" FontSize="12" Foreground="#1F7A3D" />
              </StackPanel>
            </Border>
            <Border Classes="card" Padding="14,10">
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding Loc[package.summaryTitle]}" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" />
                <StackPanel>
                  <Border Classes="summaryRow">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Left" Text="{Binding Loc[package.colName]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                      <TextBlock Classes="summaryValue" Text="{Binding HeaderCollectionName}" />
                    </DockPanel>
                  </Border>
                  <Border Classes="summaryRow">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Left" Text="{Binding Loc[package.colImages]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                      <TextBlock Classes="summaryValue" Text="{Binding HeaderImageCount}" />
                    </DockPanel>
                  </Border>
                  <Border Classes="summaryRow">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Left" Text="{Binding Loc[package.colTags]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                      <TextBlock Classes="summaryValue" Text="{Binding HeaderTagCount}" />
                    </DockPanel>
                  </Border>
                  <Border Classes="summaryRow">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Left" Text="{Binding Loc[snapshot.colCreatedAt]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                      <TextBlock Classes="summaryValue" Text="{Binding HeaderCreatedAt}" />
                    </DockPanel>
                  </Border>
                  <Border Classes="summaryRow last">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Left" Text="app_version" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                      <TextBlock Classes="summaryValue" Text="{Binding HeaderAppVersion}" />
                    </DockPanel>
                  </Border>
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- 互換性 NG(判定は format_version/min_reader_version・app_version は参考) -->
          <Border Background="#FDECEC" BorderBrush="#F2C7C7" BorderThickness="1" CornerRadius="8" Padding="14,10"
                  IsVisible="{Binding VerifyError, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding Loc[package.incompatibleTitle]}" FontSize="13" FontWeight="SemiBold"
                         Foreground="#B3261E" />
              <TextBlock Text="{Binding VerifyError}" FontSize="12" Foreground="#B3261E" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- ===== B-3: プレビュー&競合解決 ===== -->
        <StackPanel Spacing="12" IsVisible="{Binding OnPreviewStep}">
          <!-- 追加型マージの規則バナー(M4) -->
          <Border Background="#E7F6EC" BorderBrush="#C4E7D2" BorderThickness="1" CornerRadius="8" Padding="12,8">
            <DockPanel>
              <Path DockPanel.Dock="Left" Classes="calloutGlyph" Width="11" Height="9" Stretch="Uniform"
                    VerticalAlignment="Top" Margin="0,3,8,0" Stroke="#1F7A3D" StrokeThickness="1.8"
                    Data="M1,5.5 L4.5,9 L11,1.5" />
              <TextBlock Text="{Binding Loc[package.addOnlyNote]}" FontSize="12" Foreground="#1F7A3D" TextWrapping="Wrap" />
            </DockPanel>
          </Border>
          <!-- 取り込み先ルート(入口コレクション固定=SS-001(b)。「変更」は非搭載=V1裁定・項目9) -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding Loc[package.targetRoot]}" FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
            <Border Classes="card" Padding="12,6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Path Classes="rootGlyph" Width="15" Height="12" Stretch="Uniform" VerticalAlignment="Center"
                      Fill="#5B657A"
                      Data="M1,2.5 C1,1.7 1.7,1 2.5,1 L6,1 L7.5,3 L14.5,3 C15.3,3 16,3.7 16,4.5 L16,11.5 C16,12.3 15.3,13 14.5,13 L2.5,13 C1.7,13 1,12.3 1,11.5 Z" />
                <TextBlock Text="{Binding TargetRootPath}" FontFamily="Consolas,monospace" FontSize="12"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- GF-073-07: 広幅=タグ/画像の 2 カラム・狭幅=縦積み(CAD layoutInvariant。切替は code-behind) -->
          <Grid x:Name="PreviewColumns" ColumnDefinitions="*,16,*" RowDefinitions="Auto,12,Auto">
            <!-- タグ列 -->
            <StackPanel x:Name="TagColumn" Grid.Row="0" Grid.Column="0" Spacing="10" VerticalAlignment="Top">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding Loc[package.tagsTitle]}" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Border Classes="tagChip create">
                  <TextBlock Text="{Binding TagCreatedChip}" FontSize="11" Foreground="#1F7A3D" />
                </Border>
                <Border Classes="tagChip map">
                  <TextBlock Text="{Binding TagMappedChip}" FontSize="11" Foreground="#2F6BED" />
                </Border>
                <Border Classes="tagChip conflict">
                  <TextBlock Text="{Binding TagConflictChip}" FontSize="11" Foreground="#8A6D1A" />
                </Border>
              </StackPanel>
              <TextBlock x:Name="ConflictHeading" Text="{Binding ConflictHeader}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding Loc[package.mapCompatNote]}" FontSize="11"
                         Foreground="{StaticResource TextMutedBrush}" />
              <ItemsControl ItemsSource="{Binding Conflicts}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:TagConflictRowViewModel">
                    <Border Classes="conflictCard" Classes.resolved="{Binding IsResolved}"
                            Padding="12,10" Margin="0,0,0,8">
                      <StackPanel Spacing="8">
                        <DockPanel>
                          <Border DockPanel.Dock="Right" CornerRadius="10" Padding="8,2"
                                  Background="{Binding IsResolved, Converter={x:Static vm:SnapshotBadgeConverters.Background}}"
                                  BorderBrush="{Binding IsResolved, Converter={x:Static vm:SnapshotBadgeConverters.Border}}"
                                  BorderThickness="1">
                            <TextBlock FontSize="11"
                                       Text="{Binding IsResolved, Converter={x:Static vm:PackageConverters.ResolvedLabel}}"
                                       Foreground="{Binding IsResolved, Converter={x:Static vm:SnapshotBadgeConverters.Foreground}}" />
                          </Border>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="10" Height="10" CornerRadius="5" VerticalAlignment="Center"
                                    Background="{Binding Color}"
                                    IsVisible="{Binding Color, Converter={x:Static ObjectConverters.IsNotNull}}" />
                            <StackPanel>
                              <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                         TextWrapping="Wrap" />
                            </StackPanel>
                          </StackPanel>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <Button Classes="choice" Content="{Binding $parent[Window].((vm:CollectionImportViewModel)DataContext).Loc[package.choiceAbort]}"
                                  Command="{Binding AbortCommand}" />
                          <Button Classes="choice" Classes.selected="{Binding IsSkip}"
                                  Content="{Binding $parent[Window].((vm:CollectionImportViewModel)DataContext).Loc[package.choiceSkip]}"
                                  Command="{Binding SkipCommand}" />
                          <Button Classes="choice" Classes.selected="{Binding IsRename}"
                                  Content="{Binding $parent[Window].((vm:CollectionImportViewModel)DataContext).Loc[package.choiceRename]}"
                                  Command="{Binding RenameCommand}" />
                          <Button Classes="choice" Classes.selected="{Binding IsMap}"
                                  Content="{Binding $parent[Window].((vm:CollectionImportViewModel)DataContext).Loc[package.choiceMap]}"
                                  Command="{Binding MapCommand}" />
                          <TextBox Text="{Binding RenameTo}" Width="150" FontSize="12" IsVisible="{Binding IsRename}" />
                          <ComboBox ItemsSource="{Binding Targets}" SelectedItem="{Binding MapTarget}" Width="150"
                                    IsVisible="{Binding IsMap}">
                            <ComboBox.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12" />
                              </DataTemplate>
                            </ComboBox.ItemTemplate>
                          </ComboBox>
                        </StackPanel>
                        <TextBlock Text="{Binding SummaryText}" FontSize="12" Foreground="#1F7A3D"
                                   IsVisible="{Binding IsResolved}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- 画像列(5 状態タイル 2×2+未解決ワイド+検算行・mock B-3) -->
            <StackPanel x:Name="ImageColumn" Grid.Row="0" Grid.Column="2" Spacing="10" VerticalAlignment="Top">
              <TextBlock Text="{Binding Loc[package.imagesTitle]}" FontSize="13" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto,8,Auto">
                <Border Classes="stateTile exact" Grid.Row="0" Grid.Column="0">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding ImageCounts.Exact, FallbackValue=0, StringFormat='{}{0:N0}'}"
                               FontSize="18" FontWeight="Bold" Foreground="#1F7A3D" />
                    <TextBlock Text="{Binding Loc[package.stateExact]}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Border Classes="stateTile moved" Grid.Row="0" Grid.Column="2">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding ImageCounts.Moved, FallbackValue=0, StringFormat='{}{0:N0}'}"
                               FontSize="18" FontWeight="Bold" Foreground="#2F6BED" />
                    <TextBlock Text="{Binding Loc[package.stateMoved]}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Loc[package.stateMovedSub]}" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Border Classes="stateTile warn" Grid.Row="2" Grid.Column="0">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding ImageCounts.Changed, FallbackValue=0, StringFormat='{}{0:N0}'}"
                               FontSize="18" FontWeight="Bold" Foreground="#8A6D1A" />
                    <TextBlock Text="{Binding Loc[package.stateChanged]}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Loc[package.stateChangedSub]}" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Border Classes="stateTile warn" Grid.Row="2" Grid.Column="2">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding ImageCounts.Ambiguous, FallbackValue=0, StringFormat='{}{0:N0}'}"
                               FontSize="18" FontWeight="Bold" Foreground="#8A6D1A" />
                    <TextBlock Text="{Binding Loc[package.stateAmbiguous]}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Loc[package.stateAmbiguousSub]}" FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Border Classes="stateTile warn" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ImageCounts.Unresolved, FallbackValue=0, StringFormat='{}{0:N0}'}"
                               FontSize="18" FontWeight="Bold" Foreground="#8A6D1A" />
                    <TextBlock Text="{Binding Loc[package.stateUnresolved]}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
              </Grid>
              <TextBlock x:Name="StateSumText" Text="{Binding StateSumText}" FontSize="11"
                         FontFamily="Consolas,monospace" Foreground="{StaticResource TextMutedBrush}"
                         TextWrapping="Wrap" />

              <!-- 未解決一覧+missing 登録の説明(gate①)+過半警告(EX-002)。「場所を指定」は非搭載=V1裁定・項目9 -->
              <StackPanel Spacing="6" IsVisible="{Binding HasUnresolved}">
                <TextBlock Text="{Binding Loc[package.unresolvedTitle]}" FontSize="12" FontWeight="SemiBold" />
                <Border Classes="card" MaxHeight="200" Padding="8">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding UnresolvedSamples}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,2">
                            <Path Classes="sampleGlyph" Width="12" Height="10" Stretch="Uniform"
                                  VerticalAlignment="Center" Stroke="#8A93A6" StrokeThickness="1.2"
                                  Data="M1,1 L15,1 L15,12 L1,12 Z M4.5,4.5 A1.2,1.2 0 1 0 4.51,4.5 M1,10 L5.5,6.5 L9,9.5 L12,7 L15,9.5" />
                            <TextBlock Text="{Binding}" FontFamily="Consolas,monospace" FontSize="11" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
                <TextBlock Text="{Binding Loc[package.missingNote]}" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
                <Border Background="#FCF4DC" BorderBrush="#EDDFAF" BorderThickness="1" CornerRadius="8" Padding="12,8"
                        IsVisible="{Binding MajorityUnresolved}">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Loc[package.majorityWarn]}" FontSize="12" Foreground="#8A6D1A" TextWrapping="Wrap" />
                    <CheckBox IsChecked="{Binding AcceptMajority}" FontSize="12"
                              Content="{Binding Loc[package.majorityAccept]}" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </StackPanel>
          </Grid>
        </StackPanel>

        <!-- ===== B-4: 結果レポート ===== -->
        <StackPanel Spacing="12" IsVisible="{Binding OnDoneStep}">
          <Border Background="#E7F6EC" BorderBrush="#C4E7D2" BorderThickness="1" CornerRadius="8" Padding="14,10">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding Loc[package.doneTitle]}" FontSize="14" FontWeight="SemiBold" Foreground="#1F7A3D" />
              <TextBlock Text="{Binding ResultSummaryText}" FontSize="12" Foreground="#1F7A3D" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <WrapPanel>
            <Border Classes="stateTile" Margin="0,0,8,8" MinWidth="120">
              <StackPanel>
                <TextBlock Text="{Binding ResultAdded}" FontSize="20" FontWeight="Bold" Foreground="#1F7A3D" />
                <TextBlock Text="{Binding Loc[package.resultAdded]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
              </StackPanel>
            </Border>
            <Border Classes="stateTile" Margin="0,0,8,8" MinWidth="120">
              <StackPanel>
                <TextBlock Text="{Binding ResultUnchanged}" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="{Binding Loc[package.resultUnchanged]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
              </StackPanel>
            </Border>
            <Border Classes="stateTile" Margin="0,0,8,8" MinWidth="120">
              <StackPanel>
                <TextBlock Text="{Binding ResultSkipped}" FontSize="20" FontWeight="Bold" Foreground="#8A6D1A" />
                <TextBlock Text="{Binding Loc[package.resultSkipped]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
              </StackPanel>
            </Border>
            <Border Classes="stateTile" Margin="0,0,8,8" MinWidth="120">
              <StackPanel>
                <TextBlock Text="{Binding ResultConflictResolved}" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="{Binding Loc[package.resultConflicts]}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
              </StackPanel>
            </Border>
          </WrapPanel>
          <StackPanel Spacing="6" IsVisible="{Binding HasUnresolved}">
            <TextBlock Text="{Binding Loc[package.unresolvedRegistered]}" FontSize="12" FontWeight="SemiBold" />
            <Border Classes="card" MaxHeight="160" Padding="8">
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding UnresolvedSamples}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontFamily="Consolas,monospace" FontSize="11" Margin="4,1" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
            <TextBlock Text="{Binding Loc[package.missingDoneNote]}" FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
