<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        x:Class="ViewPrism2.App.Views.CollectionExportWindow"
        x:DataType="vm:CollectionExportViewModel"
        Title="{Binding Loc[package.exportTitle]}"
        Width="560" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- ECO-073 B-1 コレクションを書き出す(CAD snapshot_export_import B-1・mock 権威)。
       GF-073-01: タイトルは Window.Title のみ(本文へ重複させない)・カードにフォルダグリフ・
       ボタンは中央揃え・キャンセルは outline(テーマ既定グレーにしない) -->
  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.outlineButton">
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      <Setter Property="BorderBrush" Value="#D6E0EE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
  </Window.Styles>
  <StackPanel Margin="24" Spacing="16">
    <!-- 書き出すコレクション(入口の三点メニューを開いたコレクション=SS-001 裁定(b)) -->
    <StackPanel Spacing="6">
      <TextBlock Text="{Binding Loc[package.exportCollection]}" FontSize="12"
                 Foreground="{StaticResource TextMutedBrush}" />
      <Border Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
              CornerRadius="10" Padding="14,12">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Border Background="#EEF1F7" CornerRadius="8" Width="36" Height="36">
            <Path Classes="collectionGlyph" Width="17" Height="14" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#5B657A"
                  Data="M1,2.5 C1,1.7 1.7,1 2.5,1 L6,1 L7.5,3 L14.5,3 C15.3,3 16,3.7 16,4.5 L16,11.5 C16,12.3 15.3,13 14.5,13 L2.5,13 C1.7,13 1,12.3 1,11.5 Z" />
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{Binding CollectionName}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="{Binding CollectionSummary}" FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- 出力先(既定名 <名前>.viewprism2-collection.json) -->
    <StackPanel Spacing="6">
      <TextBlock Text="{Binding Loc[package.outputPath]}" FontSize="12"
                 Foreground="{StaticResource TextMutedBrush}" />
      <Border Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1"
              CornerRadius="10" Padding="14,10">
        <DockPanel>
          <Button DockPanel.Dock="Right" Classes="outlineButton" Content="{Binding Loc[snapshot.changeDir]}"
                  Command="{Binding ChangeOutputCommand}" FontSize="12" VerticalAlignment="Center"
                  Foreground="#2F6BED" />
          <TextBlock Text="{Binding OutputPath}" FontFamily="Consolas,monospace" FontSize="12"
                     VerticalAlignment="Center" Margin="0,0,12,0" TextTrimming="CharacterEllipsis" />
        </DockPanel>
      </Border>
      <TextBlock Text="{Binding Loc[package.defaultNameNote]}" FontSize="11"
                 Foreground="{StaticResource TextMutedBrush}" />
    </StackPanel>

    <!-- 画像非含有 callout(M3+ビュー非同梱の理由)。GF-073-02: カメラ×斜線グリフ+太字リード(mock 準拠) -->
    <Border Background="#EEF4FF" BorderBrush="#D6E4FC" BorderThickness="1" CornerRadius="10" Padding="16,12">
      <DockPanel>
        <Path DockPanel.Dock="Left" Classes="calloutGlyph" VerticalAlignment="Top" Margin="0,3,12,0"
              Width="16" Height="14" Stretch="Uniform" Stroke="#2F4A75" StrokeThickness="1.4"
              Data="M2,4 L5,4 L6.5,2 L11.5,2 L13,4 L16,4 L16,13 L2,13 Z M9,6 A2.6,2.6 0 1 0 9.01,6 M1,1 L17,14" />
        <StackPanel Spacing="6">
          <TextBlock x:Name="NoImagesText" FontSize="12" Foreground="#2F4A75" TextWrapping="Wrap"
                     LineHeight="19"><Run FontWeight="SemiBold" Text="{Binding Loc[package.noImagesLead]}" /><Run Text="{Binding Loc[package.noImagesRest]}" /></TextBlock>
          <TextBlock Text="{Binding Loc[package.metadataNote]}" FontSize="11"
                     Foreground="#5A6E92" TextWrapping="Wrap" LineHeight="17" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 書き出し中進捗(done/total 実測) -->
    <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14,10"
            IsVisible="{Binding IsExporting}">
      <StackPanel Spacing="6">
        <DockPanel>
          <TextBlock DockPanel.Dock="Right" Text="{Binding ProgressText}" FontSize="12"
                     Foreground="#2F6BED" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Loc[package.exporting]}" FontSize="12" />
        </DockPanel>
        <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressRatio}" Height="6" CornerRadius="3"
                     Foreground="{StaticResource AccentBrush}" />
        <Button Content="{Binding Loc[common.cancel]}" Command="{Binding CancelExportCommand}"
                FontSize="12" HorizontalAlignment="Right"
                Background="Transparent" Foreground="#2F6BED" BorderThickness="0" Padding="4,0" />
      </StackPanel>
    </Border>

    <TextBlock Text="{Binding StatusMessage}" FontSize="12" TextWrapping="Wrap"
               Foreground="{StaticResource TextMutedBrush}"
               IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />

    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
      <Button Classes="footerBtn outlineButton" Content="{Binding Loc[common.cancel]}" Click="OnCloseClick"
              MinWidth="110" Padding="0,7" IsVisible="{Binding !Done}" />
      <Button Classes="footerBtn" Content="{Binding Loc[package.export]}" Command="{Binding ExportCommand}"
              IsEnabled="{Binding !IsExporting}" IsVisible="{Binding !Done}"
              Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="6"
              MinWidth="120" Padding="0,7" />
      <Button Classes="footerBtn outlineButton" Content="{Binding Loc[common.close]}" Click="OnCloseClick"
              MinWidth="110" Padding="0,7" IsVisible="{Binding Done}" />
    </StackPanel>
  </StackPanel>
</Window>
