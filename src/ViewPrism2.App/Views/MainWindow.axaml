<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:v="using:ViewPrism2.App.Views"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ViewPrism2"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        FontSize="14"
        Foreground="{StaticResource TextPrimaryBrush}"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- K-DESIGN: ウィンドウ既定 1200×800・最小 900×600 / 本文 14px / 見出し 16px / キャプション 12px
       シェル v1.2(仕様 §2.6): 上部タブナビゲーション「タグ」「画像」+右端「設定」 -->

  <Window.Styles>
    <!-- ECO-103(NAV-dirty): タグタブの未保存琥珀ドット= 7px #e8b931+3px 20%α リング(mock v4) -->
    <Style Selector="Border.unsavedDot">
      <Setter Property="Background" Value="#33e8b931" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="Margin" Value="12,12,12,4" />
    </Style>
    <Style Selector="Border.navItem">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Margin" Value="4,0" />
    </Style>
    <Style Selector="Border.navItem.selected">
      <Setter Property="Background" Value="#1F3B82F6" />
    </Style>
    <Style Selector="Button.mini">
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.plain">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="4" />
    </Style>
    <!-- GF-02(REQ-060(b)): グリッドの行(ListBoxItem)から選択視覚を完全に除去する。
         行リスト仮想化の実装が「行選択視覚」として漏れ出ることを禁止(セル強調枠+選択順バッジのみが正)。
         背景は常に透明・パディングなしの素テンプレートで、:selected/:pointerover でも変化させない。 -->
    <Style Selector="ListBox.plain ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Name="PART_ContentPresenter"
                            Background="Transparent"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <!-- GF-02(REQ-060(b)): Fluent テーマの :pointerover/:selected はテンプレート部品(PART_ContentPresenter)に
         背景を適用する(テンプレート定義値より Style が高優先)。アプリスコープのスタイル(テーマより高優先)で
         確実に透明化し、ホバー・選択で行が反応しないようにする(エクスプローラー特大アイコンと同じ=画像のみ反応)。
         リスト表示の行選択視覚は子 Border.listRow.selected が担うため影響しない。 -->
    <Style Selector="ListBox.plain ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.plain ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.cellFrame">
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="2" />
      <!-- 基底背景はスタイルで透明指定(ヒットテスト可)。ローカル属性にしないのは :pointerover が
           上書きできるようにするため(ローカル値は Style より高優先) — GF-02 ホバー -->
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- GF-02(maintainer 再目視): ホバーしたセルだけ控えめに反応(エクスプローラー特大アイコン同様)。
         行は反応しない(セル単位の Border.cellFrame に限定)。8% アクセントの淡い塗り。 -->
    <Style Selector="Border.cellFrame:pointerover">
      <Setter Property="Background" Value="#143B82F6" />
    </Style>
    <!-- 選択表示: アクセント色の 2px 枠(K-DESIGN) -->
    <Style Selector="Border.cellFrame.selected">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="Border.listRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="Border.listRow.selected">
      <Setter Property="Background" Value="#1F3B82F6" />
    </Style>
    <Style Selector="TreeView#NodeTree TreeViewItem">
      <Setter Property="IsExpanded" Value="True" />
    </Style>
    <!-- タブナビゲーション(v1.3): モック CAD 準拠の丸角セグメント+アイコン。
         旧アクセント下線(Button.tab)を撤去し、整理トレイの segmented/segBtnText と同型の
         ピル群へ統一(BadgeBg コンテナ・選択ピル=白地+アクセント文字/アイコン)。 -->
    <Style Selector="Border.tabBar">
      <Setter Property="Background" Value="{StaticResource BadgeBg}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="3" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.tab.selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    </Style>
    <Style Selector="Button.tab.selected">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="Button.tab PathIcon">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tab.selected PathIcon">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>
    <!-- 設定(右端): ピル群とは別の従ボタン。アイコン+ラベルの ghost。ホバーで淡背景。 -->
    <Style Selector="Button.tabAction">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tabAction /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.tabAction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource IconBtnHoverBg}" />
    </Style>
    <Style Selector="Button.tabAction PathIcon">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <DockPanel>
    <!-- 上部タブナビゲーション: 「タグ」「画像」+右端「設定」(仕様 §2.6 v1.2) -->
    <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,0,1">
      <DockPanel Margin="8,8">
        <Button DockPanel.Dock="Right" Classes="tabAction"
                Command="{Binding OpenSettingsCommand}" Margin="0,0,4,0">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <PathIcon Data="{StaticResource TuneIcon}" />
            <TextBlock Text="{Binding Loc[navigation.settings]}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- タブナビ(v1.3): 丸角コンテナに乗ったピル群(アイコン+ラベル)。モック CAD 準拠。 -->
        <Border Classes="tabBar" HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="tab" Classes.selected="{Binding IsTagsTabSelected}"
                    Command="{Binding ShowTagsTabCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <PathIcon Data="{StaticResource TagIcon}" />
                <TextBlock Text="{Binding Loc[navigation.tags]}" VerticalAlignment="Center" />
                <!-- ECO-103(VC-TAG-16①/NAV-dirty): 未保存の琥珀ドット(7px+20%α リング) -->
                <Border Classes="unsavedDot" IsVisible="{Binding TagsTab.Editor.IsDirty}"
                        ToolTip.Tip="{Binding Loc[hierarchy.saveBar.unsaved]}">
                  <Ellipse Width="7" Height="7" Fill="#e8b931" />
                </Border>
              </StackPanel>
            </Button>
            <Button Classes="tab" Classes.selected="{Binding IsImagesTabSelected}"
                    Command="{Binding ShowImagesTabCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <PathIcon Data="{StaticResource ImageTabIcon}" />
                <TextBlock Text="{Binding Loc[navigation.images]}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <!-- 作業タブ(第3タブ・ECO-020) -->
            <Button Classes="tab" Classes.selected="{Binding IsWorkTabSelected}"
                    Command="{Binding ShowWorkTabCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <PathIcon Data="{StaticResource WorkIcon}" />
                <TextBlock Text="{Binding Loc[navigation.work]}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>
      </DockPanel>
    </Border>

    <!-- ステータスバー(非モーダル通知、REQ-031 警告等) -->
    <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,1,0,0" Height="28">
      <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}"
                 FontSize="12" VerticalAlignment="Center" Margin="12,0" TextTrimming="CharacterEllipsis" />
    </Border>

    <Panel>
      <!-- ===== タグタブ(3 ペイン、G-6) ===== -->
      <v:TagsTabView DataContext="{Binding TagsTab}"
                     IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsTagsTabSelected}" />

      <!-- ===== 画像タブ(ImageTabView 一本化・ECO-024 で原典 Grid 撤去) ===== -->
      <v:ImageTabView DataContext="{Binding ImageTab}"
                      IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsImagesTabSelected}" />

      <!-- ===== 作業タブ(ECO-020 / ECO-α: 作業スペース) ===== -->
      <v:WorkTabView DataContext="{Binding WorkTab}"
                     IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsWorkTabSelected}" />

    </Panel>
  </DockPanel>
</Window>
