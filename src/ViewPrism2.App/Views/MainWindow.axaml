<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:v="using:ViewPrism2.App.Views"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ViewPrism2"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        FontSize="14"
        Foreground="{StaticResource TextPrimaryBrush}"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- K-DESIGN: ウィンドウ既定 1200×800・最小 900×600 / 本文 14px / 見出し 16px / キャプション 12px
       シェル v1.2(仕様 §2.6): 上部タブナビゲーション「タグ」「画像」+右端「設定」 -->

  <Window.Resources>
    <!-- 左ペインのビュー一覧項目(全画像/お気に入り/最近 共通。編集/削除はタグタブ側) -->
    <DataTemplate x:Key="NavItemTemplate" x:DataType="vm:ViewListItemViewModel">
      <Border Classes="navItem" Classes.selected="{Binding IsSelected}"
              Background="Transparent" PointerPressed="OnViewItemPressed">
        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="Margin" Value="12,12,12,4" />
    </Style>
    <Style Selector="Border.navItem">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Margin" Value="4,0" />
    </Style>
    <Style Selector="Border.navItem.selected">
      <Setter Property="Background" Value="#1F3B82F6" />
    </Style>
    <Style Selector="Button.mini">
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.plain">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="4" />
    </Style>
    <!-- GF-02(REQ-060(b)): グリッドの行(ListBoxItem)から選択視覚を完全に除去する。
         行リスト仮想化の実装が「行選択視覚」として漏れ出ることを禁止(セル強調枠+選択順バッジのみが正)。
         背景は常に透明・パディングなしの素テンプレートで、:selected/:pointerover でも変化させない。 -->
    <Style Selector="ListBox.plain ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Name="PART_ContentPresenter"
                            Background="Transparent"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <!-- GF-02(REQ-060(b)): Fluent テーマの :pointerover/:selected はテンプレート部品(PART_ContentPresenter)に
         背景を適用する(テンプレート定義値より Style が高優先)。アプリスコープのスタイル(テーマより高優先)で
         確実に透明化し、ホバー・選択で行が反応しないようにする(エクスプローラー特大アイコンと同じ=画像のみ反応)。
         リスト表示の行選択視覚は子 Border.listRow.selected が担うため影響しない。 -->
    <Style Selector="ListBox.plain ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.plain ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.cellFrame">
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="2" />
      <!-- 基底背景はスタイルで透明指定(ヒットテスト可)。ローカル属性にしないのは :pointerover が
           上書きできるようにするため(ローカル値は Style より高優先) — GF-02 ホバー -->
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- GF-02(maintainer 再目視): ホバーしたセルだけ控えめに反応(エクスプローラー特大アイコン同様)。
         行は反応しない(セル単位の Border.cellFrame に限定)。8% アクセントの淡い塗り。 -->
    <Style Selector="Border.cellFrame:pointerover">
      <Setter Property="Background" Value="#143B82F6" />
    </Style>
    <!-- 選択表示: アクセント色の 2px 枠(K-DESIGN) -->
    <Style Selector="Border.cellFrame.selected">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="Border.listRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style Selector="Border.listRow.selected">
      <Setter Property="Background" Value="#1F3B82F6" />
    </Style>
    <Style Selector="TreeView#NodeTree TreeViewItem">
      <Setter Property="IsExpanded" Value="True" />
    </Style>
    <!-- タブナビゲーション(v1.2): 選択タブはアクセント下線+主文字色 -->
    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
    <Style Selector="Button.tab.selected">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
  </Window.Styles>

  <DockPanel>
    <!-- 上部タブナビゲーション: 「タグ」「画像」+右端「設定」(仕様 §2.6 v1.2) -->
    <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,0,1">
      <DockPanel>
        <Button DockPanel.Dock="Right" Classes="tab" Content="{Binding Loc[navigation.settings]}"
                Command="{Binding OpenSettingsCommand}" Margin="0,0,8,0" />
        <!-- M2 scaffold: 画像タブ harness ⇄ 原典 surface トグル(画像タブ表示時のみ。M3 で撤去)。 -->
        <CheckBox DockPanel.Dock="Right" IsChecked="{Binding ShowImageTabPreview}" Content="harness"
                  VerticalAlignment="Center" Margin="0,0,12,0"
                  IsVisible="{Binding IsImagesTabSelected}" />

        <StackPanel Orientation="Horizontal">
          <Button Classes="tab" Classes.selected="{Binding IsTagsTabSelected}"
                  Content="{Binding Loc[navigation.tags]}" Command="{Binding ShowTagsTabCommand}" />
          <Button Classes="tab" Classes.selected="{Binding IsImagesTabSelected}"
                  Content="{Binding Loc[navigation.images]}" Command="{Binding ShowImagesTabCommand}" />
          <!-- 作業タブ(第3タブ・ECO-020) -->
          <Button Classes="tab" Classes.selected="{Binding IsWorkTabSelected}"
                  Content="{Binding Loc[navigation.work]}" Command="{Binding ShowWorkTabCommand}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ステータスバー(非モーダル通知、REQ-031 警告等) -->
    <Border DockPanel.Dock="Bottom" Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,1,0,0" Height="28">
      <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}"
                 FontSize="12" VerticalAlignment="Center" Margin="12,0" TextTrimming="CharacterEllipsis" />
    </Border>

    <Panel>
      <!-- ===== タグタブ(3 ペイン、G-6) ===== -->
      <v:TagsTabView DataContext="{Binding TagsTab}"
                     IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsTagsTabSelected}" />

      <!-- ===== 画像タブ(M2 golden ハーネス: モック準拠の作り直し。dev トグル ON で表示) ===== -->
      <v:ImageTabView DataContext="{Binding ImageTab}"
                      IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowImageTabHarness}" />

      <!-- ===== 作業タブ(ECO-020 / ECO-α: 作業スペース) ===== -->
      <v:WorkTabView DataContext="{Binding WorkTab}"
                     IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsWorkTabSelected}" />

      <!-- ===== 画像タブ(原典 surface: 配線済み。harness OFF 時のみ表示。M3 で作り直し統合) ===== -->
      <Grid ColumnDefinitions="240,1,*,1,280" IsVisible="{Binding ShowImageTabLegacy}">
        <!-- 左: 同期フォルダ(コレクション)+ビュー(お気に入り/最近)+NodeGraph+「全画像」固定入口 -->
        <DockPanel Grid.Column="0" Background="{StaticResource PanelBrush}">
          <StackPanel DockPanel.Dock="Top">
            <DockPanel>
              <Button DockPanel.Dock="Right" Classes="mini" Content="{Binding Loc[menu.manage]}"
                      Command="{Binding OpenFolderManagementCommand}" Margin="0,12,12,4" />
              <TextBlock Classes="sectionHeader" Text="{Binding Loc[navigation.collections]}" />
            </DockPanel>
            <!-- コレクション=選択スコープ(REQ-053 v1.3/CR-2): クリックで選択し一覧の母集合を切替。
                 各項目は名前+画像数+スキャン中表示、パスはツールチップ(CR-8) -->
            <ItemsControl ItemsSource="{Binding FolderPane.Folders}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:FolderRowViewModel">
                  <Border Classes="navItem" Classes.selected="{Binding IsSelected}"
                          Background="Transparent" PointerPressed="OnCollectionPressed"
                          ToolTip.Tip="{Binding Path}">
                    <StackPanel>
                      <DockPanel>
                        <Button DockPanel.Dock="Right" Classes="mini" Content="⟳"
                                IsEnabled="{Binding !IsScanning}"
                                Command="{Binding ScanCommand}" />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ImageCountText}"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="4,0" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                      </DockPanel>
                      <TextBlock Text="{Binding RowMessage}" IsVisible="{Binding RowMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                                 Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Classes="mini" Content="{Binding Loc[folder.add]}"
                    Command="{Binding FolderPane.AddFolderCommand}" Margin="12,2,12,0"
                    HorizontalAlignment="Left" />
            <TextBlock Text="{Binding FolderPane.StatusMessage}"
                       IsVisible="{Binding FolderPane.StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                       Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="12,2" TextWrapping="Wrap" />

            <ContentControl Content="{Binding AllImagesItem}" ContentTemplate="{StaticResource NavItemTemplate}"
                            Margin="0,8,0,0" />
            <TextBlock Classes="sectionHeader" Text="{Binding Loc[view.favorite]}" />
            <ItemsControl ItemsSource="{Binding Favorites}" ItemTemplate="{StaticResource NavItemTemplate}" />
            <TextBlock Classes="sectionHeader" Text="{Binding Loc[view.recent]}" />
            <ItemsControl ItemsSource="{Binding Recents}" ItemTemplate="{StaticResource NavItemTemplate}" />
            <TextBlock Classes="sectionHeader" Text="{Binding Loc[navigation.hierarchy]}" />
          </StackPanel>
          <!-- ECO-006/BL-001: 画像タブナビはルート常在(TreeRoots は選択ビューでルート 1 件を常に持つ)。
               ツリーと空状態プレースホルダは排他のため nodeGraph.empty の重ねを撤去し TreeView を直置きする。 -->
          <TreeView x:Name="NodeTree" ItemsSource="{Binding TreeRoots}"
                    SelectionChanged="OnTreeSelectionChanged" Background="Transparent">
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:GraphNodeViewModel">
                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </DockPanel>

        <Border Grid.Column="1" Background="{StaticResource BorderLineBrush}" />

        <!-- 中央: ツールバー+グリッド⇔リスト -->
        <DockPanel Grid.Column="2">
          <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,0,1">
            <!-- 列数セレクタは v1.3/CR-1 で撤去(列数はレスポンシブ自動算出 — REQ-041) -->
            <!-- v3.0/GF-V3-01: ボタン数増(類似/マージ/ゴミ箱)で既定幅では末尾が見切れたため
                 WrapPanel に変更し、狭い時は折り返して全ボタンを常に見せる(maintainer golden 所見の是正) -->
            <WrapPanel Orientation="Horizontal" Margin="8">
              <WrapPanel.Styles>
                <Style Selector="WrapPanel > :is(Control)">
                  <Setter Property="Margin" Value="0,2,8,2" />
                </Style>
              </WrapPanel.Styles>
              <TextBlock Text="{Binding Loc[view.sortBy]}" VerticalAlignment="Center" FontSize="12"
                         Foreground="{StaticResource TextMutedBrush}" />
              <ComboBox ItemsSource="{Binding Browser.SortFieldOptions}"
                        SelectedItem="{Binding Browser.SelectedSortFieldOption}" MinWidth="110">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:SortFieldOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ComboBox ItemsSource="{Binding Browser.SortDirectionOptions}"
                        SelectedItem="{Binding Browser.SelectedSortDirectionOption}" MinWidth="90">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:SortDirectionOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <ToggleButton IsChecked="{Binding !Browser.IsListMode}" Content="{Binding Loc[toolbar.grid]}" />
              <ToggleButton IsChecked="{Binding Browser.IsListMode}" Content="{Binding Loc[toolbar.list]}" />
              <!-- タグ編集モードトグル(REQ-046): 右パネルが詳細⇔タグ付与に切替 -->
              <ToggleButton IsChecked="{Binding IsTagEditMode}" Content="{Binding Loc[toolbar.tagEdit]}" />
              <Button Content="{Binding Loc[toolbar.refresh]}" Command="{Binding RefreshCommand}" />
              <!-- v3.0 類似検索/マージ/トラッシュの入口(仕様 §2.10、REQ-065/067) -->
              <Border Width="1" Background="{StaticResource BorderLineBrush}" Margin="4,2" />
              <Button Content="{Binding Loc[toolbar.searchSimilar]}" Command="{Binding SearchSimilarCommand}"
                      IsEnabled="{Binding CanSearchSimilar}" />
              <Button Content="{Binding Loc[toolbar.merge]}" Command="{Binding MergeSelectedCommand}"
                      IsEnabled="{Binding CanMerge}" />
              <Button Content="{Binding Loc[toolbar.trash]}" Command="{Binding OpenTrashCommand}" />
              <!-- v4.0 修復ライフサイクルの入口(仕様 §2.11、REQ-072) -->
              <Button Content="{Binding Loc[toolbar.repair]}" Command="{Binding OpenRepairCommand}" />
            </WrapPanel>
          </Border>

          <Panel x:Name="ContentHost" SizeChanged="OnContentSizeChanged">
            <!-- グリッド(REQ-041): 1 行 = N セルの行リストを ListBox(VirtualizingStackPanel)に載せる(K-AVALONIA) -->
            <ListBox Classes="plain" ItemsSource="{Binding Browser.Rows}"
                     IsVisible="{Binding ShowGridPane}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:GridRowViewModel">
                  <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ImageItemViewModel">
                        <Border Classes="cellFrame" Classes.selected="{Binding IsSelected}"
                                Margin="4" PointerPressed="OnCellPressed">
                          <StackPanel Width="{Binding Browser.CellSize}">
                            <!-- 正方形セル+プレースホルダ(パネル背景+'?' グリフ — K-DESIGN) -->
                            <Grid Height="{Binding Browser.CellSize}">
                              <Border Background="{StaticResource PanelBrush}" />
                              <TextBlock Text="?" Foreground="{StaticResource TextMutedBrush}" FontSize="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                              <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="Uniform" />
                              <!-- 選択順バッジ: アクセント色円形・白文字・1 起点(K-DESIGN / G-1) -->
                              <Border IsVisible="{Binding IsSelected}" Background="{StaticResource AccentBrush}"
                                      CornerRadius="10" Width="20" Height="20"
                                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4">
                                <TextBlock Text="{Binding SelectionOrderText}" Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Border>
                            </Grid>
                            <!-- ファイル名: セル下部 1 行・中央寄せ・末尾省略(K-DESIGN / G-1) -->
                            <TextBlock Text="{Binding FileName}" FontSize="12" TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="2,2,2,0" />
                            <!-- DC-GRID-001(A-2): ファイル名の下にファイルサイズを従テキスト(小フォント・ミュート色)で提示 -->
                            <TextBlock Text="{Binding SizeText}" FontSize="11" TextAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" Margin="2,0,2,2" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <!-- リスト(REQ-042): display_columns に従う列構成+ヘッダ -->
            <DockPanel IsVisible="{Binding ShowListPane}">
              <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}"
                      BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,0,1">
                <ItemsControl ItemsSource="{Binding Browser.Columns}" Margin="8,0">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ListColumnViewModel">
                      <TextBlock Text="{Binding Header}" Width="{Binding PixelWidth}" FontSize="12"
                                 Foreground="{StaticResource TextMutedBrush}" Margin="0,6"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
              <ListBox Classes="plain" ItemsSource="{Binding Browser.ListItems}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ImageItemViewModel">
                    <Border Classes="listRow" Classes.selected="{Binding IsSelected}"
                            PointerPressed="OnCellPressed">
                      <ItemsControl ItemsSource="{Binding ListCells}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ListCellViewModel">
                            <TextBlock Text="{Binding Text}" Width="{Binding Column.PixelWidth}"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>

            <!-- 空状態(仕様 §2.6): 中央配置・テキスト弱色(K-DESIGN) -->
            <TextBlock Text="{Binding Browser.EmptyMessage}" IsVisible="{Binding ShowEmptyMessage}"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- コレクション未選択の空状態(REQ-053 v1.3/CR-2: 選択を促す) -->
            <TextBlock Text="{Binding Loc[collection.pleaseSelectCollection]}"
                       IsVisible="{Binding ShowCollectionPrompt}"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Panel>
        </DockPanel>

        <Border Grid.Column="3" Background="{StaticResource BorderLineBrush}" />

        <!-- 右パネル: 通常時=詳細(REQ-043 / G-3)、タグ編集モード時=タグ付与(REQ-046 / G-7) -->
        <Panel Grid.Column="4">
          <ScrollViewer Background="{StaticResource PanelBrush}" IsVisible="{Binding !IsTagEditMode}">
            <Panel>
              <!-- 選択 0 件のプレースホルダ(仕様 §2.6) -->
              <TextBlock Text="{Binding Loc[detail.selectImagePrompt]}" IsVisible="{Binding !Detail.HasImage}"
                         Foreground="{StaticResource TextMutedBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,24" />
              <StackPanel IsVisible="{Binding Detail.HasImage}" Margin="12" Spacing="8">
                <TextBlock Text="{Binding Loc[detail.title]}" FontSize="16" />
                <Grid Height="160">
                  <Border Background="{StaticResource AppBackgroundBrush}"
                          BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="1" />
                  <c:ThumbnailImage SourcePath="{Binding Detail.AbsolutePath}" Stretch="Uniform" Margin="4" />
                </Grid>
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Loc[common.fileName]}" Classes="sectionHeader" Margin="0" />
                  <TextBlock Text="{Binding Detail.FileName}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Loc[common.size]}" Classes="sectionHeader" Margin="0" />
                  <TextBlock Text="{Binding Detail.SizeText}" />
                  <TextBlock Text="{Binding Loc[detail.resolution]}" Classes="sectionHeader" Margin="0" />
                  <TextBlock Text="{Binding Detail.ResolutionText}" />
                  <TextBlock Text="{Binding Loc[common.createdDate]}" Classes="sectionHeader" Margin="0" />
                  <TextBlock Text="{Binding Detail.CreatedText}" />
                  <TextBlock Text="{Binding Loc[common.modifiedDate]}" Classes="sectionHeader" Margin="0" />
                  <TextBlock Text="{Binding Detail.ModifiedText}" />
                </StackPanel>
                <TextBlock Text="{Binding Loc[detail.notes]}" Classes="sectionHeader" Margin="0" />
                <TextBox Text="{Binding Detail.Notes}" AcceptsReturn="True" MinHeight="64" TextWrapping="Wrap" />
                <Button Content="{Binding Loc[common.save]}" Command="{Binding Detail.SaveNotesCommand}"
                        HorizontalAlignment="Right" />
                <TextBlock Text="{Binding Loc[navigation.tags]}" Classes="sectionHeader" Margin="0" />
                <ItemsControl ItemsSource="{Binding Detail.Tags}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DetailTagViewModel">
                      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                        <!-- タグ色見本: 16px 円形スウォッチ。color=NULL は境界線色のリング(K-DESIGN) -->
                        <Ellipse Width="16" Height="16" Fill="{Binding Color, FallbackValue=Transparent}"
                                 IsVisible="{Binding HasColor}" VerticalAlignment="Center" />
                        <Ellipse Width="16" Height="16" Stroke="{StaticResource BorderLineBrush}" StrokeThickness="2"
                                 IsVisible="{Binding !HasColor}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ValueText}" Foreground="{StaticResource TextMutedBrush}"
                                   IsVisible="{Binding HasValue}" VerticalAlignment="Center" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Panel>
          </ScrollViewer>

          <Border Background="{StaticResource PanelBrush}" IsVisible="{Binding IsTagEditMode}">
            <v:TaggingPanelView DataContext="{Binding Tagging}" />
          </Border>
        </Panel>
      </Grid>
    </Panel>
  </DockPanel>
</Window>
