<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ViewPrism2.App.ViewModels"
        xmlns:c="using:ViewPrism2.App.Controls"
        x:Class="ViewPrism2.App.Views.RelinkWindow"
        x:DataType="vm:RelinkViewModel"
        Title="{Binding Loc[relink.title]}"
        Width="720" Height="480"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- 再リンク(REQ-017): missing 選択 → 候補(relative_path 昇順、パス・サイズ・更新日時)→ 確認 → 確定 -->
  <DockPanel Margin="12">
    <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
      <Button DockPanel.Dock="Right" Content="{Binding Loc[relink.commit]}" Command="{Binding CommitCommand}" />
      <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                 VerticalAlignment="Center" TextWrapping="Wrap" />
    </DockPanel>
    <Grid ColumnDefinitions="*,8,*">
      <DockPanel Grid.Column="0">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Loc[relink.missingImages]}" FontSize="12"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
        <Panel>
          <TextBlock Text="{Binding Loc[relink.noMissingImages]}" IsVisible="{Binding HasNoMissing}"
                     Foreground="{StaticResource TextMutedBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
          <ListBox ItemsSource="{Binding MissingImages}" SelectedItem="{Binding SelectedMissing}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:MissingImageViewModel">
                <!-- DC-RELINK-001(A-6): リンク切れ画像行はファイル名(主)+相対パス(従)。実体欠損のためサムネイルなし。 -->
                <StackPanel Spacing="1" Margin="0,2">
                  <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding RelativePath}" FontSize="11"
                             Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Panel>
      </DockPanel>
      <DockPanel Grid.Column="2">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Loc[relink.candidates]}" FontSize="12"
                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
        <Panel>
          <TextBlock Text="{Binding Loc[relink.noCandidates]}" IsVisible="{Binding HasNoCandidates}"
                     Foreground="{StaticResource TextMutedBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
          <ListBox ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:RelinkCandidateViewModel">
                <!-- DC-RELINK-001(A-1・ECO-004): 候補カードは IntegrityReviewWindow と同型 —
                     サムネイル+ファイル名+パス+サイズ+更新日時で再リンク可否を判断できる情報を提示する。 -->
                <Grid ColumnDefinitions="56,8,*" Margin="0,2">
                  <Border Grid.Column="0" Width="56" Height="56" CornerRadius="4" ClipToBounds="True"
                          Background="{StaticResource AppBackgroundBrush}"
                          BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="1">
                    <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" />
                  </Border>
                  <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding RelativePath}" FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}" TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                      <TextBlock Text="{Binding SizeText}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                      <TextBlock Text="{Binding ModifiedText}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Panel>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
