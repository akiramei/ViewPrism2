<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ViewPrism2.App.ViewModels"
             xmlns:c="using:ViewPrism2.App.Controls"
             xmlns:cv="using:ViewPrism2.App.Converters"
             xmlns:media="clr-namespace:Avalonia.Media;assembly=Avalonia.Base"
             x:Class="ViewPrism2.App.Views.WorkTabView"
             x:DataType="vm:WorkTabViewModel">
  <!-- 作業タブ surface(ECO-020 / ECO-α)。左=作業スペースサイドバー / 中央=現スペース画像のブラウズ。
       右ペイン文脈モード(タグ編集/作業=別スペース移動/整理/⋯)は ECO-β。部品は Styles/Components.axaml。 -->
  <Panel>
  <DockPanel LastChildFill="True" Background="{StaticResource AppBackgroundBrush}">

    <!-- ===== 左: 作業スペース(折り畳み 64 / 展開 276) ===== -->
    <Border DockPanel.Dock="Left" Width="{Binding SidebarWidth}"
            Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
      <Panel>
        <!-- 折り畳み: 縦アイコン列 -->
        <StackPanel IsVisible="{Binding Collapsed}" HorizontalAlignment="Center" Spacing="10" Margin="0,12">
          <Button Classes="railIcon" Command="{Binding ToggleSidebarCommand}">
            <PathIcon Data="{StaticResource ChevronRightIcon}" />
          </Button>
          <Button Classes="railIcon" Command="{Binding AddWorkspaceCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.add]}">
            <PathIcon Data="{StaticResource PlusIcon}" />
          </Button>
          <Border Width="30" Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,2" />
          <ItemsControl ItemsSource="{Binding Workspaces}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:WorkspaceRowVM">
                <Button Classes="railIcon" Classes.selected="{Binding IsActive}" ToolTip.Tip="{Binding Name}"
                        Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).SelectWorkspaceCommand}"
                        CommandParameter="{Binding Id}">
                  <PathIcon Data="{StaticResource WorkIcon}" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- 展開: ヘッダ + 作業スペース行 -->
        <DockPanel IsVisible="{Binding Expanded}">
          <Border DockPanel.Dock="Top" MinHeight="58" Padding="18,0,16,0"
                  BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
              <Button DockPanel.Dock="Right" Classes="crumbHome" Command="{Binding ToggleSidebarCommand}">
                <PathIcon Data="{StaticResource ChevronLeftIcon}" />
              </Button>
              <Button DockPanel.Dock="Right" Classes="crumbHome" Command="{Binding AddWorkspaceCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.add]}">
                <PathIcon Data="{StaticResource PlusIcon}" />
              </Button>
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[navigation.workspaces]}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>
          </Border>
          <ScrollViewer Margin="12,8,12,8" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Workspaces}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:WorkspaceRowVM">
                  <Border Classes="navCard" Classes.selected="{Binding IsActive}" MinHeight="52"
                          Width="{Binding $parent[ScrollViewer].Viewport.Width}"
                          PointerPressed="OnWorkspacePressed">
                    <DockPanel>
                      <Border DockPanel.Dock="Right" Classes="countBadge" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CountText}" />
                      </Border>
                      <!-- 削除(デフォルト以外)。確認モーダルを開く。 -->
                      <Button DockPanel.Dock="Right" Classes="crumbHome" VerticalAlignment="Center"
                              IsVisible="{Binding CanRename}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.delete]}"
                              Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).RequestDeleteWorkspaceCommand}"
                              CommandParameter="{Binding Id}">
                        <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                      </Button>
                      <Button DockPanel.Dock="Right" Classes="crumbHome" VerticalAlignment="Center"
                              IsVisible="{Binding CanRename}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.rename]}"
                              Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).StartRenameCommand}"
                              CommandParameter="{Binding Id}">
                        <PathIcon Data="{StaticResource PencilIcon}" Width="14" Height="14" />
                      </Button>
                      <Border DockPanel.Dock="Left" Classes="leadIcon" Width="34" Height="34" Margin="0,0,11,0">
                        <PathIcon Data="{StaticResource WorkIcon}" />
                      </Border>
                      <StackPanel VerticalAlignment="Center" MinWidth="0">
                        <!-- 名前 or インラインリネーム -->
                        <Panel>
                          <TextBox IsVisible="{Binding IsEditing}" FontSize="13.5" FontWeight="SemiBold"
                                   Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).RenameValue, Mode=TwoWay}"
                                   KeyDown="OnRenameKeyDown" LostFocus="OnRenameLostFocus" />
                          <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding ShowName}">
                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center" />
                            <Border IsVisible="{Binding IsDefault}" Background="#E3EEFD" CornerRadius="5"
                                    Padding="6,1" VerticalAlignment="Center">
                              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.badgeDefault]}" FontSize="10" FontWeight="Bold" Foreground="#2F6BED" />
                            </Border>
                          </StackPanel>
                        </Panel>
                        <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="{StaticResource FaintTextBrush}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" IsVisible="{Binding ShowName}" />
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Panel>
    </Border>

    <!-- ===== 右: タグ編集パネル(編集モード時のみ・E-UI-TAGASSIGN-029 再利用・ECO-β-2) ===== -->
    <Border DockPanel.Dock="Right" Classes="editPanel" Width="344" IsVisible="{Binding EditMode}">
      <DockPanel>
        <Border DockPanel.Dock="Top" Classes="editPanelHeader">
          <DockPanel VerticalAlignment="Center">
            <Button DockPanel.Dock="Right" Classes="iconBtn" Command="{Binding ToggleEditCommand}">
              <PathIcon Data="{StaticResource CloseIcon}" />
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource PencilIcon}" Width="17" Height="17" Foreground="{StaticResource AccentBrush}" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.tagEdit]}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
              <Border Classes="accentPill" IsVisible="{Binding HasSelection}">
                <TextBlock Text="{Binding SelectionLabel}" />
              </Border>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- 空(選択なし) -->
        <StackPanel IsVisible="{Binding PanelEmpty}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14" Margin="30">
          <Border Width="58" Height="58" CornerRadius="15" Background="{StaticResource BadgeBg}" HorizontalAlignment="Center">
            <PathIcon Data="{StaticResource CheckIcon}" Width="26" Height="26" Foreground="{StaticResource FaintTextBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[image.feature.selectImages]}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ChipSimpleFg}" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.selectImagesHint]}"
                     FontSize="12.5" Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="220" />
        </StackPanel>

        <!-- アクティブ(選択あり) -->
        <DockPanel IsVisible="{Binding PanelActive}">
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*" Margin="14,10,14,0">
            <Button Grid.Column="0" Classes="panelTab" Classes.active="{Binding OnCurrentTab}"
                    Content="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.currentTags]}" Command="{Binding TabCurrentCommand}" />
            <Button Grid.Column="1" Classes="panelTab" Classes.active="{Binding OnAddTab}"
                    Content="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.addTag]}" Command="{Binding TabAddCommand}" />
          </Grid>
          <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource CardBorderBrush}" />

          <!-- 現在のタグ -->
          <ScrollViewer IsVisible="{Binding OnCurrentTab}" Padding="16">
            <StackPanel>
              <StackPanel IsVisible="{Binding HasCurrentTags}">
                <TextBlock Text="{Binding CurrentNote}" FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" Margin="0,0,0,11" />
                <ItemsControl ItemsSource="{Binding CurrentTags}">
                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CurrentTagVM">
                      <Border Height="30" Padding="11,0,6,0" CornerRadius="9" BorderThickness="1"
                              Background="{Binding PillBackground}" BorderBrush="{Binding PillBorderBrush}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                          <Ellipse Width="8" Height="8" Fill="{Binding DotBrush}" VerticalAlignment="Center" />
                          <TextBlock Text="{Binding Label}" FontSize="12.5" FontWeight="SemiBold" Foreground="{Binding PillForeground}" VerticalAlignment="Center" />
                          <Button Classes="iconBtn" Width="18" Height="18"
                                  Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).RemoveCurrentTagCommand}"
                                  CommandParameter="{Binding}">
                            <PathIcon Data="{StaticResource CloseIcon}" Width="11" Height="11" />
                          </Button>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              <StackPanel IsVisible="{Binding NoCurrentTags}" HorizontalAlignment="Center" Spacing="10" Margin="10,32">
                <PathIcon Data="{StaticResource TagIcon}" Width="28" Height="28" Foreground="{StaticResource FaintTextBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding NoCurrentLabel}" FontSize="12.5" Foreground="{StaticResource FaintTextBrush}" TextAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <!-- タグ追加 -->
          <ScrollViewer IsVisible="{Binding OnAddTab}" Padding="16,14,16,20">
            <StackPanel>
              <!-- ECO-041: タグ追加検索(画像タブと同一構造・mock 作業タブ準拠)。
                   整列は ECO-040 規約(VerticalContentAlignment+Padding 4,0)。 -->
              <Border Background="{StaticResource BadgeBg}" CornerRadius="10" Height="40" Padding="12,0" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource SearchIcon}" Width="15" Height="15" Foreground="{StaticResource FaintTextBrush}" />
                  <TextBox Text="{Binding AddQuery}" PlaceholderText="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.searchPlaceholder]}" BorderThickness="0" Background="Transparent"
                           VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="4,0" Width="240" />
                </StackPanel>
              </Border>
              <ItemsControl ItemsSource="{Binding AddGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AddGroupVM">
                  <StackPanel Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,0,0,9">
                      <Border Background="{Binding LabelBackground}" CornerRadius="6" Padding="9,3" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" Foreground="{Binding LabelForeground}" />
                      </Border>
                      <TextBlock Text="{Binding Hint}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Tags}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:AddRowVM">
                          <StackPanel Margin="0,0,0,6">
                            <Border Classes="tagAddRow" Classes.added="{Binding Added}"
                                    Background="{Binding RowBackground}" BorderBrush="{Binding RowBorderBrush}" PointerPressed="OnAddRowPressed">
                              <DockPanel VerticalAlignment="Center">
                                <Panel DockPanel.Dock="Right" VerticalAlignment="Center">
                                  <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding Added}">
                                    <PathIcon Data="{StaticResource CheckIcon}" Width="13" Height="13" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Classes="addedBadge" Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.added]}" />
                                  </StackPanel>
                                  <PathIcon Classes="addAffordance" Data="{StaticResource ChevronDownIcon}" IsVisible="{Binding ShowCaret}" RenderTransformOrigin="50%,50%">
                                    <PathIcon.RenderTransform><RotateTransform Angle="{Binding CaretAngle}" /></PathIcon.RenderTransform>
                                  </PathIcon>
                                  <PathIcon Classes="addAffordance" Data="{StaticResource PlusIcon}" IsVisible="{Binding Plain}" />
                                </Panel>
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                  <Ellipse Width="9" Height="9" Fill="{Binding DotBrush}" Opacity="{Binding DotOpacity}" VerticalAlignment="Center" />
                                  <TextBlock Classes="addName" Text="{Binding Name}" />
                                </StackPanel>
                              </DockPanel>
                            </Border>
                            <!-- インライン候補値(テキスト型) -->
                            <Border Classes="inlinePicker" IsVisible="{Binding ShowText}">
                              <StackPanel Spacing="8">
                                <TextBlock Classes="pickerHint" Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.selectFromCandidates]}" />
                                <ItemsControl ItemsSource="{Binding ValueChips}">
                                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ValueChipVM">
                                      <Border Height="30" Padding="13,0" CornerRadius="9" BorderThickness="1"
                                              Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" Margin="0,0,7,7" PointerPressed="OnValueChipPressed">
                                        <TextBlock Text="{Binding Label}" FontSize="12.5" FontWeight="SemiBold" Foreground="{Binding Foreground}" VerticalAlignment="Center" />
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>
                            <!-- インライン数値セル(数値型) -->
                            <Border Classes="inlinePicker" IsVisible="{Binding ShowNum}">
                              <StackPanel Spacing="9">
                                <DockPanel>
                                  <TextBlock Classes="numCurrent" DockPanel.Dock="Right" Text="{Binding NumCurrent}" />
                                  <TextBlock Classes="pickerHint">
                                    <TextBlock.Text>
                                      <MultiBinding Converter="{x:Static cv:LocalizedFormatConverter.Instance}">
                                        <Binding Path="$parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.selectValueToApply]" />
                                        <Binding Path="NumRange" />
                                      </MultiBinding>
                                    </TextBlock.Text>
                                  </TextBlock>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding NumCells}">
                                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NumCellVM">
                                      <Border Classes="numCell" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" Margin="3,0" PointerPressed="OnNumCellPressed">
                                        <TextBlock Text="{Binding Label}" Foreground="{Binding Foreground}" />
                                      </Border>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </Border>
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </DockPanel>
    </Border>

    <!-- ===== 右: 整理トレイ(整理モード時のみ・E-UI-SIMILARITY-035 + E-UI-MERGE-036 再利用・ECO-β-3) ===== -->
    <Border DockPanel.Dock="Right" Classes="editPanel" Width="344" IsVisible="{Binding IsOrganizeContext}">
      <DockPanel>
        <Border DockPanel.Dock="Top" Classes="editPanelHeader">
          <DockPanel VerticalAlignment="Center">
            <Button DockPanel.Dock="Right" Classes="iconBtn" Command="{Binding ToggleOrganizeCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.organizeExit]}">
              <PathIcon Data="{StaticResource CloseIcon}" />
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource TuneIcon}" Width="17" Height="17" Foreground="{StaticResource AccentBrush}" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.organize]}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- 完了状態 -->
        <ScrollViewer IsVisible="{Binding OrganizeDone}" Margin="16,14" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Width="{Binding $parent[ScrollViewer].Viewport.Width}" Spacing="14">
            <Border Classes="organizeDoneCard">
              <StackPanel Spacing="11">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentBrush}">
                    <PathIcon Data="{StaticResource CheckIcon}" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.consolidated]}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
                <TextBlock Text="{Binding DoneSummary}" FontSize="12.5" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <!-- ECO-044(IMG-011 裁定③): ログに基づく補償 Undo。条件破れ時は不活性+理由表示 -->
            <Button Classes="toolbarBtn" Height="40" MinHeight="40" IsEnabled="{Binding CanUndo}"
                    Command="{Binding UndoMergeCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.undoHint]}">
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.undo]}" VerticalAlignment="Center" />
            </Button>
            <TextBlock IsVisible="{Binding HasUndoNote}" Text="{Binding UndoNote}" FontSize="11.5"
                       Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap" TextAlignment="Center" />
            <Button Classes="primaryAction" Command="{Binding ContinueOrganizeCommand}">
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.continueOrganizing]}" />
            </Button>
          </StackPanel>
        </ScrollViewer>

        <!-- 作業トレイ(完了前)= 3 ゾーン固定(ECO-056/v2 A-1 裁定: 画像タブと同一部品 —
             work_tab.md L95「トレイの構造・操作は画像タブと同一部品」)。 -->
        <DockPanel IsVisible="{Binding !OrganizeDone}">

          <!-- PINNED TOP: マージ先(残す1枚) -->
          <StackPanel DockPanel.Dock="Top" Margin="16,14,16,0" Spacing="8">
            <Border Classes="trayBadge dest" HorizontalAlignment="Left">
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.targetSlotTitle]}" />
            </Border>
            <Border Classes="organizeSlot target" IsVisible="{Binding HasMergeTarget}">
              <DockPanel>
                <!-- マージ先の解除(ECO-056/CAD v2 clearDest・A-2 裁定=REQ-067) -->
                <Button DockPanel.Dock="Right" Classes="iconBtn" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.clearTargetTip]}" VerticalAlignment="Top"
                        Command="{Binding ClearMergeTargetCommand}">
                  <PathIcon Data="{StaticResource CloseIcon}" Width="13" Height="13" />
                </Button>
                <Border DockPanel.Dock="Left" Classes="organizeMini" Margin="0,0,10,0">
                  <c:ThumbnailImage SourcePath="{Binding MergeTarget.AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding MergeTarget.HasThumb}" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding MergeTarget.Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding MergeTarget.SizeLabel}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="{StaticResource CheckIcon}" Width="12" Height="12"
                              Foreground="{StaticResource OrganizeDestBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.thisRemains]}" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource OrganizeDestBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </DockPanel>
            </Border>
            <Border Classes="trayHint" IsVisible="{Binding ShowMergeTargetPrompt}">
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.pickTargetHint]}" />
            </Border>
          </StackPanel>

          <!-- PINNED TOP: 整理対象ヘッダ(件数バッジ+すべて解除) -->
          <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
            <Button DockPanel.Dock="Right" Classes="trayLink" Content="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.clearAll]}"
                    IsVisible="{Binding HasOrganizeTargets}" Command="{Binding ClearOrganizeTargetsCommand}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="trayBadge src">
                <TextBlock>
                  <TextBlock.Text>
                    <MultiBinding Converter="{x:Static cv:LocalizedFormatConverter.Instance}">
                      <Binding Path="$parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.organizeTargetsBadge]" />
                      <Binding Path="OrganizeTargets.Count" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Border>
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.consolidateNote]}" FontSize="11" Foreground="{StaticResource FaintTextBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </DockPanel>

          <!-- PINNED BOTTOM: 似た画像を探す(折りたたみ)+マージを実行 -->
          <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Margin="16,12,16,14" Spacing="10">
              <Button Classes="searchHead" Command="{Binding ToggleSearchOpenCommand}">
                <DockPanel VerticalAlignment="Center">
                  <PathIcon DockPanel.Dock="Right" Classes="caret" Classes.open="{Binding SearchOpen}"
                            Data="{StaticResource ChevronDownIcon}" Width="15" Height="15"
                            Foreground="{StaticResource FaintTextBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="9">
                    <PathIcon Data="{StaticResource SearchIcon}" Width="15" Height="15"
                              Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[similar.findSimilar]}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </DockPanel>
              </Button>
              <Border Classes="searchPanel" IsVisible="{Binding SearchOpen}">
                <StackPanel Spacing="12">
                  <!-- 方式タブ: 順・名称は CAD(v1 から)=「条件検索」「類似画像検索」 -->
                  <Border Classes="segmented" IsEnabled="{Binding ShowSearchSettings}">
                    <Grid ColumnDefinitions="*,*">
                      <Button Grid.Column="0" Classes="segBtnText" HorizontalAlignment="Stretch"
                              Classes.active="{Binding IsCriteriaMethod}" Content="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.criteriaSearch]}"
                              Command="{Binding SetSearchMethodCommand}" CommandParameter="criteria" />
                      <Button Grid.Column="1" Classes="segBtnText" HorizontalAlignment="Stretch"
                              Classes.active="{Binding IsSimilarMethod}" Content="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[similar.title]}"
                              Command="{Binding SetSearchMethodCommand}" CommandParameter="similar" />
                    </Grid>
                  </Border>
                  <!-- 切替コンテンツは 150px 固定(GF-056-01: モック height:150px — タブ切替で高さを変えない) -->
                  <Panel Height="150">
                    <Panel IsVisible="{Binding ShowSearchSettings}">
                    <!-- 条件: 2 列グリッド+チェック行(ECO-055 意味論・意匠は v2 モック) -->
                    <StackPanel Spacing="8" VerticalAlignment="Top" IsVisible="{Binding IsCriteriaMethod}">
                      <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[similar.matchCriteriaHeading]}" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{StaticResource FaintTextBrush}" />
                      <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto,8,Auto">
                        <ToggleButton Grid.Row="0" Grid.Column="0" Classes="condRow" IsChecked="{Binding CondHash}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="condBox">
                              <PathIcon Data="{StaticResource CheckIcon}" Width="11" Height="11" Foreground="White"
                                        IsVisible="{Binding $parent[ToggleButton].IsChecked}" />
                            </Border>
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.hashValue]}" VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Row="0" Grid.Column="2" Classes="condRow" IsChecked="{Binding CondExt}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="condBox">
                              <PathIcon Data="{StaticResource CheckIcon}" Width="11" Height="11" Foreground="White"
                                        IsVisible="{Binding $parent[ToggleButton].IsChecked}" />
                            </Border>
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.extension]}" VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Row="2" Grid.Column="0" Classes="condRow" IsChecked="{Binding CondSize}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="condBox">
                              <PathIcon Data="{StaticResource CheckIcon}" Width="11" Height="11" Foreground="White"
                                        IsVisible="{Binding $parent[ToggleButton].IsChecked}" />
                            </Border>
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.size]}" VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Row="2" Grid.Column="2" Classes="condRow" IsChecked="{Binding CondName}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="condBox">
                              <PathIcon Data="{StaticResource CheckIcon}" Width="11" Height="11" Foreground="White"
                                        IsVisible="{Binding $parent[ToggleButton].IsChecked}" />
                            </Border>
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.fileName]}" VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Row="4" Grid.Column="0" Classes="condRow" IsChecked="{Binding CondDate}">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Classes="condBox">
                              <PathIcon Data="{StaticResource CheckIcon}" Width="11" Height="11" Foreground="White"
                                        IsVisible="{Binding $parent[ToggleButton].IsChecked}" />
                            </Border>
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.modifiedDate]}" VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                      </Grid>
                    </StackPanel>
                    <!-- GF-067-02: 表示結果と同じ検証器一致度%をしきい値にする -->
                    <StackPanel Spacing="4" VerticalAlignment="Top" IsVisible="{Binding IsSimilarMethod}">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                          <TextBlock.Text>
                            <MultiBinding Converter="{x:Static cv:LocalizedFormatConverter.Instance}">
                              <Binding Path="$parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.thresholdAtLeast]" />
                              <Binding Path="SimilarThresholdLabel" />
                            </MultiBinding>
                          </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[similar.matchThreshold]}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource FaintTextBrush}" />
                      </DockPanel>
                      <Slider Minimum="50" Maximum="100" Value="{Binding SimilarThreshold}" />
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="100%" FontSize="10.5" Foreground="{StaticResource FaintTextBrush}" />
                        <TextBlock Text="50%" FontSize="10.5" Foreground="{StaticResource FaintTextBrush}" />
                      </DockPanel>
                    </StackPanel>
                    </Panel>
                    <StackPanel IsVisible="{Binding ShowSearchProgress}" Spacing="14"
                                VerticalAlignment="Center" HorizontalAlignment="Stretch">
                      <TextBlock Text="{Binding SearchProgressLabel}" FontSize="12.5" FontWeight="SemiBold"
                                 Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" />
                      <ProgressBar Minimum="0" Maximum="100" Value="{Binding SearchProgressValue}"
                                   IsIndeterminate="{Binding SearchProgressIndeterminate}" Height="8" />
                    </StackPanel>
                  </Panel>
                  <!-- 探す(文言は CAD v1 から「探す」) -->
                  <Button Classes="primaryAction" Height="40" IsVisible="{Binding ShowStartSearch}"
                          IsEnabled="{Binding CanRunSearch}"
                          Command="{Binding RunSearchCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                      <PathIcon Data="{StaticResource SearchIcon}" Width="14" Height="14" />
                      <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[modals.advancedRepair.find]}" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                  <Button Classes="primaryAction" Height="40" IsVisible="{Binding ShowCancelSearch}"
                          IsEnabled="{Binding CanCancelSearch}" Command="{Binding CancelSearchCommand}">
                    <TextBlock Text="{Binding SearchCancelButtonLabel}" />
                  </Button>
                </StackPanel>
              </Border>

              <!-- タグ統合トグルは ECO-044(IMG-011 裁定②)で撤去 — タグ union は常時 ON -->

              <!-- マージを実行(緑=モック色意味論)+不可時の理由注記 -->
              <Button Classes="primaryAction merge" IsEnabled="{Binding CanExecuteMerge}" Command="{Binding ExecuteMergeCommand}">
                <TextBlock Text="{Binding MergeButtonLabel}" />
              </Button>
              <TextBlock IsVisible="{Binding ShowMergeBlockedNote}" Text="{Binding MergeBlockedNote}"
                         FontSize="11" Foreground="{StaticResource FaintTextBrush}" TextAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- SCROLLABLE: 整理対象リストのみ内部スクロール(3 ゾーンの可変部) -->
          <ScrollViewer Margin="16,0,16,8" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <Border Classes="trayHint" IsVisible="{Binding ShowOrganizeTargetsPrompt}">
                <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.noCandidates]}" />
              </Border>
              <ItemsControl ItemsSource="{Binding OrganizeTargets}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:OrganizeSlotVM">
                    <Border Classes="organizeSlot" Margin="0,0,0,8">
                      <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                          <Button Classes="iconBtn" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.setAsTarget]}"
                                  Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).PromoteToMergeTargetCommand}"
                                  CommandParameter="{Binding Id}">
                            <PathIcon Data="{StaticResource ArrowUpIcon}" Width="14" Height="14" />
                          </Button>
                          <Button Classes="iconBtn" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.removeFromTargets]}"
                                  Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).RemoveOrganizeTargetCommand}"
                                  CommandParameter="{Binding Id}">
                            <PathIcon Data="{StaticResource CloseIcon}" Width="13" Height="13" />
                          </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Left" Classes="organizeMini" Margin="0,0,10,0">
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding HasThumb}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding SizeLabel}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" />
                        </StackPanel>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </DockPanel>
    </Border>

    <!-- ===== 中央: ブラウズ ===== -->
    <DockPanel LastChildFill="True">

      <!-- ツールバー(ソート + レイアウト)。モード入口・⋯ は ECO-β -->
      <Border DockPanel.Dock="Top" MinHeight="60" Padding="18,0"
              BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
        <DockPanel VerticalAlignment="Center">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <!-- ECO-069/FL-003案A: ImageTab v2を基本3列へ射影。listはheader、gridは単一menu。 -->
            <Border IsVisible="{Binding ShowSortChip}" Background="#EAF1FE" BorderBrush="#CFE0FC" BorderThickness="1"
                    CornerRadius="14" Padding="10,3" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource ArrowUpIcon}" Width="12" Height="12" Foreground="{StaticResource AccentBrush}"
                          RenderTransformOrigin="50%,50%">
                  <PathIcon.RenderTransform><RotateTransform Angle="{Binding ColumnSortArrowAngle}" /></PathIcon.RenderTransform>
                </PathIcon>
                <TextBlock Text="{Binding ColumnSortLabel}" FontSize="12.5" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <Button Command="{Binding ClearColumnSortCommand}" Background="Transparent" Padding="2"
                        ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.clearSort]}" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource CloseIcon}" Width="11" Height="11" Foreground="{StaticResource TextMutedBrush}" />
                </Button>
              </StackPanel>
            </Border>
            <Panel IsVisible="{Binding IsGrid}">
                <Button x:Name="SortTrigger" Classes="toolbarBtn" Command="{Binding ToggleSortMenuCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource SortIcon}" Foreground="{StaticResource FaintTextBrush}" />
                    <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.sort]}" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    <Border Background="{StaticResource CardSelectedBgBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding SortButtonBadge}" FontSize="11.5" Foreground="{StaticResource AccentBrush}" />
                    </Border>
                    <PathIcon Data="{StaticResource ChevronDownIcon}" Width="14" Height="14" Foreground="{StaticResource FaintTextBrush}" />
                  </StackPanel>
                </Button>
                <Popup PlacementTarget="{Binding #SortTrigger}" Placement="BottomEdgeAlignedRight"
                       VerticalOffset="6" IsOpen="{Binding SortMenuOpen}" IsLightDismissEnabled="True"
                       Closed="OnSortMenuClosed">
                  <Border Classes="popupMenu" Width="248">
                    <StackPanel>
                      <StackPanel Margin="12,10,12,6">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.sort]}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.sortFromBasicInfo]}" FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" />
                      </StackPanel>
                      <ItemsControl x:Name="SortColumnsList" ItemsSource="{Binding SortColumns}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SortOptionVM">
                            <Button Classes="menuRow sortOpt" Classes.active="{Binding IsActive}"
                                    Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).SelectColumnSortCommand}"
                                    CommandParameter="{Binding Key}">
                              <DockPanel>
                                <PathIcon DockPanel.Dock="Right" Data="{StaticResource ArrowUpIcon}" Width="13" Height="13"
                                          Foreground="{StaticResource AccentBrush}" IsVisible="{Binding IsActive}"
                                          RenderTransformOrigin="50%,50%" VerticalAlignment="Center">
                                  <PathIcon.RenderTransform><RotateTransform Angle="{Binding ArrowAngle}" /></PathIcon.RenderTransform>
                                </PathIcon>
                                <Border DockPanel.Dock="Right" Background="{StaticResource CardSelectedBgBrush}" CornerRadius="4"
                                        Padding="5,1" Margin="6,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding KindChip}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="13.5" Foreground="{StaticResource TextPrimaryBrush}" />
                              </DockPanel>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <Border Classes="segmented" Margin="12,6,12,10">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                          <Button Classes="segBtn" Classes.active="{Binding SortAscActive}" Command="{Binding SetSortAscCommand}">
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.ascending]}" FontSize="12.5" />
                          </Button>
                          <Button Classes="segBtn" Classes.active="{Binding SortDescActive}" Command="{Binding SetSortDescCommand}">
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.descending]}" FontSize="12.5" />
                          </Button>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                </Popup>
            </Panel>
            <Border Classes="segmented">
              <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Classes="segBtn" Classes.active="{Binding IsGrid}" Command="{Binding SetGridCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.grid]}">
                  <PathIcon Data="{StaticResource GridIcon}" />
                </Button>
                <Button Classes="segBtn" Classes.active="{Binding IsList}" Command="{Binding SetListCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.list]}">
                  <PathIcon Data="{StaticResource ViewListIcon}" />
                </Button>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- 左: 文脈モード入口(β-1=作業 / β-2=タグ編集・排他表示) -->
          <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
            <Button Classes="toolbarBtn" Classes.active="{Binding EditMode}" FontWeight="SemiBold"
                    IsVisible="{Binding ShowEditEntry}" Command="{Binding ToggleEditCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource PencilIcon}" Width="16" Height="16" />
                <TextBlock Text="{Binding EditButtonLabel}" />
              </StackPanel>
            </Button>
            <Button Classes="toolbarBtn" Classes.active="{Binding OrganizeMode}" FontWeight="SemiBold"
                    IsVisible="{Binding ShowOrganizeEntry}" Command="{Binding ToggleOrganizeCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource TuneIcon}" Width="16" Height="16" />
                <TextBlock Text="{Binding OrganizeButtonLabel}" />
              </StackPanel>
            </Button>
            <Button Classes="toolbarBtn" Classes.workActive="{Binding WorkMode}" FontWeight="SemiBold"
                    IsVisible="{Binding ShowWorkEntry}" Command="{Binding ToggleWorkCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource WorkIcon}" Width="16" Height="16" />
                <TextBlock Text="{Binding WorkButtonLabel}" />
              </StackPanel>
            </Button>
            <!-- 作業モード: 別スペースへ移動 -->
            <Panel IsVisible="{Binding WorkMode}">
              <Button x:Name="MoveTrigger" Classes="workAddBtn" Classes.ready="{Binding HasMoveSelection}"
                      IsEnabled="{Binding HasMoveSelection}" Command="{Binding ToggleMoveMenuCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource WorkIcon}" Width="16" Height="16" />
                  <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.moveToOther]}" />
                  <Border Classes="workAddBadge" IsVisible="{Binding HasMoveSelection}">
                    <TextBlock Text="{Binding MoveSelCount}" />
                  </Border>
                </StackPanel>
              </Button>
              <Popup PlacementTarget="{Binding #MoveTrigger}" Placement="BottomEdgeAlignedLeft"
                     VerticalOffset="6" IsOpen="{Binding MoveMenuOpen}" IsLightDismissEnabled="True"
                     Closed="OnMenuClosed">
                <Border Classes="popupMenu" Width="240">
                  <StackPanel>
                    <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.moveDestination]}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FaintTextBrush}" Margin="9,6,9,8" />
                    <ItemsControl ItemsSource="{Binding MoveTargets}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MoveTargetVM">
                          <Button Classes="menuRow"
                                  Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).MoveSelectedToCommand}"
                                  CommandParameter="{Binding Id}">
                            <DockPanel>
                              <Border DockPanel.Dock="Left" Classes="leadIcon" Width="28" Height="28" Margin="0,0,10,0">
                                <PathIcon Data="{StaticResource WorkIcon}" Width="15" Height="15" />
                              </Border>
                              <TextBlock DockPanel.Dock="Right" Text="{Binding CountText}" FontSize="11"
                                         Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                              <TextBlock Text="{Binding Name}" FontSize="13.5" VerticalAlignment="Center"
                                         Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock IsVisible="{Binding NoMoveTargets}" Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.noOtherSpaces]}"
                               FontSize="12.5" Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="10" />
                  </StackPanel>
                </Border>
              </Popup>
            </Panel>

            <!-- 削除モード(β-4): ⋯「削除」で入る排他モード。削除を終了 + ゴミ箱へ移動(赤・件数バッジ) -->
            <Button Classes="toolbarBtn" IsVisible="{Binding DeleteMode}" Command="{Binding ExitDeleteCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource CloseIcon}" />
                <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.deleteExit]}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Classes="delMoveBtn" Classes.ready="{Binding CanDeleteToTrash}" IsVisible="{Binding DeleteMode}"
                    IsEnabled="{Binding CanDeleteToTrash}" Command="{Binding DeleteToTrashCommand}">
              <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.moveToTrash]}" VerticalAlignment="Center" />
                <Border Classes="delMoveBadge" IsVisible="{Binding HasDeleteSelection}">
                  <TextBlock Text="{Binding DeleteSelCount}" />
                </Border>
              </StackPanel>
            </Button>

            <!-- ⋯ = メンテナンスメニュー(削除/ゴミ箱)。修復はコレクションスコープのため作業タブでは非搭載。モード中は隠す -->
            <Panel IsVisible="{Binding !InAnyMode}">
              <Button x:Name="MoreTrigger" Classes="toolbarBtn square" Command="{Binding ToggleMoreMenuCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.more]}">
                <PathIcon Data="{StaticResource MoreIcon}" />
              </Button>
              <Popup PlacementTarget="{Binding #MoreTrigger}" Placement="BottomEdgeAlignedRight"
                     VerticalOffset="6" IsOpen="{Binding MoreMenuOpen}" IsLightDismissEnabled="True" Closed="OnMenuClosed">
                <Border Classes="popupMenu" Width="200">
                  <StackPanel>
                    <Button Classes="menuRow" Command="{Binding EnterDeleteCommand}" IsEnabled="{Binding CanOpenMaintenance}">
                      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" Foreground="#C4282D" />
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.delete]}" FontSize="13.5" FontWeight="SemiBold" Foreground="#C4282D" />
                      </StackPanel>
                    </Button>
                    <Button Classes="menuRow" Command="{Binding OpenTrashCommand}" IsEnabled="{Binding CanOpenMaintenance}">
                      <DockPanel VerticalAlignment="Center">
                        <PathIcon DockPanel.Dock="Left" Data="{StaticResource TrashIcon}" Width="16" Height="16" Margin="0,0,10,0" Foreground="{StaticResource FaintTextBrush}" />
                        <Border DockPanel.Dock="Right" Classes="trashCountBadge" IsVisible="{Binding HasTrash}">
                          <TextBlock Text="{Binding TrashCount}" />
                        </Border>
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.trash]}" FontSize="13.5" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                      </DockPanel>
                    </Button>
                  </StackPanel>
                </Border>
              </Popup>
            </Panel>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- ワークスペースヘッダ(パンくず代替) -->
      <Border DockPanel.Dock="Top" Classes="breadcrumbBar">
        <DockPanel VerticalAlignment="Center">
          <TextBlock DockPanel.Dock="Right" Classes="crumbCount" Text="{Binding CountLabel}" />
          <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
            <Border Classes="leadIcon" Width="26" Height="26">
              <PathIcon Data="{StaticResource WorkIcon}" Width="15" Height="15" />
            </Border>
            <TextBlock Text="{Binding WsName}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
            <Border IsVisible="{Binding WsIsDefault}" Background="#E3EEFD" CornerRadius="5" Padding="7,2" VerticalAlignment="Center">
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.defaultAutoAdd]}" FontSize="10" FontWeight="Bold" Foreground="#2F6BED" />
            </Border>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- タグ絞り込みチップ行 -->
      <Border DockPanel.Dock="Top" IsVisible="{Binding ShowChips}" Background="{StaticResource AppBackgroundBrush}"
              BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="18,11">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Classes="chipHint" Text="{Binding ChipHintLabel}" IsVisible="{Binding ShowChipHint}" />
          <ItemsControl ItemsSource="{Binding Chips}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ChipVM">
                <Border Classes="tagChip" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}"
                        Margin="0,0,8,0" PointerPressed="OnChipPressed">
                  <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="{Binding DotBrush}" IsVisible="{Binding HasDot}" VerticalAlignment="Center" />
                    <TextBlock Classes="chipLabel" Text="{Binding Label}" Foreground="{Binding LabelBrush}" />
                    <Border Classes="chipCount" Background="{Binding CountBackground}" IsVisible="{Binding HasCount}">
                      <TextBlock Text="{Binding Count}" Foreground="{Binding CountForeground}" />
                    </Border>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- 本体: 空 / グリッド / リスト -->
      <Panel>
        <!-- 空スペース -->
        <StackPanel IsVisible="{Binding WsEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="340">
          <Border Classes="leadIcon" Width="64" Height="64" HorizontalAlignment="Center">
            <PathIcon Data="{StaticResource WorkIcon}" Width="30" Height="30" Foreground="{StaticResource FaintTextBrush}" />
          </Border>
          <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.emptyTitle]}" FontSize="15" FontWeight="SemiBold"
                     Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
          <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.emptyHint]}"
                     FontSize="13" Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap" TextAlignment="Center" />
        </StackPanel>

        <!-- グリッド(ECO-058 / E-UI-BROWSE-022 read-across): 画像タブと同じ仮想化ホストを使い、
             画面外セルと ThumbnailImage を実体化しない。セルのテンプレートと操作経路は不変。 -->
        <ScrollViewer IsVisible="{Binding ShowBrowseGrid}">
          <ItemsRepeater ItemsSource="{Binding Items}" Margin="11">
            <ItemsRepeater.Layout>
              <UniformGridLayout MinItemWidth="164" MinItemHeight="206" MinColumnSpacing="0" MinRowSpacing="0" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="vm:ImageItemVM">
                <Border Classes="thumbCellWrap" Width="164" Padding="7" PointerPressed="OnItemPressed">
                 <StackPanel Width="150">
                  <Border Classes="thumbCell" Classes.selected="{Binding IsSelected}"
                          Classes.mergeTarget="{Binding IsMergeTarget}"
                          Classes.organizeTarget="{Binding IsOrganizeTarget}" Height="150">
                    <Panel>
                      <Border Background="{Binding ThumbBrush}" IsVisible="{Binding HasThumb}" />
                      <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill"
                                        IsVisible="{Binding HasRealThumb}" />
                      <PathIcon Data="{StaticResource ImageIcon}" Width="38" Height="38" Foreground="#C6CDD8"
                                IsVisible="{Binding IsPlaceholder}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <!-- 選択順バッジ(作業モード) -->
                      <Border Classes="thumbCheck" Classes.selected="{Binding IsSelected}" IsVisible="{Binding Selectable}">
                        <TextBlock Text="{Binding SelectionOrderText}" IsVisible="{Binding IsSelected}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <!-- 整理モード(ECO-056/v2 モック): 宛先も対象も 左上チェック+右上バッジ の同型(宛先=緑/対象=青) -->
                      <Border Classes="thumbCheck selected dest" IsVisible="{Binding IsMergeTarget}">
                        <PathIcon Data="{StaticResource CheckIcon}" />
                      </Border>
                      <Border Classes="cellTag dest" IsVisible="{Binding IsMergeTarget}">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.colDestination]}" />
                      </Border>
                      <Border Classes="thumbCheck selected" IsVisible="{Binding IsOrganizeTarget}">
                        <PathIcon Data="{StaticResource CheckIcon}" />
                      </Border>
                      <Border Classes="cellTag" IsVisible="{Binding IsOrganizeTarget}">
                        <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[merge.colTarget]}" />
                      </Border>
                      <!-- タグドット -->
                      <ItemsControl ItemsSource="{Binding TagDots}" IsVisible="{Binding HasTagDots}"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="7">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="media:IBrush">
                            <Ellipse Width="8" Height="8" Fill="{Binding}" Stroke="White" StrokeThickness="1.5" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Panel>
                  </Border>
                  <TextBlock Classes="thumbName" Text="{Binding Name}" HorizontalAlignment="Center" />
                  <StackPanel IsVisible="{Binding ShowSortItem}" Orientation="Horizontal" Spacing="4"
                              HorizontalAlignment="Center" Margin="0,1,0,0">
                    <TextBlock Text="{Binding SortItemLabel}" FontSize="10.5" VerticalAlignment="Center"
                               Foreground="{StaticResource FaintTextBrush}" />
                    <TextBlock Text="{Binding SortItemCell.Text}" FontSize="10.5" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" />
                  </StackPanel>
                 </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </ScrollViewer>

        <!-- リスト(ECO-069: 固定基本3列をv2 header/cell共通templateで描画) -->
        <DockPanel IsVisible="{Binding ShowBrowseList}">
          <DockPanel.Styles>
            <Style Selector="Button.listHeaderBtn">
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="6,2" />
              <Setter Property="HorizontalAlignment" Value="Stretch" />
              <Setter Property="HorizontalContentAlignment" Value="Left" />
              <Setter Property="Cursor" Value="Hand" />
              <Setter Property="CornerRadius" Value="4" />
            </Style>
            <Style Selector="Button.listHeaderBtn:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
            </Style>
            <Style Selector="Button.listHeaderBtn.active"><Setter Property="FontWeight" Value="SemiBold" /></Style>
          </DockPanel.Styles>
          <Border DockPanel.Dock="Top" Classes="imageListHeader">
            <DockPanel VerticalAlignment="Center">
              <Border DockPanel.Dock="Left" Width="44" />
              <ItemsControl ItemsSource="{Binding ListColumns}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Grid cv:GridColumnsBinder.Template="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).ColumnTemplate}" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter" x:DataType="vm:ListColumnHeaderVM">
                    <Setter Property="Grid.Column" Value="{Binding ColumnIndex}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ListColumnHeaderVM">
                    <Button Classes="listHeaderBtn" Classes.active="{Binding IsSortActive}"
                            Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).SelectColumnSortCommand}"
                            CommandParameter="{Binding Key}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                        <TextBlock Text="▲" FontSize="9" Foreground="{StaticResource AccentBrush}"
                                   IsVisible="{Binding IsSortActive}">
                          <TextBlock.RenderTransform><RotateTransform Angle="{Binding ArrowAngle}" /></TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="⇅" FontSize="10" Foreground="{StaticResource FaintTextBrush}"
                                   IsVisible="{Binding !IsSortActive}" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DockPanel>
          </Border>
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ImageItemVM">
                  <Border Classes="imageListRow" Classes.selected="{Binding IsSelected}" PointerPressed="OnItemPressed">
                    <DockPanel VerticalAlignment="Center">
                      <Border DockPanel.Dock="Left" Classes="imageListMini" Margin="0,0,12,0">
                        <Panel>
                          <Border Background="{Binding ThumbBrush}" IsVisible="{Binding HasThumb}" />
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill"
                                            IsVisible="{Binding HasRealThumb}" />
                          <PathIcon Data="{StaticResource ImageIcon}" Width="16" Height="16" Foreground="#C6CDD8"
                                    IsVisible="{Binding IsPlaceholder}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Panel>
                      </Border>
                      <ItemsControl ItemsSource="{Binding Cells}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <Grid cv:GridColumnsBinder.Template="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).ColumnTemplate}" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                          <Style Selector="ContentPresenter" x:DataType="vm:ListCell">
                            <Setter Property="Grid.Column" Value="{Binding ColumnIndex}" />
                          </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ListCell">
                            <TextBlock IsVisible="{Binding IsBasic}" Text="{Binding Text}" Margin="6,0"
                                       Classes="listMeta" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>

        <!-- 整理: 検索結果(中央ペイン全面・候補+一致率)。ECO-β-3。
             ECO-056: ヘッダ(グリッドへ+件数+方式)を追加 — 画像タブと同一部品 -->
        <DockPanel IsVisible="{Binding ShowSearchResults}" Background="{StaticResource AppBackgroundBrush}">
          <Border DockPanel.Dock="Top" Height="48" Padding="18,0" Background="{StaticResource PanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
              <TextBlock DockPanel.Dock="Right" Text="{Binding SearchMethodLabel}" FontSize="12"
                         Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Classes="toolbarBtn" Height="32" MinHeight="32" Padding="8,0,11,0"
                        Command="{Binding BackToGridCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource ChevronLeftIcon}" Width="14" Height="14"
                              Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.toGrid]}" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
                <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.searchResults]}" FontSize="13.5" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SearchResultsSubLabel}" FontSize="12.5"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
              </StackPanel>
            </DockPanel>
          </Border>
          <ScrollViewer>
          <StackPanel Margin="18,14">
            <StackPanel IsVisible="{Binding NoSearchResults}" HorizontalAlignment="Center" Spacing="10" Margin="0,40">
              <PathIcon Data="{StaticResource SearchIcon}" Width="34" Height="34" Foreground="{StaticResource FaintTextBrush}" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[view.noCandidatesFound]}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding SearchResults}">
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:OrganizeResultVM">
                  <Border Classes="resultCard" Classes.added="{Binding Added}" Width="184" Margin="0,0,12,12">
                    <StackPanel>
                      <Border Height="150">
                        <Panel>
                          <Border Background="{StaticResource ValueChipBg}" />
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding HasThumb}" />
                          <Border Classes="matchBadge"><TextBlock Text="{Binding ScoreText}" /></Border>
                        </Panel>
                      </Border>
                      <DockPanel Margin="10,8,10,10">
                        <Button DockPanel.Dock="Right" Classes="toolbarBtn" Height="30" MinHeight="30" Padding="9,0" IsVisible="{Binding !Added}"
                                Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).AddCandidateToTargetsCommand}"
                                CommandParameter="{Binding Id}">
                          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource PlusIcon}" Width="13" Height="13" />
                            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.add]}" VerticalAlignment="Center" />
                          </StackPanel>
                        </Button>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" IsVisible="{Binding Added}">
                          <PathIcon Data="{StaticResource CheckIcon}" Width="13" Height="13" Foreground="{StaticResource AccentBrush}" />
                          <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[tagging.added]}" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                      </DockPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Panel>
    </DockPanel>
  </DockPanel>

  <!-- ===== ゴミ箱ポップアップ(ECO-019 再利用・ECO-β-4): 作業タブ内 中央オーバーレイ ===== -->
  <Border IsVisible="{Binding TrashOpen}" Background="#57142C2C">
    <Border Classes="trashPopup" Width="780" MaxWidth="780" Height="560" MaxHeight="560"
            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
      <DockPanel LastChildFill="True">
        <!-- header -->
        <Border DockPanel.Dock="Top" Classes="trashPopupHeader">
          <DockPanel VerticalAlignment="Center">
            <Button DockPanel.Dock="Right" Classes="iconBtn" Command="{Binding CloseTrashCommand}" ToolTip.Tip="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.close]}">
              <PathIcon Data="{StaticResource CloseIcon}" />
            </Button>
            <Button DockPanel.Dock="Right" Classes="toolbarBtn" Height="32" MinHeight="32" Padding="11,0" Margin="0,0,8,0"
                    IsVisible="{Binding HasTrashItems}" Command="{Binding ToggleTrashSelectAllCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource CheckIcon}" Width="14" Height="14" />
                <TextBlock Text="{Binding TrashSelectAllLabel}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource TrashIcon}" Width="18" Height="18" Foreground="{StaticResource FaintTextBrush}" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[toolbar.trash]}" FontSize="15.5" FontWeight="SemiBold" VerticalAlignment="Center" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[trash.deletedImages]}" FontSize="12" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
              <Border Classes="trashCountBadge" IsVisible="{Binding HasTrashItems}">
                <TextBlock Text="{Binding TrashPopupCount}" />
              </Border>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- footer action bar -->
        <Border DockPanel.Dock="Bottom" Classes="trashPopupFooter" IsVisible="{Binding HasTrashItems}">
          <DockPanel VerticalAlignment="Center">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <Button Classes="trashRestoreBtn" Classes.ready="{Binding CanRestoreTrash}"
                      IsEnabled="{Binding CanRestoreTrash}" Command="{Binding RestoreSelectedTrashCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource RestoreIcon}" Width="16" Height="16" />
                  <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[trash.restore]}" VerticalAlignment="Center" />
                  <Border Classes="trashRestoreBadge" IsVisible="{Binding HasTrashSel}"><TextBlock Text="{Binding TrashSelCount}" /></Border>
                </StackPanel>
              </Button>
              <Button Classes="delMoveBtn" Classes.ready="{Binding CanPurgeTrash}"
                      IsEnabled="{Binding CanPurgeTrash}" Command="{Binding PurgeSelectedTrashCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                  <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[trash.purge]}" VerticalAlignment="Center" />
                  <Border Classes="delMoveBadge" IsVisible="{Binding HasTrashSel}"><TextBlock Text="{Binding TrashSelCount}" /></Border>
                </StackPanel>
              </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
              <TextBlock Text="{Binding TrashSelCountLabel}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
              <Button Classes="trashEmptyBtn" Command="{Binding EmptyTrashCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource TrashIcon}" Width="15" Height="15" />
                  <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[modals.trash.emptyTrash]}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- body: グリッド or 空状態 -->
        <Panel>
          <ScrollViewer IsVisible="{Binding HasTrashItems}" Padding="18" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding TrashPopupItems}">
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TrashPopupItemVM">
                  <Button Classes="trashCard"
                          Command="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).ToggleTrashItemCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Width="150" Margin="6">
                      <Border Classes="trashThumb" Classes.selected="{Binding IsSelected}">
                        <Panel>
                          <Border Background="{StaticResource ValueChipBg}" />
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding HasThumb}" />
                          <Border Classes="trashCheck" Classes.selected="{Binding IsSelected}">
                            <PathIcon Data="{StaticResource CheckIcon}" Width="13" Height="13" Foreground="White" IsVisible="{Binding IsSelected}" />
                          </Border>
                        </Panel>
                      </Border>
                      <TextBlock Text="{Binding Name}" FontSize="12" Margin="2,7,2,0" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Text="{Binding SizeLabel}" FontSize="11" Margin="2,1,2,0" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <StackPanel IsVisible="{Binding TrashPopupEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="13">
            <Border Width="58" Height="58" CornerRadius="15" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
              <PathIcon Data="{StaticResource TrashIcon}" Width="26" Height="26" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[trash.emptyStateFull]}" FontSize="13.5" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[trash.emptyStateHint]}" FontSize="13.5" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            </StackPanel>
          </StackPanel>
        </Panel>
      </DockPanel>
    </Border>
  </Border>

  <!-- ===== 作業スペース削除 確認モーダル(タブ内中央オーバーレイ) ===== -->
  <Border IsVisible="{Binding WsDeleteOpen}" Background="#57142C2C">
    <Border Classes="trashPopup" Width="400" MaxWidth="400"
            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
      <StackPanel Margin="22" Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="11">
          <Border Width="40" Height="40" CornerRadius="11" Background="#FBEDED" VerticalAlignment="Center">
            <PathIcon Data="{StaticResource TrashIcon}" Width="19" Height="19" Foreground="#C4282D"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[workspace.delete]}" FontSize="15.5" FontWeight="SemiBold"
                     VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>
        <TextBlock Text="{Binding WsDeleteMessage}" FontSize="13" TextWrapping="Wrap" LineHeight="20"
                   Foreground="{StaticResource TextMutedBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="9" HorizontalAlignment="Right">
          <Button Classes="toolbarBtn" Height="40" MinHeight="40" Padding="16,0"
                  Command="{Binding CancelDeleteWorkspaceCommand}">
            <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.cancel]}" VerticalAlignment="Center" />
          </Button>
          <Button Classes="delMoveBtn ready" Command="{Binding ConfirmDeleteWorkspaceCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
              <TextBlock Text="{Binding $parent[UserControl].((vm:WorkTabViewModel)DataContext).Loc[common.deleteConfirm]}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>
  </Border>

  </Panel>
</UserControl>
