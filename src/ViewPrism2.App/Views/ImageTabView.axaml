<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ViewPrism2.App.ViewModels"
             xmlns:views="using:ViewPrism2.App.Views"
             xmlns:c="using:ViewPrism2.App.Controls"
             xmlns:cv="using:ViewPrism2.App.Converters"
             xmlns:media="clr-namespace:Avalonia.Media;assembly=Avalonia.Base"
             x:Class="ViewPrism2.App.Views.ImageTabView"
             x:DataType="vm:ImageTabViewModel">
  <!-- 画像タブ製造(M2)golden ハーネス。3 ペイン content(左=コレクション/中央=ブラウズ/右=タグ編集モード時)。
       部品は Styles/Components.axaml(M1)。シェル(titlebar/menu/navbar/⌘K)はシェル所有のため含めない。
       タグ色依存の塗りは ImageTabSeedViewModel が IBrush で供給(Background/BorderBrush/Foreground バインド)。 -->

  <Panel>
  <DockPanel LastChildFill="True" Background="{StaticResource AppBackgroundBrush}">

    <!-- ===== 左: コレクション(折り畳み 64 / 展開 276) ===== -->
    <Border DockPanel.Dock="Left" Width="{Binding SidebarWidth}"
            Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource BorderLineBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
      <Panel>
        <!-- 折り畳み: 縦アイコン列 -->
        <StackPanel IsVisible="{Binding Collapsed}" HorizontalAlignment="Center" Spacing="10" Margin="0,12">
          <Button Classes="railIcon" Command="{Binding ToggleSidebarCommand}">
            <PathIcon Data="{StaticResource ChevronRightIcon}" />
          </Button>
          <!-- コレクション管理(追加/スキャン/削除)入口(ECO-013/IMG-009) -->
          <Button Classes="railIcon" Command="{Binding OpenFolderManagementCommand}" ToolTip.Tip="コレクションを管理">
            <PathIcon Data="{StaticResource PlusIcon}" />
          </Button>
          <Border Width="30" Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,2" />
          <ItemsControl ItemsSource="{Binding Collections}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CollectionRowVM">
                <Button Classes="railIcon" Classes.selected="{Binding IsSelected}" ToolTip.Tip="{Binding Name}"
                        Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).SelectCollectionCommand}"
                        CommandParameter="{Binding Id}">
                  <PathIcon Data="{StaticResource FolderIcon}" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- 展開: ヘッダ + コレクション行 -->
        <DockPanel IsVisible="{Binding Expanded}">
          <Border DockPanel.Dock="Top" MinHeight="58" Padding="18,0,16,0"
                  BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
              <Button DockPanel.Dock="Right" Classes="crumbHome" Command="{Binding ToggleSidebarCommand}">
                <PathIcon Data="{StaticResource ChevronLeftIcon}" />
              </Button>
              <!-- コレクション管理(追加/スキャン/削除)入口(ECO-013/IMG-009) -->
              <Button DockPanel.Dock="Right" Classes="crumbHome" Command="{Binding OpenFolderManagementCommand}" ToolTip.Tip="コレクションを管理">
                <PathIcon Data="{StaticResource PlusIcon}" />
              </Button>
              <TextBlock Text="コレクション" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>
          </Border>
          <ScrollViewer Margin="12,8,12,8" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Collections}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CollectionRowVM">
                  <Border Classes="navCard" Classes.selected="{Binding IsSelected}" MinHeight="52"
                          Width="{Binding $parent[ScrollViewer].Viewport.Width}"
                          PointerPressed="OnCollectionPressed" ToolTip.Tip="{Binding Path}">
                    <DockPanel>
                      <Border DockPanel.Dock="Right" Classes="countBadge" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CountText}" />
                      </Border>
                      <Border DockPanel.Dock="Left" Classes="leadIcon" Width="34" Height="34" Margin="0,0,11,0">
                        <PathIcon Data="{StaticResource FolderIcon}" />
                      </Border>
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Medium"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding Path}" FontSize="11" Foreground="{StaticResource FaintTextBrush}"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Panel>
    </Border>

    <!-- ===== 右: タグ編集パネル(編集モード時のみ) ===== -->
    <Border DockPanel.Dock="Right" Classes="editPanel" Width="344" IsVisible="{Binding EditMode}">
      <DockPanel>
        <!-- ヘッダ -->
        <Border DockPanel.Dock="Top" Classes="editPanelHeader">
          <DockPanel VerticalAlignment="Center">
            <Button DockPanel.Dock="Right" Classes="iconBtn" Command="{Binding ToggleEditCommand}">
              <PathIcon Data="{StaticResource CloseIcon}" />
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource PencilIcon}" Width="17" Height="17" Foreground="{StaticResource AccentBrush}" />
              <TextBlock Text="タグ編集" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
              <Border Classes="accentPill" IsVisible="{Binding HasSelection}">
                <TextBlock Text="{Binding SelectionLabel}" />
              </Border>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- 空(選択なし) -->
        <StackPanel IsVisible="{Binding PanelEmpty}" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="14" Margin="30">
          <Border Width="58" Height="58" CornerRadius="15" Background="{StaticResource BadgeBg}"
                  HorizontalAlignment="Center">
            <PathIcon Data="{StaticResource CheckIcon}" Width="26" Height="26" Foreground="{StaticResource FaintTextBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="画像を選択" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ChipSimpleFg}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="タグ付けする画像をグリッドから選んでください。Ctrl＝複数選択 / Shift＝連続選択"
                     FontSize="12.5" Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap"
                     TextAlignment="Center" MaxWidth="220" />
        </StackPanel>

        <!-- アクティブ(選択あり) -->
        <DockPanel IsVisible="{Binding PanelActive}">
          <!-- タブ -->
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*" Margin="14,10,14,0">
            <Button Grid.Column="0" Classes="panelTab" Classes.active="{Binding OnCurrentTab}"
                    Content="現在のタグ" Command="{Binding TabCurrentCommand}" />
            <Button Grid.Column="1" Classes="panelTab" Classes.active="{Binding OnAddTab}"
                    Content="タグ追加" Command="{Binding TabAddCommand}" />
          </Grid>
          <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource CardBorderBrush}" />

          <!-- 現在のタグ -->
          <ScrollViewer IsVisible="{Binding OnCurrentTab}" Padding="16">
            <StackPanel>
              <StackPanel IsVisible="{Binding HasCurrentTags}">
                <TextBlock Text="{Binding CurrentNote}" FontSize="11.5" Foreground="{StaticResource FaintTextBrush}"
                           Margin="0,0,0,11" />
                <ItemsControl ItemsSource="{Binding CurrentTags}">
                  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CurrentTagVM">
                      <Border Height="30" Padding="11,0,6,0" CornerRadius="9" BorderThickness="1"
                              Background="{Binding PillBackground}" BorderBrush="{Binding PillBorderBrush}"
                              Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                          <Ellipse Width="8" Height="8" Fill="{Binding DotBrush}" VerticalAlignment="Center" />
                          <TextBlock Text="{Binding Label}" FontSize="12.5" FontWeight="SemiBold"
                                     Foreground="{Binding PillForeground}" VerticalAlignment="Center" />
                          <Button Classes="iconBtn" Width="18" Height="18"
                                  Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).RemoveCurrentTagCommand}"
                                  CommandParameter="{Binding}">
                            <PathIcon Data="{StaticResource CloseIcon}" Width="11" Height="11" />
                          </Button>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              <StackPanel IsVisible="{Binding NoCurrentTags}" HorizontalAlignment="Center" Spacing="10" Margin="10,32">
                <PathIcon Data="{StaticResource TagIcon}" Width="28" Height="28" Foreground="{StaticResource FaintTextBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{Binding NoCurrentLabel}" FontSize="12.5" Foreground="{StaticResource FaintTextBrush}"
                           TextAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <!-- タグ追加 -->
          <ScrollViewer IsVisible="{Binding OnAddTab}" Padding="16,14,16,20">
            <StackPanel>
              <Border Background="{StaticResource BadgeBg}" CornerRadius="10" Height="40" Padding="12,0" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource SearchIcon}" Width="15" Height="15" Foreground="{StaticResource FaintTextBrush}" />
                  <!-- ECO-040: テーマ既定余白を潰すため VerticalContentAlignment を明示(上寄り防止)。
                       Padding 左右 4 はフォーカス枠へのテキスト密着防止(GF-040-01)。 -->
                  <TextBox Text="{Binding AddQuery}" PlaceholderText="タグを検索…" BorderThickness="0" Background="Transparent"
                           VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="4,0" Width="240" />
                </StackPanel>
              </Border>
              <ItemsControl ItemsSource="{Binding AddGroups}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:AddGroupVM">
                    <StackPanel Margin="0,0,0,16">
                      <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,0,0,9">
                        <Border Background="{Binding LabelBackground}" CornerRadius="6" Padding="9,3" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" Foreground="{Binding LabelForeground}" />
                        </Border>
                        <TextBlock Text="{Binding Hint}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                      </StackPanel>
                      <ItemsControl ItemsSource="{Binding Tags}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:AddRowVM">
                            <StackPanel Margin="0,0,0,6">
                              <Border Classes="tagAddRow" Classes.added="{Binding Added}"
                                      Background="{Binding RowBackground}" BorderBrush="{Binding RowBorderBrush}"
                                      PointerPressed="OnAddRowPressed">
                                <DockPanel VerticalAlignment="Center">
                                  <Panel DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding Added}">
                                      <PathIcon Data="{StaticResource CheckIcon}" Width="13" Height="13"
                                                Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
                                      <TextBlock Classes="addedBadge" Text="追加済" />
                                    </StackPanel>
                                    <PathIcon Classes="addAffordance" Data="{StaticResource ChevronDownIcon}"
                                              IsVisible="{Binding ShowCaret}" RenderTransformOrigin="50%,50%">
                                      <PathIcon.RenderTransform>
                                        <RotateTransform Angle="{Binding CaretAngle}" />
                                      </PathIcon.RenderTransform>
                                    </PathIcon>
                                    <PathIcon Classes="addAffordance" Data="{StaticResource PlusIcon}" IsVisible="{Binding Plain}" />
                                  </Panel>
                                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" Fill="{Binding DotBrush}" Opacity="{Binding DotOpacity}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Classes="addName" Text="{Binding Name}" />
                                  </StackPanel>
                                </DockPanel>
                              </Border>

                              <!-- インライン候補値(テキスト型) -->
                              <Border Classes="inlinePicker" IsVisible="{Binding ShowText}">
                                <StackPanel Spacing="8">
                                  <TextBlock Classes="pickerHint" Text="候補値から選んで付与" />
                                  <ItemsControl ItemsSource="{Binding ValueChips}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:ValueChipVM">
                                        <Border Height="30" Padding="13,0" CornerRadius="9" BorderThickness="1"
                                                Background="{Binding Background}" BorderBrush="{Binding BorderBrush}"
                                                Margin="0,0,7,7" PointerPressed="OnValueChipPressed">
                                          <TextBlock Text="{Binding Label}" FontSize="12.5" FontWeight="SemiBold"
                                                     Foreground="{Binding Foreground}" VerticalAlignment="Center" />
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </StackPanel>
                              </Border>

                              <!-- インライン数値セル(数値型) -->
                              <Border Classes="inlinePicker" IsVisible="{Binding ShowNum}">
                                <StackPanel Spacing="9">
                                  <DockPanel>
                                    <TextBlock Classes="numCurrent" DockPanel.Dock="Right" Text="{Binding NumCurrent}" />
                                    <TextBlock Classes="pickerHint" Text="{Binding NumRange, StringFormat='値を選んで付与（{0}）'}" />
                                  </DockPanel>
                                  <ItemsControl ItemsSource="{Binding NumCells}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:NumCellVM">
                                        <Border Classes="numCell" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}"
                                                Margin="3,0" PointerPressed="OnNumCellPressed">
                                          <TextBlock Text="{Binding Label}" Foreground="{Binding Foreground}" />
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <!-- 連番別アクション(UQ-I02b): 固定値はセル、連番はダイアログ経由で別途付与 -->
                                  <Button Classes="toolbarBtn" HorizontalAlignment="Left" Height="32" MinHeight="32" Padding="11,0"
                                          Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).ApplySequentialCommand}"
                                          CommandParameter="{Binding Id}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                      <PathIcon Data="{StaticResource SortIcon}" Width="14" Height="14" />
                                      <TextBlock Text="連番で付与…" VerticalAlignment="Center" />
                                    </StackPanel>
                                  </Button>
                                </StackPanel>
                              </Border>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </DockPanel>
    </Border>

    <!-- ===== 右: 整理トレイ(整理モード時のみ・ECO-014) ===== -->
    <Border DockPanel.Dock="Right" Classes="editPanel" Width="344" IsVisible="{Binding IsOrganizeContext}">
      <DockPanel>
        <!-- ヘッダ -->
        <Border DockPanel.Dock="Top" Classes="editPanelHeader">
          <DockPanel VerticalAlignment="Center">
            <Button DockPanel.Dock="Right" Classes="iconBtn" Command="{Binding ToggleOrganizeCommand}" ToolTip.Tip="整理を終了">
              <PathIcon Data="{StaticResource CloseIcon}" />
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource TuneIcon}" Width="17" Height="17" Foreground="{StaticResource AccentBrush}" />
              <TextBlock Text="整理" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- ECO-037: 完了/トレイの 2 枚は Panel で包み DockPanel の最終子(残域いっぱい=幅 344 確定)にする。
             旧構造では完了 ScrollViewer が Dock 無指定の非終端子(Dock.Left 既定)となり、中身の
             StackPanel Width={Binding $parent[ScrollViewer].Viewport.Width}(1d93378 の幅はみ出し是正)と
             自己参照して幅 0 に潰れ、完了パネルが表示されなかった(51 G-E36S3 追補・A/B で既存バグ確定)。 -->
        <Panel>
        <!-- 完了状態(統合しました) -->
        <ScrollViewer IsVisible="{Binding OrganizeDone}" Margin="16,14" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Width="{Binding $parent[ScrollViewer].Viewport.Width}" Spacing="14">
            <Border Classes="organizeDoneCard">
              <StackPanel Spacing="11">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentBrush}">
                    <PathIcon Data="{StaticResource CheckIcon}" Width="18" Height="18" Foreground="White"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Text="統合しました" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                             Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
                <TextBlock Text="{Binding DoneSummary}" FontSize="12.5" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <!-- ECO-044(IMG-011 裁定③): ログに基づく補償 Undo。条件破れ時は不活性+理由表示 -->
            <Button Classes="toolbarBtn" Height="40" MinHeight="40" IsEnabled="{Binding CanUndo}"
                    Command="{Binding UndoMergeCommand}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    ToolTip.Tip="直前のマージを取り消す（マージ後に変更が無い場合のみ）">
              <TextBlock Text="取り消す" VerticalAlignment="Center" />
            </Button>
            <TextBlock IsVisible="{Binding HasUndoNote}" Text="{Binding UndoNote}" FontSize="11.5"
                       Foreground="{StaticResource FaintTextBrush}" TextWrapping="Wrap" TextAlignment="Center" />
            <Button Classes="primaryAction" Command="{Binding ContinueOrganizeCommand}">
              <TextBlock Text="別の整理を続ける" />
            </Button>
          </StackPanel>
        </ScrollViewer>

        <!-- 作業トレイ(完了前)= 3 ゾーン固定(ECO-056/v2 A-1 裁定: マージ先=上部ピン+
             アクション(探す・実行)=下部ピン+内部スクロールは整理対象リストのみ。
             対象が増えてもマージ先と実行ボタンはスクロールアウトしない — 右ペイン共通クロームの実体化)。 -->
        <DockPanel IsVisible="{Binding !OrganizeDone}">

          <!-- PINNED TOP: マージ先(残す1枚) -->
          <StackPanel DockPanel.Dock="Top" Margin="16,14,16,0" Spacing="8">
            <Border Classes="trayBadge dest" HorizontalAlignment="Left">
              <TextBlock Text="マージ先（残す1枚）" />
            </Border>
            <Border Classes="organizeSlot target" IsVisible="{Binding HasMergeTarget}">
              <DockPanel>
                <!-- マージ先の解除(ECO-056/CAD v2 clearDest・A-2 裁定=REQ-067) -->
                <Button DockPanel.Dock="Right" Classes="iconBtn" ToolTip.Tip="マージ先を解除" VerticalAlignment="Top"
                        Command="{Binding ClearMergeTargetCommand}">
                  <PathIcon Data="{StaticResource CloseIcon}" Width="13" Height="13" />
                </Button>
                <Border DockPanel.Dock="Left" Classes="organizeMini" Margin="0,0,10,0">
                  <c:ThumbnailImage SourcePath="{Binding MergeTarget.AbsolutePath}" Stretch="UniformToFill"
                                    IsVisible="{Binding MergeTarget.HasThumb}" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding MergeTarget.Name}" FontSize="13" FontWeight="SemiBold"
                             Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding MergeTarget.SizeLabel}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="{StaticResource CheckIcon}" Width="12" Height="12"
                              Foreground="{StaticResource OrganizeDestBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="この1枚が残ります" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource OrganizeDestBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </StackPanel>
              </DockPanel>
            </Border>
            <Border Classes="trayHint" IsVisible="{Binding ShowMergeTargetPrompt}">
              <TextBlock Text="グリッドで残したい1枚を選ぶとマージ先になります。" />
            </Border>
          </StackPanel>

          <!-- PINNED TOP: 整理対象ヘッダ(件数バッジ+すべて解除) -->
          <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
            <Button DockPanel.Dock="Right" Classes="trayLink" Content="すべて解除"
                    IsVisible="{Binding HasOrganizeTargets}" Command="{Binding ClearOrganizeTargetsCommand}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="trayBadge src">
                <TextBlock Text="{Binding OrganizeTargets.Count, StringFormat='整理対象 {0}'}" />
              </Border>
              <TextBlock Text="宛先へ統合し削除" FontSize="11" Foreground="{StaticResource FaintTextBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </DockPanel>

          <!-- PINNED BOTTOM: 似た画像を探す(折りたたみ)+マージを実行 -->
          <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Margin="16,12,16,14" Spacing="10">
              <Button Classes="searchHead" Command="{Binding ToggleSearchOpenCommand}">
                <DockPanel VerticalAlignment="Center">
                  <PathIcon DockPanel.Dock="Right" Classes="caret" Classes.open="{Binding SearchOpen}"
                            Data="{StaticResource ChevronDownIcon}" Width="15" Height="15"
                            Foreground="{StaticResource FaintTextBrush}" />
                  <StackPanel Orientation="Horizontal" Spacing="9">
                    <PathIcon Data="{StaticResource SearchIcon}" Width="15" Height="15"
                              Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="似た画像を探す" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </DockPanel>
              </Button>
              <Border Classes="searchPanel" IsVisible="{Binding SearchOpen}">
                <StackPanel Spacing="12">
                  <!-- 方式タブ: 順・名称は CAD(v1 から)=「条件検索」「類似画像検索」(51ad8ee の逆順短縮が逸脱) -->
                  <Border Classes="segmented">
                    <Grid ColumnDefinitions="*,*">
                      <Button Grid.Column="0" Classes="segBtnText" HorizontalAlignment="Stretch"
                              Classes.active="{Binding IsCriteriaMethod}" Content="条件検索"
                              Command="{Binding SetSearchMethodCommand}" CommandParameter="criteria" />
                      <Button Grid.Column="1" Classes="segBtnText" HorizontalAlignment="Stretch"
                              Classes.active="{Binding IsSimilarMethod}" Content="類似画像検索"
                              Command="{Binding SetSearchMethodCommand}" CommandParameter="similar" />
                    </Grid>
                  </Border>
                  <!-- 条件: 2 列グリッド+チェック行(ECO-055 意味論=マージ先との属性一致・意匠は v2 モック) -->
                  <StackPanel Spacing="8" IsVisible="{Binding IsCriteriaMethod}">
                    <TextBlock Text="一致を判定する条件" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FaintTextBrush}" />
                    <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto,8,Auto">
                      <Border Grid.Row="0" Grid.Column="0" Classes="condRow" Classes.on="{Binding CondHash}">
                        <CheckBox IsChecked="{Binding CondHash}" Content="ハッシュ値" />
                      </Border>
                      <Border Grid.Row="0" Grid.Column="2" Classes="condRow" Classes.on="{Binding CondExt}">
                        <CheckBox IsChecked="{Binding CondExt}" Content="拡張子" />
                      </Border>
                      <Border Grid.Row="2" Grid.Column="0" Classes="condRow" Classes.on="{Binding CondSize}">
                        <CheckBox IsChecked="{Binding CondSize}" Content="サイズ" />
                      </Border>
                      <Border Grid.Row="2" Grid.Column="2" Classes="condRow" Classes.on="{Binding CondName}">
                        <CheckBox IsChecked="{Binding CondName}" Content="ファイル名" />
                      </Border>
                      <Border Grid.Row="4" Grid.Column="0" Classes="condRow" Classes.on="{Binding CondDate}">
                        <CheckBox IsChecked="{Binding CondDate}" Content="更新日" />
                      </Border>
                    </Grid>
                  </StackPanel>
                  <!-- 類似: しきい値 -->
                  <StackPanel Spacing="4" IsVisible="{Binding IsSimilarMethod}">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Right" Text="{Binding SimilarThresholdLabel, StringFormat='{}{0} 以上'}"
                                 FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                      <TextBlock Text="類似度のしきい値" FontSize="11" FontWeight="SemiBold"
                                 Foreground="{StaticResource FaintTextBrush}" />
                    </DockPanel>
                    <Slider Minimum="50" Maximum="100" Value="{Binding SimilarThreshold}" />
                  </StackPanel>
                  <!-- 探す(文言は CAD v1 から「探す」— 51ad8ee の「似た画像を探す」が逸脱) -->
                  <Button Classes="primaryAction" Height="40" IsEnabled="{Binding CanRunSearch}"
                          Command="{Binding RunSearchCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                      <PathIcon Data="{StaticResource SearchIcon}" Width="14" Height="14" />
                      <TextBlock Text="探す" VerticalAlignment="Center" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Border>

              <!-- タグ統合トグルは ECO-044(IMG-011 裁定②)で撤去 — タグ union は常時 ON -->

              <!-- マージを実行(緑=モック色意味論)+不可時の理由注記 -->
              <Button Classes="primaryAction merge" IsEnabled="{Binding CanExecuteMerge}" Command="{Binding ExecuteMergeCommand}">
                <TextBlock Text="{Binding MergeButtonLabel}" />
              </Button>
              <TextBlock IsVisible="{Binding ShowMergeBlockedNote}" Text="{Binding MergeBlockedNote}"
                         FontSize="11" Foreground="{StaticResource FaintTextBrush}" TextAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- SCROLLABLE: 整理対象リストのみ内部スクロール(3 ゾーンの可変部) -->
          <ScrollViewer Margin="16,0,16,8" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <Border Classes="trayHint" IsVisible="{Binding ShowOrganizeTargetsPrompt}">
                <TextBlock Text="まとめる相手がありません。グリッドで選ぶか、下の検索で探します。" />
              </Border>
              <ItemsControl ItemsSource="{Binding OrganizeTargets}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:OrganizeSlotVM">
                    <Border Classes="organizeSlot" Margin="0,0,0,8">
                      <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                          <Button Classes="iconBtn" ToolTip.Tip="マージ先にする"
                                  Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).PromoteToMergeTargetCommand}"
                                  CommandParameter="{Binding Id}">
                            <PathIcon Data="{StaticResource ArrowUpIcon}" Width="14" Height="14" />
                          </Button>
                          <Button Classes="iconBtn" ToolTip.Tip="対象から外す"
                                  Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).RemoveOrganizeTargetCommand}"
                                  CommandParameter="{Binding Id}">
                            <PathIcon Data="{StaticResource CloseIcon}" Width="13" Height="13" />
                          </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Left" Classes="organizeMini" Margin="0,0,10,0">
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding HasThumb}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                     Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding SizeLabel}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" />
                        </StackPanel>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
        </Panel>
      </DockPanel>
    </Border>

    <!-- ===== 中央: ツールバー + パンくず + チップ + 本体 ===== -->
    <!-- 詰め込みの本格対応は IMG-014(ツールバー狭幅レスポンシブ収納)で実装済み=実測幅による段階収納
         (ラベル畳み→整理を⋯へ退避→WrapPanel 折り返し)。ClipToBounds は最終保険として残す(段階収納で
         吸収しきれない極狭幅でも隣ペインへ描画はみ出しを封じる)。Popup メニューは上位層で非クリップ。 -->
    <DockPanel ClipToBounds="True">

      <!-- ツールバー(IMG-014: 狭幅レスポンシブ収納。x:Name=code-behind が SizeChanged で実測幅を報告) -->
      <Border x:Name="ToolbarRoot" DockPanel.Dock="Top" MinHeight="60" Padding="18,0"
              BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
        <!-- IMG-014 tier3: 2 列×2 行 Grid でモック flex-wrap を再現。広い時=左(row0/col0)+右(row0/col1・右寄せ)、
             狭い時(ToolbarWrapped)=左(row0 全幅)+右(row1 全幅・右寄せ)へ右クラスタを下段へ回り込ませる。
             回り込み判定は code-behind が各クラスタ実測幅の合算 > 使える幅 で行う(重なり原理排除)。 -->
        <Grid VerticalAlignment="Center" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
          <!-- 右クラスタ: ソート + レイアウト -->
          <StackPanel x:Name="RightCluster"
                      Grid.Row="{Binding RightClusterRow}" Grid.Column="{Binding RightClusterColumn}"
                      Grid.ColumnSpan="{Binding RightClusterColumnSpan}"
                      Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
            <!-- ソート(ECO-025 β/FL-003 v2): 対象=アクティブビューの表示列・状態は表示形式間で共有。
                 リスト=列ヘッダー+要約チップ / アイコン=単一「並び替え」メニュー(候補=表示列・昇順/降順) -->
            <!-- 要約チップ(方向矢印 + 列名（方向） + ✕でクリア)。ソート中は list/grid とも表示=アイコンでもクリア可(モック isSorted) -->
            <Border IsVisible="{Binding ShowSortChip}" Background="#EAF1FE" BorderBrush="#CFE0FC" BorderThickness="1"
                    CornerRadius="14" Padding="10,3" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource ArrowUpIcon}" Width="12" Height="12" Foreground="{StaticResource AccentBrush}"
                          RenderTransformOrigin="50%,50%">
                  <PathIcon.RenderTransform><RotateTransform Angle="{Binding ColumnSortArrowAngle}" /></PathIcon.RenderTransform>
                </PathIcon>
                <TextBlock Text="{Binding ColumnSortLabel}" FontSize="12.5" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <Button Command="{Binding ClearColumnSortCommand}" Background="Transparent" Padding="2"
                        ToolTip.Tip="ソートを解除" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource CloseIcon}" Width="11" Height="11" Foreground="{StaticResource TextMutedBrush}" />
                </Button>
              </StackPanel>
            </Border>
            <!-- アイコン: 単一「並び替え」メニュー -->
            <Panel IsVisible="{Binding IsGrid}">
              <Button x:Name="SortTrigger" Classes="toolbarBtn" Command="{Binding ToggleSortMenuCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource SortIcon}" Foreground="{StaticResource FaintTextBrush}" />
                  <TextBlock Text="並び替え" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                  <Border Background="{StaticResource CardSelectedBgBrush}" CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SortButtonBadge}" FontSize="11.5" Foreground="{StaticResource AccentBrush}" />
                  </Border>
                  <PathIcon Data="{StaticResource ChevronDownIcon}" Width="14" Height="14" Foreground="{StaticResource FaintTextBrush}" />
                </StackPanel>
              </Button>
              <Popup PlacementTarget="{Binding #SortTrigger}" Placement="BottomEdgeAlignedRight" VerticalOffset="6"
                     IsOpen="{Binding SortMenuOpen}" IsLightDismissEnabled="True" Closed="OnMenuClosed">
                <Border Classes="popupMenu" Width="248">
                  <StackPanel>
                    <StackPanel Margin="12,10,12,6">
                      <TextBlock Text="並び替え" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                      <TextBlock Text="ビューの表示列から選択" FontSize="11.5" Foreground="{StaticResource FaintTextBrush}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding SortColumns}">
                      <ItemsControl.Styles>
                        <Style Selector="Button.sortOpt.active">
                          <Setter Property="Background" Value="#F3F8FF" />
                        </Style>
                      </ItemsControl.Styles>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SortOptionVM">
                          <Button Classes="menuRow sortOpt" Classes.active="{Binding IsActive}"
                                  Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).SelectColumnSortCommand}"
                                  CommandParameter="{Binding Key}">
                            <DockPanel>
                              <PathIcon DockPanel.Dock="Right" Data="{StaticResource ArrowUpIcon}" Width="13" Height="13"
                                        Foreground="{StaticResource AccentBrush}" IsVisible="{Binding IsActive}"
                                        RenderTransformOrigin="50%,50%" VerticalAlignment="Center">
                                <PathIcon.RenderTransform><RotateTransform Angle="{Binding ArrowAngle}" /></PathIcon.RenderTransform>
                              </PathIcon>
                              <Border DockPanel.Dock="Right" Background="{StaticResource CardSelectedBgBrush}" CornerRadius="4"
                                      Padding="5,1" Margin="6,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding KindChip}" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                              </Border>
                              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="{Binding Color, FallbackValue=Transparent}"
                                         IsVisible="{Binding ShowColorDot}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Label}" FontSize="13.5" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                              </StackPanel>
                            </DockPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Classes="segmented" Margin="12,6,12,10">
                      <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Classes="segBtn" Classes.active="{Binding SortAscActive}" Command="{Binding SetSortAscCommand}">
                          <TextBlock Text="昇順" FontSize="12.5" />
                        </Button>
                        <Button Classes="segBtn" Classes.active="{Binding SortDescActive}" Command="{Binding SetSortDescCommand}">
                          <TextBlock Text="降順" FontSize="12.5" />
                        </Button>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </Popup>
            </Panel>
            <Border Classes="segmented">
              <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Classes="segBtn" Classes.active="{Binding IsGrid}" Command="{Binding SetGridCommand}" ToolTip.Tip="グリッド">
                  <PathIcon Data="{StaticResource GridIcon}" />
                </Button>
                <Button Classes="segBtn" Classes.active="{Binding IsList}" Command="{Binding SetListCommand}" ToolTip.Tip="リスト">
                  <PathIcon Data="{StaticResource ViewListIcon}" />
                </Button>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- 左: 表示軸 + アクション。IMG-014 tier3 で狭幅時(ToolbarWrapped)は row0 全幅を占め、右クラスタが
               row1 へ回り込む。さらに左クラスタ単体でも全幅に入りきらない極狭幅では WrapPanel が内部で折り返し、
               離脱ボタン(◯◯を終了)をクリップせず次行へ送る(契約③=終了ラベル維持)。旧 Spacing="14" は各子の
               Margin="14,0,0,0" で等価再現(通常幅は不変)。回り込み判定用の自然幅は code-behind が子希望幅を合算。 -->
          <WrapPanel x:Name="LeftCluster" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="{Binding LeftClusterColumnSpan}"
                     Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="表示" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FaintTextBrush}"
                         VerticalAlignment="Center" />
              <Panel>
                <Button x:Name="AxisTrigger" Classes="toolbarBtn" Padding="12,0" Command="{Binding ToggleAxisMenuCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                    <Border Classes="axisIcon" Classes.view="{Binding IsViewAxis}">
                      <Panel>
                        <PathIcon Data="{StaticResource FolderIcon}" IsVisible="{Binding !IsViewAxis}" />
                        <PathIcon Data="{StaticResource TagIcon}" IsVisible="{Binding IsViewAxis}" />
                      </Panel>
                    </Border>
                    <TextBlock Text="{Binding AxisLabel}" FontSize="13.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    <PathIcon Data="{StaticResource ChevronDownIcon}" Width="15" Height="15" Foreground="{StaticResource FaintTextBrush}" />
                  </StackPanel>
                </Button>
                <Popup PlacementTarget="{Binding #AxisTrigger}" Placement="BottomEdgeAlignedLeft"
                       VerticalOffset="6" IsOpen="{Binding AxisMenuOpen}" IsLightDismissEnabled="True"
                       Closed="OnMenuClosed">
                  <Border Classes="popupMenu" Width="260" MaxHeight="360">
                    <ScrollViewer>
                      <ItemsControl ItemsSource="{Binding AxisOptions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:AxisOptionVM">
                            <Button Classes="menuRow"
                                    Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).SelectAxisCommand}"
                                    CommandParameter="{Binding Id}">
                              <DockPanel>
                                <PathIcon DockPanel.Dock="Right" Data="{StaticResource CheckIcon}" Width="16" Height="16"
                                          Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                          IsVisible="{Binding IsActive}" />
                                <Border Classes="axisIcon lg" Classes.view="{Binding IsView}">
                                  <Panel>
                                    <PathIcon Data="{StaticResource FolderIcon}" IsVisible="{Binding !IsView}" />
                                    <PathIcon Data="{StaticResource TagIcon}" IsVisible="{Binding IsView}" />
                                  </Panel>
                                </Border>
                                <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding Label}" FontSize="13.5" FontWeight="SemiBold"
                                             Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="{StaticResource FaintTextBrush}" />
                                </StackPanel>
                              </DockPanel>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                </Popup>
              </Panel>
            </StackPanel>

            <!-- 表示列(ECO-025 β-2): アクティブビューの display_columns を編集(ライブ書き戻し=VE-003)。
                 view 軸+ビュー選択時のみ表示(FS 軸は書き戻し先が無い)。さらに CAD 準拠で文脈モード中は隠す
                 (残すのは表示軸・ソート・グリッド/リスト・終了だけ=ShowColumnsEntry・IMG-014)。列ピッカー=ColumnPickerView。 -->
            <Panel IsVisible="{Binding ShowColumnsEntry}" Margin="14,0,0,0">
              <Button x:Name="ColumnsTrigger" Classes="toolbarBtn" Padding="12,0" Command="{Binding ToggleColumnPickerCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource ViewColumnIcon}" Foreground="{StaticResource FaintTextBrush}" />
                  <TextBlock Text="表示列" FontSize="13.5" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                  <PathIcon Data="{StaticResource ChevronDownIcon}" Width="14" Height="14" Foreground="{StaticResource FaintTextBrush}" />
                </StackPanel>
              </Button>
              <Popup PlacementTarget="{Binding #ColumnsTrigger}" Placement="BottomEdgeAlignedLeft" VerticalOffset="6"
                     IsOpen="{Binding ColumnPickerOpen}" IsLightDismissEnabled="True" Closed="OnMenuClosed">
                <Border Classes="popupMenu" Width="304">
                  <views:ColumnPickerView DataContext="{Binding ColumnPicker}" />
                </Border>
              </Popup>
            </Panel>

            <Border Width="1" Height="26" Background="{StaticResource CardBorderBrush}" Margin="14,0,0,0" VerticalAlignment="Center" />

            <!-- モード中(タグ編集/整理/作業)は他モード入口・⋯ を隠し、当該モードの「終了」と
                 表示軸/ソート/レイアウトのみ残す(集中・排他可視化・狭い中央列での被り解消)。ECO-014 §8 / ECO-017 -->
            <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center" Margin="14,0,0,0">
              <!-- 入口ボタン(タグ編集/整理/作業): IMG-014 tier1 でラベルをアイコンのみへ畳む(CollapseEntryLabels)。
                   ToolTip でツールチップは残す。モード中は当該ボタンが「終了」=離脱導線になりラベル維持(契約③)。 -->
              <Button Classes="toolbarBtn" Classes.active="{Binding EditMode}" FontWeight="SemiBold"
                      IsVisible="{Binding ShowEditEntry}" ToolTip.Tip="{Binding EditButtonLabel}" Command="{Binding ToggleEditCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource PencilIcon}" />
                  <TextBlock Text="{Binding EditButtonLabel}" VerticalAlignment="Center" IsVisible="{Binding !CollapseEntryLabels}" />
                </StackPanel>
              </Button>
              <!-- 整理入口: tier2(<約640px)で ⋯ メニューへ退避(ShowOrganizeEntryButton=false)。整理モード中の「整理を終了」は退避しない。 -->
              <Button Classes="toolbarBtn" Classes.active="{Binding OrganizeMode}" FontWeight="SemiBold"
                      IsVisible="{Binding ShowOrganizeEntryButton}" ToolTip.Tip="{Binding OrganizeButtonLabel}" Command="{Binding ToggleOrganizeCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource TuneIcon}" />
                  <TextBlock Text="{Binding OrganizeButtonLabel}" VerticalAlignment="Center" IsVisible="{Binding !CollapseEntryLabels}" />
                </StackPanel>
              </Button>
              <!-- 作業=3つ目の排他文脈モード(ECO-017)。active=緑塗り。作業中は「作業を終了」+「追加」+作業対象チップ。 -->
              <Button Classes="toolbarBtn" Classes.workActive="{Binding WorkMode}" FontWeight="SemiBold"
                      IsVisible="{Binding ShowWorkEntry}" ToolTip.Tip="{Binding WorkButtonLabel}" Command="{Binding ToggleWorkCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource WorkIcon}" />
                  <TextBlock Text="{Binding WorkButtonLabel}" VerticalAlignment="Center" IsVisible="{Binding !CollapseEntryLabels}" />
                </StackPanel>
              </Button>
              <!-- 追加: 選択を作業対象セットへ蓄積(作業モード中のみ・選択あり時のみ活性・件数バッジ) -->
              <Button Classes="workAddBtn" Classes.ready="{Binding CanAddToWork}" IsVisible="{Binding WorkMode}"
                      IsEnabled="{Binding CanAddToWork}" Command="{Binding AddToWorkCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource PlusIcon}" Width="16" Height="16" />
                  <TextBlock Text="追加" VerticalAlignment="Center" />
                  <Border Classes="workAddBadge" IsVisible="{Binding HasWorkSelection}">
                    <TextBlock Text="{Binding WorkSelCount}" />
                  </Border>
                </StackPanel>
              </Button>
              <!-- 作業対象 N 枚 チップ(蓄積件数の確認・セル個別バッジは出さない=描画モック準拠 W2) -->
              <Border Classes="workTargetChip" IsVisible="{Binding HasWorkTargets}">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource CheckIcon}" Width="14" Height="14" />
                  <TextBlock Text="{Binding WorkTargetLabel}" VerticalAlignment="Center" />
                </StackPanel>
              </Border>
              <!-- 削除モード(ECO-018): ⋯メニュー「削除」で入る排他モード。削除を終了 + ゴミ箱へ移動(赤・件数バッジ) -->
              <Button Classes="toolbarBtn" IsVisible="{Binding DeleteMode}" Command="{Binding ExitDeleteCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource CloseIcon}" />
                  <TextBlock Text="削除を終了" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Classes="delMoveBtn" Classes.ready="{Binding CanDeleteToTrash}" IsVisible="{Binding DeleteMode}"
                      IsEnabled="{Binding CanDeleteToTrash}" Command="{Binding DeleteToTrashCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                  <TextBlock Text="ゴミ箱へ移動" VerticalAlignment="Center" />
                  <Border Classes="delMoveBadge" IsVisible="{Binding HasDeleteSelection}">
                    <TextBlock Text="{Binding DeleteSelCount}" />
                  </Border>
                </StackPanel>
              </Button>
              <!-- ⋯ = メンテナンスメニュー(修復/削除/ゴミ箱・ECO-015/018)。モード中は隠す(InAnyMode に作業・削除を含む) -->
              <Panel IsVisible="{Binding !InAnyMode}">
                <Button x:Name="MoreTrigger" Classes="toolbarBtn square" Command="{Binding ToggleMoreMenuCommand}" ToolTip.Tip="その他">
                  <PathIcon Data="{StaticResource MoreIcon}" />
                </Button>
                <Popup PlacementTarget="{Binding #MoreTrigger}" Placement="BottomEdgeAlignedRight"
                       VerticalOffset="6" IsOpen="{Binding MoreMenuOpen}" IsLightDismissEnabled="True" Closed="OnMenuClosed">
                  <Border Classes="popupMenu" Width="200">
                    <StackPanel>
                      <!-- 整理(IMG-014 tier2 退避): 実測幅 <約640px で「整理」入口をここへ移す。ラベル維持。通常幅では非表示 -->
                      <Button Classes="menuRow" IsVisible="{Binding StowOrganizeToMenu}" Command="{Binding ToggleOrganizeCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                          <PathIcon Data="{StaticResource TuneIcon}" Width="16" Height="16" Foreground="{StaticResource FaintTextBrush}" />
                          <TextBlock Text="整理" FontSize="13.5" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                      </Button>
                      <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="8,4" IsVisible="{Binding StowOrganizeToMenu}" />
                      <!-- 修復: 既存モーダル(ECO-015・変更なし) -->
                      <Button Classes="menuRow" Command="{Binding OpenRepairCommand}" IsEnabled="{Binding CanOpenMaintenance}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                          <PathIcon Data="{StaticResource RepairIcon}" Width="16" Height="16" Foreground="{StaticResource FaintTextBrush}" />
                          <TextBlock Text="修復" FontSize="13.5" Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                      </Button>
                      <!-- 削除: 削除モードに入る(ECO-018・赤) -->
                      <Button Classes="menuRow" Command="{Binding EnterDeleteCommand}" IsEnabled="{Binding CanOpenMaintenance}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                          <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" Foreground="#C4282D" />
                          <TextBlock Text="削除" FontSize="13.5" FontWeight="SemiBold" Foreground="#C4282D" />
                        </StackPanel>
                      </Button>
                      <!-- ゴミ箱: 既存トラッシュモーダル(ECO-015・改名)+ deleted 件数バッジ -->
                      <Button Classes="menuRow" Command="{Binding Trash.OpenTrashCommand}" IsEnabled="{Binding CanOpenMaintenance}">
                        <DockPanel VerticalAlignment="Center">
                          <PathIcon DockPanel.Dock="Left" Data="{StaticResource TrashIcon}" Width="16" Height="16" Margin="0,0,10,0" Foreground="{StaticResource FaintTextBrush}" />
                          <Border DockPanel.Dock="Right" Classes="trashCountBadge" IsVisible="{Binding Trash.HasTrash}">
                            <TextBlock Text="{Binding Trash.TrashCount}" />
                          </Border>
                          <TextBlock Text="ゴミ箱" FontSize="13.5" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                        </DockPanel>
                      </Button>
                    </StackPanel>
                  </Border>
                </Popup>
              </Panel>
            </StackPanel>
          </WrapPanel>
        </Grid>
      </Border>

      <!-- パンくず -->
      <Border DockPanel.Dock="Top" Classes="breadcrumbBar">
        <DockPanel VerticalAlignment="Center">
          <TextBlock DockPanel.Dock="Right" Classes="crumbCount" Text="{Binding CountLabel}" />
          <StackPanel Orientation="Horizontal" Spacing="3">
            <Button Classes="crumbHome" Classes.active="{Binding HomeActive}" Command="{Binding GoHomeCommand}">
              <PathIcon Data="{StaticResource HomeIcon}" />
            </Button>
            <ItemsControl ItemsSource="{Binding Crumbs}">
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:CrumbVM">
                  <StackPanel Orientation="Horizontal" Spacing="3">
                    <PathIcon Classes="crumbSep" Data="{StaticResource ChevronRightIcon}" VerticalAlignment="Center" />
                    <Button Classes="crumb" Classes.last="{Binding IsLast}" Content="{Binding Name}"
                            Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).GoCrumbCommand}"
                            CommandParameter="{Binding Depth}" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- チップ行(絞り込み/ナビ) -->
      <Border DockPanel.Dock="Top" IsVisible="{Binding ShowChips}" Background="{StaticResource AppBackgroundBrush}"
              BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="18,11">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Classes="chipHint" Text="{Binding ChipHintLabel}" IsVisible="{Binding ShowChipHint}" />
          <ItemsControl ItemsSource="{Binding Chips}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ChipVM">
                <Border Classes="tagChip" Background="{Binding Background}" BorderBrush="{Binding BorderBrush}"
                        Margin="0,0,8,0" PointerPressed="OnChipPressed">
                  <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="{Binding DotBrush}" IsVisible="{Binding HasDot}" VerticalAlignment="Center" />
                    <TextBlock Classes="chipLabel" Text="{Binding Label}" Foreground="{Binding LabelBrush}" />
                    <Border Classes="chipCount" Background="{Binding CountBackground}" IsVisible="{Binding HasCount}">
                      <TextBlock Text="{Binding Count}" Foreground="{Binding CountForeground}" />
                    </Border>
                    <PathIcon Classes="chipNav" Data="{StaticResource ChevronRightIcon}" IsVisible="{Binding IsNav}"
                              Foreground="{Binding LabelBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- 空タグ注記 -->
      <Border DockPanel.Dock="Top" Classes="noteBar" IsVisible="{Binding ShowEmptyTagNote}"
              Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <PathIcon Data="{StaticResource InfoIcon}" />
          <TextBlock Text="このフォルダにはタグ付き画像がありません" />
        </StackPanel>
      </Border>

      <!-- 本体: グリッド or リスト(コレクション未選択時はプロンプト=REQ-053) -->
      <Panel>
        <!-- 未選択プロンプト(REQ-053): コレクションを選ぶまで横断表示しない -->
        <StackPanel IsVisible="{Binding ShowCollectionPrompt}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
          <PathIcon Data="{StaticResource FolderIcon}" Width="44" Height="44" Foreground="{StaticResource FaintTextBrush}" HorizontalAlignment="Center" />
          <TextBlock Text="左のコレクションを選択してください" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- 画像 0 件の空状態(コレクション選択済み) -->
        <StackPanel IsVisible="{Binding ShowEmptyMessage}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
          <PathIcon Data="{StaticResource ImageIcon}" Width="40" Height="40" Foreground="{StaticResource FaintTextBrush}" HorizontalAlignment="Center" />
          <TextBlock Text="画像がありません" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- グリッド(ECO-026/#1: REQ-041/KBOM 適合の仮想化。旧 ItemsControl+WrapPanel=非仮想化 → ItemsRepeater+
             UniformGridLayout で画面外セル/サムネを実体化しない。ビューア scroll で是正した FMEA-013 の罠と同型。
             ItemsRepeater/UniformGridLayout は別 NuGet Avalonia.Controls.ItemsRepeater(12.0.0)。
             MinItemHeight=206 はソート項目タイル込みの最大セル高でクリップ回避(無ソート時は下方に僅かな余白)。
             選択はコード側 PointerPressed(OnItemPressed)維持=セル DataTemplate は不変・視覚は maintainer 実機 golden 再確認)。 -->
        <ScrollViewer IsVisible="{Binding ShowBrowseGrid}">
          <ItemsRepeater ItemsSource="{Binding Items}" Margin="11">
            <ItemsRepeater.Layout>
              <UniformGridLayout MinItemWidth="164" MinItemHeight="206" MinColumnSpacing="0" MinRowSpacing="0" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="vm:ImageItemVM">
                <Border Classes="thumbCellWrap" Width="164" Padding="7" PointerPressed="OnItemPressed">
                 <StackPanel Width="150">
                  <Border Classes="thumbCell" Classes.selected="{Binding IsSelected}"
                          Classes.mergeTarget="{Binding IsMergeTarget}"
                          Classes.organizeTarget="{Binding IsOrganizeTarget}" Height="150">
                    <Panel>
                      <Border Background="{Binding ThumbBrush}" IsVisible="{Binding HasThumb}" />
                      <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill"
                                        IsVisible="{Binding HasRealThumb}" />
                      <PathIcon Data="{StaticResource FolderIcon}" Width="46" Height="46" Foreground="#9AA6F0"
                                IsVisible="{Binding IsFolder}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <PathIcon Data="{StaticResource ImageIcon}" Width="38" Height="38" Foreground="#C6CDD8"
                                IsVisible="{Binding IsPlaceholder}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <!-- 選択順バッジ(REQ-041 CR-3): 選択時は連番順の番号・未選択(編集中)は空枠 -->
                      <Border Classes="thumbCheck" Classes.selected="{Binding IsSelected}" IsVisible="{Binding Selectable}">
                        <TextBlock Text="{Binding SelectionOrderText}" IsVisible="{Binding IsSelected}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <!-- 整理モード(ECO-056/v2 モック): 宛先も対象も 左上チェック+右上バッジ の同型
                           (宛先=緑/対象=青。v1 実装の「ラベル/チェック排他」は 51ad8ee の CAD 逸脱) -->
                      <Border Classes="thumbCheck selected dest" IsVisible="{Binding IsMergeTarget}">
                        <PathIcon Data="{StaticResource CheckIcon}" />
                      </Border>
                      <Border Classes="cellTag dest" IsVisible="{Binding IsMergeTarget}">
                        <TextBlock Text="宛先" />
                      </Border>
                      <Border Classes="thumbCheck selected" IsVisible="{Binding IsOrganizeTarget}">
                        <PathIcon Data="{StaticResource CheckIcon}" />
                      </Border>
                      <Border Classes="cellTag" IsVisible="{Binding IsOrganizeTarget}">
                        <TextBlock Text="対象" />
                      </Border>
                      <ItemsControl ItemsSource="{Binding TagDots}" IsVisible="{Binding HasTagDots}"
                                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="7">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="media:IBrush">
                            <Ellipse Width="8" Height="8" Fill="{Binding}" Stroke="White" StrokeThickness="1.5" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Panel>
                  </Border>
                  <TextBlock Classes="thumbName" Text="{Binding Name}" HorizontalAlignment="Center" />
                  <!-- ソート項目(ECO-025 β/FL-003 v2): ソート中かつ名前以外のとき、タイルに 列名+値 を型別表示 -->
                  <StackPanel IsVisible="{Binding ShowSortItem}" Orientation="Horizontal" Spacing="4"
                              HorizontalAlignment="Center" Margin="0,1,0,0">
                    <TextBlock Text="{Binding SortItemLabel}" FontSize="10.5" VerticalAlignment="Center"
                               Foreground="{StaticResource FaintTextBrush}" />
                    <TextBlock Text="{Binding SortItemCell.Text}" FontSize="10.5" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" IsVisible="{Binding SortItemCell.IsBasic}" />
                    <StackPanel Orientation="Horizontal" Spacing="2" IsVisible="{Binding SortItemCell.IsNum}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding SortItemCell.StarsText}" FontSize="10.5" IsVisible="{Binding SortItemCell.HasValue}"
                                 Foreground="{Binding SortItemCell.Color, FallbackValue=Gray}" />
                      <TextBlock Text="{Binding SortItemCell.Text}" FontSize="10.5" IsVisible="{Binding SortItemCell.HasValue}"
                                 Foreground="{Binding SortItemCell.Color, FallbackValue=Gray}" />
                      <TextBlock Text="未設定" FontSize="10.5" Foreground="{StaticResource FaintTextBrush}" IsVisible="{Binding SortItemCell.IsEmpty}" />
                    </StackPanel>
                    <Panel IsVisible="{Binding SortItemCell.IsTextCell}" VerticalAlignment="Center">
                      <TextBlock Text="{Binding SortItemCell.Text}" FontSize="10.5" IsVisible="{Binding SortItemCell.HasValue}"
                                 Foreground="{Binding SortItemCell.Color, FallbackValue=Gray}" />
                      <TextBlock Text="—" FontSize="10.5" Foreground="{StaticResource FaintTextBrush}" IsVisible="{Binding SortItemCell.IsEmpty}" />
                    </Panel>
                    <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding SortItemCell.IsSimple}" VerticalAlignment="Center">
                      <Ellipse Width="8" Height="8" Fill="{Binding SortItemCell.Color, FallbackValue=Transparent}"
                               IsVisible="{Binding SortItemCell.HasValue}" VerticalAlignment="Center" />
                      <TextBlock Text="あり" FontSize="10.5" Foreground="{StaticResource TextMutedBrush}" IsVisible="{Binding SortItemCell.HasValue}" />
                      <TextBlock Text="なし" FontSize="10.5" Foreground="{StaticResource FaintTextBrush}" IsVisible="{Binding SortItemCell.IsEmpty}" />
                    </StackPanel>
                  </StackPanel>
                 </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </ScrollViewer>

        <!-- リスト(ECO-025 β: アクティブビューの display_columns を動的列テーブルで描画+列ヘッダーソート)
             workspace型 layoutInvariant: ヘッダー行はクロム固定(ScrollViewer 外=sticky)・行だけがスクロール。
             名前=伸縮(1.7*)・他=固定幅。ヘッダーと各行が同一 ColumnTemplate を Grid に束ね列位置を一致させる。 -->
        <DockPanel IsVisible="{Binding ShowBrowseList}">
          <DockPanel.Styles>
            <Style Selector="Button.listHeaderBtn">
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="Padding" Value="6,2" />
              <Setter Property="HorizontalAlignment" Value="Stretch" />
              <Setter Property="HorizontalContentAlignment" Value="Left" />
              <Setter Property="Cursor" Value="Hand" />
              <Setter Property="CornerRadius" Value="4" />
            </Style>
            <!-- クリック可能と分かるようホバーで淡い背景(列ヘッダー=ソートトグル) -->
            <Style Selector="Button.listHeaderBtn:pointerover /template/ ContentPresenter">
              <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
            </Style>
            <Style Selector="Button.listHeaderBtn.active">
              <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
          </DockPanel.Styles>

          <!-- ソート概要は v2 でツールバーの要約チップへ移行(FL-003)。リストはヘッダー+チップが導線 -->
          <!-- ヘッダー行(クロム固定・sticky) -->
          <Border DockPanel.Dock="Top" Classes="imageListHeader">
            <DockPanel VerticalAlignment="Center">
              <Border DockPanel.Dock="Left" Width="44" />
              <ItemsControl ItemsSource="{Binding ListColumns}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Grid cv:GridColumnsBinder.Template="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).ColumnTemplate}" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter" x:DataType="vm:ListColumnHeaderVM">
                    <Setter Property="Grid.Column" Value="{Binding ColumnIndex}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ListColumnHeaderVM">
                    <Button Classes="listHeaderBtn" Classes.active="{Binding IsSortActive}"
                            Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).SelectColumnSortCommand}"
                            CommandParameter="{Binding Key}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                        <!-- アクティブ列: 方向矢印(降順で180°) -->
                        <TextBlock Text="▲" FontSize="9" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}"
                                   IsVisible="{Binding IsSortActive}">
                          <TextBlock.RenderTransform>
                            <RotateTransform Angle="{Binding ArrowAngle}" />
                          </TextBlock.RenderTransform>
                        </TextBlock>
                        <!-- 非アクティブ列: 薄い ⇅(この列でソートできると示す) -->
                        <TextBlock Text="⇅" FontSize="10" VerticalAlignment="Center"
                                   Foreground="{StaticResource FaintTextBrush}"
                                   IsVisible="{Binding !IsSortActive}" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </DockPanel>
          </Border>

          <!-- 行(スクロール) -->
          <ScrollViewer>
            <!-- 仮想化(REQ-041/055・ECO-025 β perf): リスト行は 入れ子 ItemsControl+Grid+型別セル で重い。
                 VirtualizingStackPanel で可視行のみ実体化し、大量件数でも Recompute/ソートを軽くする。 -->
            <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ImageItemVM">
                  <Border Classes="imageListRow" Classes.selected="{Binding IsSelected}" PointerPressed="OnItemPressed">
                    <DockPanel VerticalAlignment="Center">
                      <Border DockPanel.Dock="Left" Classes="imageListMini" Width="32" Margin="0,0,12,0">
                        <Panel>
                          <Border Background="{Binding ThumbBrush}" IsVisible="{Binding HasThumb}" />
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill"
                                            IsVisible="{Binding HasRealThumb}" />
                          <PathIcon Data="{StaticResource FolderIcon}" Width="18" Height="18" Foreground="#9AA6F0"
                                    IsVisible="{Binding IsFolder}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                          <PathIcon Data="{StaticResource ImageIcon}" Width="16" Height="16" Foreground="#C6CDD8"
                                    IsVisible="{Binding IsPlaceholder}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Panel>
                      </Border>
                      <!-- 型別セル(Grid=ColumnTemplate で列位置一致) -->
                      <ItemsControl ItemsSource="{Binding Cells}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <Grid cv:GridColumnsBinder.Template="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).ColumnTemplate}" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.Styles>
                          <Style Selector="ContentPresenter" x:DataType="vm:ListCell">
                            <Setter Property="Grid.Column" Value="{Binding ColumnIndex}" />
                          </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ListCell">
                            <Panel Margin="6,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                              <!-- basic(名前/サイズ/更新日) -->
                              <TextBlock IsVisible="{Binding IsBasic}" Text="{Binding Text}"
                                         Classes="listMeta" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                              <!-- num(★+値・金色) / 未設定 -->
                              <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding IsNum}" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StarsText}" Foreground="{Binding Color, FallbackValue=Gray}"
                                           IsVisible="{Binding HasValue}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Text}" Foreground="{Binding Color, FallbackValue=Gray}"
                                           IsVisible="{Binding HasValue}" VerticalAlignment="Center" />
                                <TextBlock Text="未設定" Foreground="{StaticResource FaintTextBrush}"
                                           IsVisible="{Binding IsEmpty}" VerticalAlignment="Center" />
                              </StackPanel>
                              <!-- text(値チップ) / — -->
                              <Panel IsVisible="{Binding IsTextCell}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Border IsVisible="{Binding HasValue}" BorderBrush="{Binding Color, FallbackValue=Gray}"
                                        BorderThickness="1" CornerRadius="4" Padding="6,1">
                                  <TextBlock Text="{Binding Text}" Foreground="{Binding Color, FallbackValue=Gray}" FontSize="12" />
                                </Border>
                                <TextBlock Text="—" Foreground="{StaticResource FaintTextBrush}" IsVisible="{Binding IsEmpty}" />
                              </Panel>
                              <!-- simple(色ドット+ラベル) / オフ -->
                              <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsSimple}" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="{Binding Color, FallbackValue=Transparent}"
                                         IsVisible="{Binding HasValue}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Text}" IsVisible="{Binding HasValue}" VerticalAlignment="Center" />
                                <TextBlock Text="—" Foreground="{StaticResource FaintTextBrush}"
                                           IsVisible="{Binding IsEmpty}" VerticalAlignment="Center" />
                              </StackPanel>
                            </Panel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>

        <!-- 整理: 検索結果(中央ペイン全面・候補+一致率)。ECO-014。
             ECO-056: ヘッダ(グリッドへ+件数+方式)を追加 — 「グリッドへ」は CAD v1 backToGrid の実装欠落是正 -->
        <DockPanel IsVisible="{Binding ShowSearchResults}" Background="{StaticResource AppBackgroundBrush}">
          <Border DockPanel.Dock="Top" Height="48" Padding="18,0" Background="{StaticResource PanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
              <TextBlock DockPanel.Dock="Right" Text="{Binding SearchMethodLabel}" FontSize="12"
                         Foreground="{StaticResource FaintTextBrush}" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Classes="toolbarBtn" Height="32" MinHeight="32" Padding="8,0,11,0"
                        Command="{Binding BackToGridCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource ChevronLeftIcon}" Width="14" Height="14"
                              Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="グリッドへ" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
                <TextBlock Text="検索結果" FontSize="13.5" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SearchResultsSubLabel}" FontSize="12.5"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
              </StackPanel>
            </DockPanel>
          </Border>
          <ScrollViewer>
          <StackPanel Margin="18,14">
            <StackPanel IsVisible="{Binding NoSearchResults}" HorizontalAlignment="Center" Spacing="10" Margin="0,40">
              <PathIcon Data="{StaticResource SearchIcon}" Width="34" Height="34" Foreground="{StaticResource FaintTextBrush}" HorizontalAlignment="Center" />
              <TextBlock Text="候補が見つかりませんでした" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding SearchResults}">
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:OrganizeResultVM">
                  <Border Classes="resultCard" Classes.added="{Binding Added}" Width="184" Margin="0,0,12,12">
                    <StackPanel>
                      <Border Height="150">
                        <Panel>
                          <Border Background="{StaticResource ValueChipBg}" />
                          <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding HasThumb}" />
                          <Border Classes="matchBadge"><TextBlock Text="{Binding ScoreText}" /></Border>
                        </Panel>
                      </Border>
                      <DockPanel Margin="10,8,10,10">
                        <Button DockPanel.Dock="Right" Classes="toolbarBtn" Height="30" MinHeight="30" Padding="9,0"
                                IsVisible="{Binding !Added}"
                                Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).AddCandidateToTargetsCommand}"
                                CommandParameter="{Binding Id}">
                          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource PlusIcon}" Width="13" Height="13" />
                            <TextBlock Text="追加" VerticalAlignment="Center" />
                          </StackPanel>
                        </Button>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" IsVisible="{Binding Added}">
                          <PathIcon Data="{StaticResource CheckIcon}" Width="13" Height="13" Foreground="{StaticResource AccentBrush}" />
                          <TextBlock Text="追加済" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                      </DockPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Panel>
    </DockPanel>
  </DockPanel>

    <!-- ===== ゴミ箱ポップアップ(ECO-019): 画像タブ内 中央オーバーレイ ===== -->
    <Border IsVisible="{Binding Trash.TrashOpen}" Background="#57142C2C">
      <Border Classes="trashPopup" Width="780" MaxWidth="780" Height="560" MaxHeight="560"
              HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
        <DockPanel LastChildFill="True">

          <!-- header -->
          <Border DockPanel.Dock="Top" Classes="trashPopupHeader">
            <DockPanel VerticalAlignment="Center">
              <Button DockPanel.Dock="Right" Classes="iconBtn" Command="{Binding Trash.CloseTrashCommand}" ToolTip.Tip="閉じる">
                <PathIcon Data="{StaticResource CloseIcon}" />
              </Button>
              <Button DockPanel.Dock="Right" Classes="toolbarBtn" Height="32" MinHeight="32" Padding="11,0" Margin="0,0,8,0"
                      IsVisible="{Binding Trash.HasTrashItems}" Command="{Binding Trash.ToggleTrashSelectAllCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <PathIcon Data="{StaticResource CheckIcon}" Width="14" Height="14" />
                  <TextBlock Text="{Binding Trash.TrashSelectAllLabel}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource TrashIcon}" Width="18" Height="18" Foreground="{StaticResource FaintTextBrush}" />
                <TextBlock Text="ゴミ箱" FontSize="15.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="削除済み画像" FontSize="12" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                <Border Classes="trashCountBadge" IsVisible="{Binding Trash.HasTrashItems}">
                  <TextBlock Text="{Binding Trash.TrashPopupCount}" />
                </Border>
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- footer action bar(項目がある時のみ) -->
          <Border DockPanel.Dock="Bottom" Classes="trashPopupFooter" IsVisible="{Binding Trash.HasTrashItems}">
            <DockPanel VerticalAlignment="Center">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                <Button Classes="trashRestoreBtn" Classes.ready="{Binding Trash.CanRestoreTrash}"
                        IsEnabled="{Binding Trash.CanRestoreTrash}" Command="{Binding Trash.RestoreSelectedTrashCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource RestoreIcon}" Width="16" Height="16" />
                    <TextBlock Text="復元" VerticalAlignment="Center" />
                    <Border Classes="trashRestoreBadge" IsVisible="{Binding Trash.HasTrashSel}"><TextBlock Text="{Binding Trash.TrashSelCount}" /></Border>
                  </StackPanel>
                </Button>
                <Button Classes="delMoveBtn" Classes.ready="{Binding Trash.CanPurgeTrash}"
                        IsEnabled="{Binding Trash.CanPurgeTrash}" Command="{Binding Trash.PurgeSelectedTrashCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource TrashIcon}" Width="16" Height="16" />
                    <TextBlock Text="完全削除" VerticalAlignment="Center" />
                    <Border Classes="delMoveBadge" IsVisible="{Binding Trash.HasTrashSel}"><TextBlock Text="{Binding Trash.TrashSelCount}" /></Border>
                  </StackPanel>
                </Button>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{Binding Trash.TrashSelCountLabel}" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                <Button Classes="trashEmptyBtn" Command="{Binding Trash.EmptyTrashCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource TrashIcon}" Width="15" Height="15" />
                    <TextBlock Text="ゴミ箱を空にする" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </DockPanel>
          </Border>

          <!-- body: グリッド or 空状態 -->
          <Panel>
            <ScrollViewer IsVisible="{Binding Trash.HasTrashItems}" Padding="18" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding Trash.TrashPopupItems}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:TrashPopupItemVM">
                    <Button Classes="trashCard"
                            Command="{Binding $parent[UserControl].((vm:ImageTabViewModel)DataContext).Trash.ToggleTrashItemCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Width="150" Margin="6">
                        <Border Classes="trashThumb" Classes.selected="{Binding IsSelected}">
                          <Panel>
                            <Border Background="{StaticResource ValueChipBg}" />
                            <c:ThumbnailImage SourcePath="{Binding AbsolutePath}" Stretch="UniformToFill" IsVisible="{Binding HasThumb}" />
                            <Border Classes="trashCheck" Classes.selected="{Binding IsSelected}">
                              <PathIcon Data="{StaticResource CheckIcon}" Width="13" Height="13" Foreground="White" IsVisible="{Binding IsSelected}" />
                            </Border>
                          </Panel>
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="12" Margin="2,7,2,0" TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding SizeLabel}" FontSize="11" Margin="2,1,2,0" Foreground="{StaticResource TextMutedBrush}" />
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <StackPanel IsVisible="{Binding Trash.TrashPopupEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="13">
              <Border Width="58" Height="58" CornerRadius="15" Background="{StaticResource PanelBrush}" HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource TrashIcon}" Width="26" Height="26" Foreground="{StaticResource TextMutedBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel Spacing="2">
                <TextBlock Text="ゴミ箱は空です。" FontSize="13.5" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="削除した画像はここに移動します。" FontSize="13.5" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Panel>

        </DockPanel>
      </Border>
    </Border>

  </Panel>
</UserControl>
