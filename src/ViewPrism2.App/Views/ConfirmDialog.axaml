<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ViewPrism2.App.Views.ConfirmDialog"
        Width="420" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
  <!-- 汎用確認ダイアログ(REQ-010 削除確認 / REQ-017 再リンク確認等)。文言はコードビハインドで注入 -->
  <StackPanel Margin="16" Spacing="16">
    <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
      <Button x:Name="NoButton" MinWidth="80" Click="OnNoClick" />
      <Button x:Name="YesButton" MinWidth="80" Click="OnYesClick" />
    </StackPanel>
  </StackPanel>
</Window>
