<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- ECO-009: タグタブ デザイン言語移植 — 再利用コンポーネント層(モック CAD 準拠)。
       Card / 型チップ / 候補値チップ / 範囲ピル / CTA / アイコンボタン / バッジ / 凡例。
       色は E-DESIGN-028 トークン(App.axaml)を参照。 -->

  <!-- 行内アイコン geometry は App.axaml Application.Resources に定義(グローバル参照)。 -->

  <!-- ============ グローバル基底(ECO-009: 全コントロールへ意図継承=統一の手触り) ============ -->
  <!-- 角丸を統一(既定の角ばった Fluent から、モックの柔らかい角丸へ)。class 指定(cta/iconBtn 等)は各々の値で上書き。 -->
  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="9" />
  </Style>
  <Style Selector="TextBox">
    <Setter Property="CornerRadius" Value="9" />
  </Style>
  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="9" />
  </Style>
  <!-- フォーカス時の TextBox 枠をアクセント青に(意図的な状態表現) -->
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
  </Style>

  <!-- ============ ナビ/ビューカード行(左ペイン ビュー管理) ============ -->
  <Style Selector="Border.navCard">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="Padding" Value="8,0,6,0" />
    <Setter Property="MinHeight" Value="46" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>
  <Style Selector="Border.navCard:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <Style Selector="Border.navCard.selected">
    <Setter Property="BorderBrush" Value="{StaticResource CardSelectedBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
  </Style>
  <!-- 先頭アイコン(30px 角丸・非選択=淡灰/微弱、選択=淡青/アクセント) -->
  <Style Selector="Border.leadIcon">
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.leadIcon PathIcon">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.navCard.selected Border.leadIcon">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.navCard.selected Border.leadIcon PathIcon">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Border.navCard.selected Border.countBadge">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.navCard.selected Border.countBadge TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ChipTextFg}" />
  </Style>

  <!-- ============ Card ============ -->
  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="11,10" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>
  <Style Selector="Border.card:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <Style Selector="Border.card.selected">
    <Setter Property="BorderBrush" Value="{StaticResource CardSelectedBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
    <Setter Property="BoxShadow" Value="0 1 3 0 #1F2F6BED" />
  </Style>

  <!-- ============ 型チップ ============ -->
  <Style Selector="Border.typeChip">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.typeChip.simple">
    <Setter Property="Background" Value="{StaticResource ChipSimpleBg}" />
  </Style>
  <Style Selector="Border.typeChip.text">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.typeChip.number">
    <Setter Property="Background" Value="{StaticResource ChipNumBg}" />
  </Style>
  <Style Selector="Border.typeChip TextBlock">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Border.typeChip.simple TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ChipSimpleFg}" />
  </Style>
  <Style Selector="Border.typeChip.text TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ChipTextFg}" />
  </Style>
  <Style Selector="Border.typeChip.number TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ChipNumFg}" />
  </Style>

  <!-- ============ 候補値チップ / 範囲ピル ============ -->
  <Style Selector="Border.valueChip">
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
    <Setter Property="BorderBrush" Value="{StaticResource ValueChipBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,2" />
  </Style>
  <Style Selector="Border.valueChip TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="Foreground" Value="{StaticResource ValueChipFg}" />
  </Style>
  <Style Selector="Border.rangePill">
    <Setter Property="Background" Value="{StaticResource RangePillBg}" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="9,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.rangePill TextBlock">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource RangePillFg}" />
  </Style>

  <!-- ============ バッジ(件数) ============ -->
  <Style Selector="Border.countBadge">
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.countBadge TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource BadgeFg}" />
  </Style>

  <!-- ============ CTA ボタン(青グラデ) ============ -->
  <Style Selector="Button.cta">
    <Setter Property="Background" Value="{StaticResource CtaBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="Height" Value="40" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.cta /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource CtaBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>
  <Style Selector="Button.cta:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource CtaHoverBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>
  <Style Selector="Button.cta:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource CtaHoverBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- ============ アイコンボタン(行内 編集/削除) ============ -->
  <Style Selector="Button.iconBtn">
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <!-- ECO-009 golden: アイコンの視認性を上げる(淡色すぎを是正。選択/ホバー行でも読める) -->
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.iconBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource IconBtnHoverBg}" />
  </Style>
  <Style Selector="Button.iconBtn:pointerover">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.iconBtn.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource DangerHoverBg}" />
  </Style>
  <Style Selector="Button.iconBtn.danger:pointerover">
    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
  </Style>
  <Style Selector="Button.iconBtn PathIcon">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
  </Style>
  <!-- ホーム設定中のアイコンボタンはアクセント色(GF-03) -->
  <Style Selector="Button.iconBtn.homeOn PathIcon">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>

  <!-- ============ コンテナカード/カードヘッダ(中央 階層構造) ============ -->
  <Style Selector="Border.containerCard">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>
  <Style Selector="Border.cardHeader">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="MinHeight" Value="52" />
  </Style>
  <!-- アクセント pill(N タグ 等) -->
  <Style Selector="Border.accentPill">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.accentPill TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource ChipTextFg}" />
  </Style>
  <!-- HOME ピル(amber) -->
  <Style Selector="Border.homePill">
    <Setter Property="Background" Value="{StaticResource RangePillBg}" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="7,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.homePill TextBlock">
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource RangePillFg}" />
  </Style>

  <!-- ============ 条件チップ(配置タグ条件。既定=緑/amber=数値/mono=regex) ============ -->
  <Style Selector="Border.condChip">
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="{StaticResource ChipNumBg}" />
  </Style>
  <Style Selector="Border.condChip.amber">
    <Setter Property="Background" Value="{StaticResource RangePillBg}" />
  </Style>
  <Style Selector="Border.condChip.mono">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.condChip TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource ChipNumFg}" />
  </Style>
  <Style Selector="Border.condChip.amber TextBlock">
    <Setter Property="Foreground" Value="{StaticResource RangePillFg}" />
  </Style>
  <Style Selector="Border.condChip.mono TextBlock">
    <Setter Property="Foreground" Value="{StaticResource ChipTextFg}" />
    <Setter Property="FontFamily" Value="Consolas, monospace" />
  </Style>
  <Style Selector="Border.condChip PathIcon">
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource ChipNumFg}" />
  </Style>
  <Style Selector="Border.condChip.amber PathIcon">
    <Setter Property="Foreground" Value="{StaticResource RangePillFg}" />
  </Style>
  <Style Selector="Border.condChip.mono PathIcon">
    <Setter Property="Foreground" Value="{StaticResource ChipTextFg}" />
  </Style>

  <!-- ============ TreeView 行 選択/ホバー(ECO-009 ③ golden) ============ -->
  <!-- Fluent 既定の濃い選択バー → モックの淡青(選択)/淡灰(ホバー)。アイコン・名前が読める。 -->
  <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="0,1" />
  </Style>
  <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
  </Style>
  <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
  </Style>
  <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{StaticResource CardSelectedBgBrush}" />
  </Style>
  <!-- ノード名は明示色(淡青選択上でも読めるよう、継承の選択前景に左右されない)。home はアクセント。 -->
  <Style Selector="TextBlock.nodeName">
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>

  <!-- =================================================================== -->
  <!-- 画像タブ 部品層(M1: design-system-bom.md DS1/DS2・golden 基準=モック)    -->
  <!--   new 6   : 軸セレクタ/ソート/パンくず/グリッドカード/リスト行/パネルタブ  -->
  <!--   extend 7: rail/ツールバーボタン/タグチップ/空注記/編集パネル/タグ追加行/数値-->
  <!-- 色は E-DESIGN-028 トークンへ写像(ハイブリッド: 新規は view軸 amber=ViewAxis* のみ)。-->
  <!-- ★タグ色依存の塗り(チップ active・候補値選択・数値セル選択)は static 不可のため        -->
  <!--   surface で Background/BorderBrush/Foreground をタグ色からバインドする。本層は           -->
  <!--   レイアウトと「静的状態」の視覚のみを規定する。                                          -->
  <!-- =================================================================== -->

  <!-- ============ extend: ツールバー セカンダリボタン(整理/作業/軸トリガ/ソートトリガ) ====
       TMP-UI-CMP-0022。白面+細枠、hover で枠濃・面パネル。.active=青枠青字淡青面(編集トグル)。 -->
  <Style Selector="Button.toolbarBtn">
    <Setter Property="Height" Value="40" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="13,0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{StaticResource ChipSimpleFg}" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.toolbarBtn /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
  </Style>
  <Style Selector="Button.toolbarBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
  </Style>
  <Style Selector="Button.toolbarBtn:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <Style Selector="Button.toolbarBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
  </Style>
  <Style Selector="Button.toolbarBtn PathIcon">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
  </Style>
  <!-- アクティブトグル(タグ編集 ON 等。border #2f6bed / 字 #2f6bed / 面 #eaf1fe) -->
  <Style Selector="Button.toolbarBtn.active">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Button.toolbarBtn.active /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <!-- アイコンのみ(⋯メニュー等)の正方形ツールバーボタン -->
  <Style Selector="Button.toolbarBtn.square">
    <Setter Property="Width" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <!-- ============ new: 表示軸セレクタ(トリガの軸グリフ) TMP-UI-CMP-0021 ============
       トリガ本体は Button.toolbarBtn を流用。先頭の軸グリフ(FS=中立グレー / view=琥珀)。 -->
  <Style Selector="Border.axisIcon">
    <Setter Property="Width" Value="26" />
    <Setter Property="Height" Value="26" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Background" Value="{StaticResource IconBtnHoverBg}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.axisIcon.lg">
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="30" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>
  <Style Selector="Border.axisIcon PathIcon">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
    <Setter Property="Foreground" Value="{StaticResource ChipSimpleFg}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <!-- FS 軸=中立グレー(既定)/ view 軸=琥珀(ViewAxis*) -->
  <Style Selector="Border.axisIcon.view">
    <Setter Property="Background" Value="{StaticResource ViewAxisBg}" />
  </Style>
  <Style Selector="Border.axisIcon.view PathIcon">
    <Setter Property="Foreground" Value="{StaticResource ViewAxisFg}" />
  </Style>

  <!-- ============ new: ポップアップメニュー(軸/ソート共通) + メニュー行 ============
       軸=TMP-UI-CMP-0021 / ソート=TMP-UI-CMP-0023 のドロップダウン本体。 -->
  <Style Selector="Border.popupMenu">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="BoxShadow" Value="0 18 44 -14 #57142040" />
  </Style>
  <Style Selector="Button.menuRow">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="10,9" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="Button.menuRow /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.menuRow:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
  </Style>

  <!-- ============ new: ソート方向トグル TMP-UI-CMP-0023(方向ボタン) ============
       40×40 の枠ボタン。無効時(ソートなし)はグレー字+操作不可視覚。矢印回転は surface で。 -->
  <Style Selector="Button.sortDirBtn">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.sortDirBtn:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <Style Selector="Button.sortDirBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
  </Style>
  <Style Selector="Button.sortDirBtn:disabled">
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
  </Style>
  <Style Selector="Button.sortDirBtn PathIcon">
    <Setter Property="Width" Value="17" />
    <Setter Property="Height" Value="17" />
  </Style>

  <!-- ============ new: パンくず TMP-UI-CMP-0025(ホーム + › + クラム + 件数) ============ -->
  <Style Selector="Border.breadcrumbBar">
    <Setter Property="MinHeight" Value="46" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="18,0" />
  </Style>
  <!-- ホーム(現在地=ルート時はアクセント淡青) -->
  <Style Selector="Button.crumbHome">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.crumbHome:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
  </Style>
  <Style Selector="Button.crumbHome.active">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Button.crumbHome.active /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Button.crumbHome PathIcon">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
  </Style>
  <!-- クラム(中間=muted500 / 末尾=濃 SemiBold) -->
  <Style Selector="Button.crumb">
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="9,0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.crumb:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
  </Style>
  <Style Selector="Button.crumb.last">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
  </Style>
  <!-- パンくず区切り › / 件数ラベル -->
  <Style Selector="PathIcon.crumbSep">
    <Setter Property="Width" Value="13" />
    <Setter Property="Height" Value="13" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
  </Style>
  <Style Selector="TextBlock.crumbCount">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ============ covered→primitive: グリッド/リスト切替セグメント TMP-UI-CMP-0024 ====
       台帳は covered(ナビ pill と同型)だが既存クラス未存在のため基本部品として追加。 -->
  <Style Selector="Border.segmented">
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="3" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.segBtn">
    <Setter Property="Width" Value="38" />
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.segBtn /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.segBtn.active /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
  </Style>
  <Style Selector="Button.segBtn.active">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Button.segBtn PathIcon">
    <Setter Property="Width" Value="17" />
    <Setter Property="Height" Value="17" />
  </Style>
  <!-- テキスト用セグメント(整理トレイの 類似/条件 切替・ECO-014)。固定幅でなく内容に合わせる。 -->
  <Style Selector="Button.segBtnText">
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.segBtnText /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.segBtnText.active /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
  </Style>
  <Style Selector="Button.segBtnText.active">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>

  <!-- ============ extend: タグチップ(絞り込み/ナビ) TMP-UI-CMP-0026 ============
       h32 の押せるチップ。色付き active 状態はタグ色依存→surface バインド。本層は
       レイアウト + 中立(クリア)状態 + neutralActive(クリア選択中) を規定。 -->
  <Style Selector="Border.tagChip">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.tagChip:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <Style Selector="Border.tagChip TextBlock.chipLabel">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <!-- クリア チップが選択中(=絞り込み無し)。静的な青系。 -->
  <Style Selector="Border.tagChip.neutralActive">
    <Setter Property="BorderBrush" Value="{StaticResource CardSelectedBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.tagChip.neutralActive TextBlock.chipLabel">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <!-- チップ内 件数ピル(色はタグ色依存→surface。本層は形状のみ) -->
  <Style Selector="Border.chipCount">
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="7,1" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
  </Style>
  <Style Selector="Border.chipCount TextBlock">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource BadgeFg}" />
  </Style>
  <!-- ナビチップ末尾の › -->
  <Style Selector="PathIcon.chipNav">
    <Setter Property="Width" Value="13" />
    <Setter Property="Height" Value="13" />
    <Setter Property="Opacity" Value="0.5" />
  </Style>
  <!-- チップ行のヒント見出し(タグで絞り込み / 階層を掘る) -->
  <Style Selector="TextBlock.chipHint">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ============ extend: 空タグ注記バー TMP-UI-CMP-0029 ============ -->
  <Style Selector="Border.noteBar">
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="18,10" />
  </Style>
  <Style Selector="Border.noteBar PathIcon">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.noteBar TextBlock">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ============ new: 画像グリッドカード TMP-UI-CMP-0027 ============
       サムネ枠(1:1)+ 選択リング/チェック + タグドット(surface)+ 名前。
       GF-02: 選択視覚はセル枠+チェックのみ(行背景を出さない)。 -->
  <Style Selector="Border.thumbCell">
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
  </Style>
  <Style Selector="Border.thumbCell.selected">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="BoxShadow" Value="0 0 0 3 #382F6BED" />
  </Style>
  <!-- ECO-013: グリッドセルのホバー淡塗り(エクスプローラー同様・セル単位)+ 枠の淡い強調 -->
  <Style Selector="Border.thumbCellWrap">
    <Setter Property="CornerRadius" Value="13" />
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Border.thumbCellWrap:pointerover">
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
  </Style>
  <Style Selector="Border.thumbCellWrap:pointerover Border.thumbCell">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <Style Selector="TextBlock.thumbName">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    <Setter Property="Margin" Value="4,7,4,2" />
  </Style>
  <!-- 選択チェック overlay(GF-02)。選択塗りは surface で .selected を付与。 -->
  <Style Selector="Border.thumbCheck">
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="7" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="BorderBrush" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="Background" Value="#D9FFFFFF" />
    <Setter Property="BoxShadow" Value="0 1 3 0 #26000000" />
  </Style>
  <Style Selector="Border.thumbCheck.selected">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Border.thumbCheck PathIcon">
    <Setter Property="Width" Value="13" />
    <Setter Property="Height" Value="13" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- ============ new: 画像リスト行 TMP-UI-CMP-0028(ミニサムネ+名前+サイズ+更新日) ====
       選択=淡青行(GF-02: リスト行の選択視覚は正)。 -->
  <Style Selector="Border.imageListHeader">
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="Padding" Value="22,0" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>
  <Style Selector="Border.imageListHeader TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.imageListRow">
    <Setter Property="MinHeight" Value="46" />
    <Setter Property="Padding" Value="22,0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Border.imageListRow:pointerover">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
  </Style>
  <Style Selector="Border.imageListRow.selected">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.imageListRow.selected:pointerover">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Border.imageListMini">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="TextBlock.listName">
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>
  <Style Selector="TextBlock.listMeta">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ============ extend: コレクション rail(折り畳み時の縦アイコン列) TMP-UI-OCC-0010 ==== -->
  <Style Selector="Button.railIcon">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.railIcon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
  </Style>
  <Style Selector="Button.railIcon.selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource ChipTextBg}" />
  </Style>
  <Style Selector="Button.railIcon.selected">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Button.railIcon PathIcon">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
  </Style>

  <!-- ============ extend: タグ編集パネル(容器/ヘッダ) TMP-UI-CMP-0030 ============
       容器=左境界の文脈ペイン。ヘッダは cardHeader(60px 相当)。枚数 pill=accentPill・×=iconBtn を再利用。-->
  <Style Selector="Border.editPanel">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderLineBrush}" />
    <Setter Property="BorderThickness" Value="1,0,0,0" />
  </Style>
  <Style Selector="Border.editPanelHeader">
    <Setter Property="MinHeight" Value="60" />
    <Setter Property="Padding" Value="16,0" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <!-- ============ new: パネルタブ(現在のタグ / タグ追加) TMP-UI-CMP-0031 ============
       active=下線青+主青字+白面。タグタブにタブ部品は未製造のため新規。 -->
  <Style Selector="Button.panelTab">
    <Setter Property="Height" Value="38" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="9,9,0,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.panelTab /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="Button.panelTab.active">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Button.panelTab.active /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
  </Style>

  <!-- ============ extend: タグ追加行 TMP-UI-CMP-0033 ============
       dot+名前+(✓追加済/キャレット/+)。展開中=タグ色枠/淡面(色依存→surface)。
       本層は h42 行レイアウトと「既定/追加済」の静的視覚。種別グループ見出しは typeChip 再利用。 -->
  <Style Selector="Border.tagAddRow">
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
  </Style>
  <Style Selector="Border.tagAddRow:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource CardHoverBorderBrush}" />
  </Style>
  <!-- 付与済(操作不可・沈める) -->
  <Style Selector="Border.tagAddRow.added">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
  </Style>
  <Style Selector="Border.tagAddRow TextBlock.addName">
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>
  <Style Selector="Border.tagAddRow.added TextBlock.addName">
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
  </Style>
  <!-- 追加済バッジ / + / キャレット(末尾アフォーダンス) -->
  <Style Selector="TextBlock.addedBadge">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="PathIcon.addAffordance">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ============ new(容器)+ extend(セル): インライン値ピッカー TMP-UI-CMP-0034/0035 ====
       右パネル内インライン展開(原則 I-04)。container=淡面の枠箱。
       テキスト=候補値チップ(valueChip.selected で塗り)/数値=範囲セル(numCell)。
       選択塗りはタグ色依存→surface。本層は形状・amber 言語・未選択視覚。 -->
  <Style Selector="Border.inlinePicker">
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="Padding" Value="12,11" />
    <Setter Property="Margin" Value="30,6,0,2" />
  </Style>
  <Style Selector="Border.inlinePicker TextBlock.pickerHint">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
  </Style>
  <!-- 候補値チップ 選択時(covered: CMP-0034)。塗り色はタグ色依存→surface が Background/Foreground 上書き。 -->
  <Style Selector="Border.valueChip.selected">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
  </Style>
  <Style Selector="Border.valueChip.selected TextBlock">
    <Setter Property="Foreground" Value="White" />
  </Style>
  <!-- 数値セル(extend: CMP-0035)。amber 言語(RangePill)。選択=塗り(色依存→surface)。 -->
  <Style Selector="Border.numCell">
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource RangePillBg}" />
    <Setter Property="Background" Value="{StaticResource RangePillBg}" />
    <Setter Property="MinHeight" Value="38" />
  </Style>
  <Style Selector="Border.numCell TextBlock">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource RangePillFg}" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.numCell.selected TextBlock">
    <Setter Property="Foreground" Value="White" />
  </Style>
  <!-- 現在値表示(★ N / 未設定) -->
  <Style Selector="TextBlock.numCurrent">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource RangePillFg}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ============================================================================
       整理トレイ(ECO-014: 類似+マージ統合)— 右ペイン部品 + 中央検索結果 + グリッド整理マーカー。
       既存の編集パネル/カード/チップ語彙を踏襲。golden 基準=「ViewPrism2 整理マージ」モック。
       ============================================================================ -->

  <!-- セクション見出し(マージ先 / 整理対象 / 似た画像を探す) -->
  <Style Selector="TextBlock.traySection">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
  </Style>

  <!-- スロット(マージ先 / 整理対象)カード: ミニサムネ + 名前/サイズ + アクション -->
  <Style Selector="Border.organizeSlot">
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
  </Style>
  <Style Selector="Border.organizeSlot.target">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
    <Setter Property="BoxShadow" Value="0 0 0 2 #2F2F6BED" />
  </Style>
  <Style Selector="Border.organizeMini">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
  </Style>

  <!-- トレイの空状態注記(残したい1枚を選ぶ / まとめる相手がない) -->
  <Style Selector="Border.trayHint">
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="Padding" Value="14,16" />
  </Style>
  <Style Selector="Border.trayHint TextBlock">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <!-- 主要アクション(マージを実行)= 塗りボタン。無効時は沈める。 -->
  <Style Selector="Button.primaryAction">
    <Setter Property="Height" Value="44" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.primaryAction /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="CornerRadius" Value="11" />
  </Style>
  <Style Selector="Button.primaryAction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#2459CF" />
  </Style>
  <Style Selector="Button.primaryAction:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#2459CF" />
  </Style>
  <Style Selector="Button.primaryAction:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{StaticResource ValueChipBg}" />
  </Style>
  <Style Selector="Button.primaryAction:disabled">
    <Setter Property="Foreground" Value="{StaticResource FaintTextBrush}" />
  </Style>

  <!-- 検索結果カード(中央ペイン): サムネ + 名前 + 一致率 + 追加アクション -->
  <Style Selector="Border.resultCard">
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
    <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>
  <Style Selector="Border.resultCard.added">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
  </Style>
  <!-- 一致率バッジ(類似=N% / 条件=条件一致) -->
  <Style Selector="Border.matchBadge">
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="Background" Value="#E6101828" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="Margin" Value="8" />
  </Style>
  <Style Selector="Border.matchBadge TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- 完了状態カード(統合しました) -->
  <Style Selector="Border.organizeDoneCard">
    <Setter Property="CornerRadius" Value="13" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="Background" Value="{StaticResource BadgeBg}" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <!-- グリッドの整理マーカー: マージ先=accent リング / 整理対象=チェック(thumbCheck 再利用) -->
  <Style Selector="Border.thumbCell.mergeTarget">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    <Setter Property="BoxShadow" Value="0 0 0 3 #382F6BED" />
  </Style>
  <!-- セル左上の整理ラベル(マージ先) -->
  <Style Selector="Border.cellTag">
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="7,2" />
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Margin" Value="7" />
  </Style>
  <Style Selector="Border.cellTag TextBlock">
    <Setter Property="FontSize" Value="10.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- ============ 作業モード(ECO-017): 緑系部品 ============ -->
  <!-- 作業ボタン active = 緑塗り(#16a34a・白字)。青の toolbarBtn.active とは別の designIntent(作業=緑) -->
  <Style Selector="Button.toolbarBtn.workActive">
    <Setter Property="BorderBrush" Value="#16A34A" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="Button.toolbarBtn.workActive /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#16A34A" />
  </Style>
  <Style Selector="Button.toolbarBtn.workActive PathIcon">
    <Setter Property="Foreground" Value="White" />
  </Style>

  <!-- 「追加」ボタン: 既定=淡緑 disabled(選択なし)/ .ready=緑塗り(選択あり) -->
  <Style Selector="Button.workAddBtn">
    <Setter Property="Height" Value="40" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="13,0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="#CFE7D4" />
    <Setter Property="Foreground" Value="#9FC3AC" />
    <Setter Property="FontSize" Value="13.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.workAddBtn /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#EEF8F1" />
  </Style>
  <!-- disabled(選択なし)= モック準拠の淡緑を不透明で保つ(既定の減光を打ち消す) -->
  <Style Selector="Button.workAddBtn:disabled">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="Foreground" Value="#9FC3AC" />
  </Style>
  <Style Selector="Button.workAddBtn:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#EEF8F1" />
    <Setter Property="TextElement.Foreground" Value="#9FC3AC" />
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="Button.workAddBtn PathIcon">
    <Setter Property="Width" Value="16" />
    <Setter Property="Height" Value="16" />
    <Setter Property="Foreground" Value="#9FC3AC" />
  </Style>
  <Style Selector="Button.workAddBtn.ready">
    <Setter Property="BorderBrush" Value="#16A34A" />
    <Setter Property="Foreground" Value="White" />
  </Style>
  <Style Selector="Button.workAddBtn.ready /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#16A34A" />
  </Style>
  <Style Selector="Button.workAddBtn.ready:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#15924A" />
  </Style>
  <Style Selector="Button.workAddBtn.ready PathIcon">
    <Setter Property="Foreground" Value="White" />
  </Style>
  <!-- 選択件数バッジ(白地・緑字) -->
  <Style Selector="Border.workAddBadge">
    <Setter Property="MinWidth" Value="20" />
    <Setter Property="Height" Value="20" />
    <Setter Property="Padding" Value="6,0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="White" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
  <Style Selector="Border.workAddBadge TextBlock">
    <Setter Property="FontSize" Value="11.5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#16A34A" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- 作業対象チップ(bg #eafaf0 / border #c2ecd2 / 字 #0f8a4d) -->
  <Style Selector="Border.workTargetChip">
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="#C2ECD2" />
    <Setter Property="Background" Value="#EAFAF0" />
  </Style>
  <Style Selector="Border.workTargetChip TextBlock">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#0F8A4D" />
  </Style>
  <Style Selector="Border.workTargetChip PathIcon">
    <Setter Property="Foreground" Value="#0F8A4D" />
  </Style>
</Styles>
