#!/bin/sh
# bomdd integrity pre-commit hook
# ─────────────────────────────────────────────────────────────
# bomdd/ 配下を含むコミット時に integrity validator を実行し、ERROR があれば commit をブロックする。
# 有効化(クローンごとに1回):  git config core.hooksPath bomdd/hooks
# 手動実行:                    python bomdd/validate_bom.py
#
# 規律: python/PyYAML が無い環境では fail-open(skip)し、コミットを wedge しない。
#       ブロックするのは「validator が ERROR を返したとき」だけ。

# ─── publication-safety gate(ECO-057) ───────────────────────
# Git 管理外の画像も ZIP/手動公開には混入するため、コミット対象に関係なく作業ツリー全体を検査する。
# secret/私有端末パス/私有画像識別子/未承認 media のいずれかを検出したら fail-closed。
AUDIT_PY=""
for c in python python3 py; do
  if command -v "$c" >/dev/null 2>&1; then
    AUDIT_PY="$c"; break
  fi
done
if [ -z "$AUDIT_PY" ]; then
  echo "[public-release] Python が見つからない — 公開安全検査を実行できないため commit をブロックしました。"
  exit 1
fi
if [ -f bomdd/audit_public_release.py ]; then
  echo "[public-release] privacy/media/secret audit..."
  if ! "$AUDIT_PY" bomdd/audit_public_release.py; then
    echo "[public-release] 公開禁止情報を検出 — commit をブロックしました。"
    exit 1
  fi
fi

# 以降の BOM 検査は bomdd/ に触れないコミットでは省略する(高速化)
git diff --cached --name-only | grep -q '^bomdd/' || exit 0

# PyYAML を実際に import できるインタプリタを選ぶ(python3 が yaml 無しスタブのことがある)
PY=""
for c in python python3 py; do
  if command -v "$c" >/dev/null 2>&1 && "$c" -c "import yaml" >/dev/null 2>&1; then
    PY="$c"; break
  fi
done
if [ -z "$PY" ]; then
  echo "[bomdd] PyYAML 付き python が見つからない — integrity validator を skip(commit は許可)"
  exit 0
fi

echo "[bomdd] integrity validator..."
"$PY" bomdd/validate_bom.py --quiet
rc=$?

if [ "$rc" -eq 1 ]; then
  echo "[bomdd] integrity ERROR — commit をブロックしました。"
  echo "        修正後に再コミット(詳細: python bomdd/validate_bom.py)。"
  echo "        どうしても通す場合のみ: git commit --no-verify"
  exit 1
fi
if [ "$rc" -eq 2 ]; then
  echo "[bomdd] validator 実行不能(PyYAML 不在?)— skip(commit は許可)"
fi

# ─── validator selftest(ECO-053)──────────────────────────────
# 陽性対照: 「必ず検出されるべき合成フィクスチャ」を検出できるかを毎コミットで確認する。
# validator の 0-0 は「健全」と「検査が止まっている」を区別できない(ECO-034 のキー改名で
# E9〜E11 が 3 日間 no-op 化・ECO-049 の重複キー事故を素通しした実績)ため、沈黙の検査器を
# ここで検出する。FAIL は検査器自身の欠陥=ブロック(fail-open は環境問題のみ)。
if ! "$PY" bomdd/validate_bom.py --selftest >/dev/null 2>&1; then
  echo "[bomdd] validator selftest FAIL — 検査器が素通し状態の疑い(ECO-053 様式)。commit をブロックしました。"
  echo "        詳細: python bomdd/validate_bom.py --selftest"
  exit 1
fi

# ─── bomdd-lint(BomDD-Plm 参照層リンタ・2026-07-03 追加)─────────────
# workspace(自リポ+ViewPrismUI)を error ゲートで lint(warn/info は通す)。
# 単一リポ実行だと正当な ViewPrismUI: 形 cross-repo パス参照が不解決になるため workspace が正
# (repo: 形の repo 不在を skip にしない仕様非対称は BomDD-Plm ECO-002 候補として記録済み)。
# fail-open: 隣接リポの CLI / ViewPrismUI が無ければ skip(exit 2)。
PLM_CLI="../BomDD-Plm/packages/cli/dist/main.js"
if command -v node >/dev/null 2>&1 && [ -f "$PLM_CLI" ] && [ -f bomdd-workspace.yaml ]; then
  LINT_OUT="${TMPDIR:-/tmp}/bomdd-lint-vp2-$$"
  node "$PLM_CLI" bomdd-workspace.yaml --fail-on error --out "$LINT_OUT" >/dev/null 2>&1
  lrc=$?
  rm -rf "$LINT_OUT" 2>/dev/null
  if [ "$lrc" = "1" ]; then
    echo "[bomdd-lint] error 所見 — commit をブロックしました。"
    echo "             詳細: node $PLM_CLI ."
    echo "             どうしても通す場合のみ: git commit --no-verify"
    exit 1
  fi
  # exit 2(実行障害)は fail-open(コミットを wedge しない)
fi
exit 0
